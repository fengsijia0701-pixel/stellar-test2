---
import timelineData from '../data/timeline.json';
import ExperienceCard from './ExperienceCard.astro';

const projectColorMap: Record<string, { bg: string, border: string, text: string, icon: string }> = {
  accent: { bg: 'bg-accent/20', border: 'border-accent', text: 'text-accent', icon: '📕' },
  highlight: { bg: 'bg-highlight/30', border: 'border-highlight', text: 'text-dark', icon: '🛍️' },
  sky: { bg: 'bg-sky/20', border: 'border-sky', text: 'text-sky', icon: '📕' },
  secondary: { bg: 'bg-secondary/20', border: 'border-secondary', text: 'text-secondary', icon: '📕' },
};

const compColorMap: Record<string, { bg: string, border: string, text: string }> = {
  accent: { bg: 'bg-accent/20', border: 'border-accent', text: 'text-accent' },
  highlight: { bg: 'bg-highlight/30', border: 'border-highlight', text: 'text-dark' },
  sky: { bg: 'bg-sky/20', border: 'border-sky', text: 'text-sky' },
  secondary: { bg: 'bg-secondary/20', border: 'border-secondary', text: 'text-secondary' },
};
---

<section id="about" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="font-heading text-4xl font-bold text-dark text-center mb-12">
      关于我
    </h2>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- 个人介绍 -->
      <div class="bg-cardBg rounded-stardew p-8 border-2 border-highlight/30">
        <h3 class="font-heading text-2xl font-semibold text-dark mb-4 flex items-center gap-2">
          <span>🌻</span> 我是谁
        </h3>
        <p class="text-dark/70 leading-relaxed">
          港大市场营销硕士，专注量化营销与 AI 产品运营。曾主导 TikTok 斋月大促实现 Fashion GMV 52% 增长，小红书 AIGC 笔记内测带动客户消耗提升，美团活动 GTV 同比增长 85%。擅长数据驱动决策与大促策略制定。
        </p>
        <p class="text-dark/70 leading-relaxed mt-4">
          相信好的产品力 + 运营力 + 数据力，能够创造可持续的增长飞轮。
        </p>
      </div>

      <!-- 教育背景 -->
      <div>
        <h3 class="font-heading text-2xl font-semibold text-dark mb-6 flex items-center gap-2">
          <span>🎓</span> 教育背景
        </h3>
        <div class="space-y-6">
          {timelineData.education.map((item) => (
            <div class="relative pl-6 border-l-2 border-secondary/40">
              <div class="absolute -left-2 top-0 w-3 h-3 bg-secondary rounded-full" />
              <span class="text-sm text-secondary font-medium">{item.period}</span>
              <h4 class="font-heading text-lg font-semibold text-dark mt-1">{item.title}</h4>
              <p class="text-dark/60 text-sm">{item.subtitle}</p>
              <p class="text-dark/50 text-xs mt-1">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- 项目经历 -->
    <div class="mt-20">
      <h3 class="font-heading text-2xl font-semibold text-dark mb-8 flex items-center gap-2">
        <span>🚀</span> 项目经历
      </h3>
      <div class="grid md:grid-cols-2 gap-6">
        {timelineData.projects.map((item) => {
          const colors = projectColorMap[item.color] || projectColorMap.accent;
          return (
            <div class={`${colors.bg} border-2 ${colors.border} rounded-stardew p-6 hover:shadow-stardew-lg transition-all duration-300 hover:-translate-y-1`}>
              <div class="flex items-start gap-3">
                <span class="text-3xl">{item.icon}</span>
                <div>
                  <h4 class="font-heading text-lg font-bold text-dark">{item.title}</h4>
                  <p class="text-dark/60 text-sm">{item.subtitle}</p>
                  <p class="text-dark/50 text-xs mt-1">{item.period} · {item.role}</p>
                </div>
              </div>
              <p class="text-dark/70 text-sm mt-4">{item.description}</p>
              <div class="flex flex-wrap gap-2 mt-4">
                {item.highlights.map((h: string) => (
                  <span class={`px-2 py-1 rounded-full text-xs ${colors.bg} ${colors.text}`}>{h}</span>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- 竞赛经历 -->
    <div class="mt-20">
      <h3 class="font-heading text-2xl font-semibold text-dark mb-8 flex items-center gap-2">
        <span>🏆</span> 竞赛经历
      </h3>
      <div class="grid md:grid-cols-3 gap-6">
        {timelineData.competitions.map((item) => {
          const colors = compColorMap[item.color] || compColorMap.accent;
          return (
            <div class={`${colors.bg} border-2 ${colors.border} rounded-stardew p-6 hover:shadow-stardew-lg transition-all duration-300 hover:-translate-y-1 cursor-default group`}>
              <div class="text-center">
                <span class="text-4xl">{item.icon}</span>
                <h4 class="font-heading text-lg font-bold text-dark mt-3">{item.title}</h4>
                <p class="text-dark/60 text-sm mt-1">{item.subtitle}</p>
                <p class={`${colors.text} text-sm font-medium mt-2`}>{item.role}</p>
                <p class="text-dark/50 text-xs mt-1">{item.period}</p>
              </div>
              <p class="text-dark/70 text-sm mt-4 text-center">{item.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>