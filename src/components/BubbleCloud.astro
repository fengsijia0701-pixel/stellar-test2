---
interface BubbleItem {
  name: string;
  size?: string;
  role?: string;
  period?: string;
  type?: string;
  detail?: string;
}

interface Props {
  items: BubbleItem[];
  type: 'company' | 'certificate' | 'skill' | 'hobby';
}

const { items, type } = Astro.props;

// Color mapping based on bubble type
const colorMap = {
  company: {
    bg: 'bg-sky/20',
    border: 'border-sky',
    text: 'text-sky',
    hover: 'hover:bg-sky/30',
  },
  certificate: {
    bg: 'bg-highlight/30',
    border: 'border-highlight',
    text: 'text-dark',
    hover: 'hover:bg-highlight/40',
  },
  skill: {
    bg: 'bg-secondary/20',
    border: 'border-secondary',
    text: 'text-secondary',
    hover: 'hover:bg-secondary/30',
  },
  hobby: {
    bg: 'bg-accent/20',
    border: 'border-accent',
    text: 'text-accent',
    hover: 'hover:bg-accent/30',
  },
};

// Size mapping for company bubbles
const sizeMap = {
  large: 'w-32 h-32 text-base',
  medium: 'w-24 h-24 text-sm',
  small: 'w-20 h-20 text-xs',
};

// Default size for non-company bubbles
const defaultSize = 'w-24 h-24 text-sm';

const colors = colorMap[type];
---

<div class="bubble-cloud flex flex-wrap justify-center items-center gap-4 md:gap-6">
  {items.map((item) => {
    const bubbleSize = type === 'company' && item.size
      ? sizeMap[item.size as keyof typeof sizeMap] || defaultSize
      : defaultSize;

    return (
      <div
        class={`bubble-item relative group ${bubbleSize} ${colors.bg} border-2 ${colors.border} rounded-full flex items-center justify-center p-2 cursor-default transition-all duration-300 hover:scale-110 hover:shadow-stardew-lg ${colors.hover}`}
        data-has-tooltip={item.role || item.detail ? 'true' : 'false'}
      >
        {/* Pixel-style corner accents */}
        <div class="absolute inset-0 rounded-full overflow-hidden">
          <div class="absolute top-0 left-0 w-2 h-2 bg-white/50 transform -translate-x-1 -translate-y-1"></div>
          <div class="absolute top-0 right-0 w-2 h-2 bg-white/50 transform translate-x-1 -translate-y-1"></div>
          <div class="absolute bottom-0 left-0 w-2 h-2 bg-white/50 transform -translate-x-1 translate-y-1"></div>
          <div class="absolute bottom-0 right-0 w-2 h-2 bg-white/50 transform translate-x-1 translate-y-1"></div>
        </div>

        {/* Floating animation with staggered delay */}
        <div class="animate-float" style={`animation-delay: ${Math.random() * 2}s`}>
          <span class={`font-heading font-bold ${colors.text} text-center leading-tight`}>
            {item.name}
          </span>
        </div>

        {/* Tooltip on hover */}
        {(item.role || item.detail) && (
          <div class="tooltip opacity-0 group-hover:opacity-100 absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 whitespace-nowrap z-20">
            <div class="bg-dark text-light px-3 py-2 rounded-lg shadow-lg text-sm">
              {item.role && <div class="font-medium">{item.role}</div>}
              {item.detail && <div class="text-dark/70">{item.detail}</div>}
              {item.period && <div class="text-dark/50 text-xs mt-1">{item.period}</div>}
            </div>
            {/* Tooltip arrow */}
            <div class="absolute top-full left-1/2 transform -translate-x-1/2 -mt-1">
              <div class="w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-dark"></div>
            </div>
          </div>
        )}
      </div>
    );
  })}
</div>

<style>
  /* Floating animation */
  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  /* Pixel-style dashed border effect */
  .bubble-item::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 4px,
      rgba(58, 46, 42, 0.1) 4px,
      rgba(58, 46, 42, 0.1) 8px
    );
    pointer-events: none;
  }

  /* Enhanced hover glow */
  .bubble-item:hover::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: inherit;
    background: radial-gradient(circle, rgba(242, 211, 136, 0.3) 0%, transparent 70%);
    z-index: -1;
    animation: pulse-glow 1.5s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.05);
    }
  }
</style>