---
import timeline from '../data/timeline.json';

const competitions = timeline.competitions;

const medals = ['🥇', '🥈', '🥉'];
---

<section id="competitions" class="fullscreen-page stardew-page">
  <div class="grass-sky-background"></div>

  <div class="stardew-panel content-panel">
    <h1 class="stardew-title">🏆 竞赛经历</h1>

    <div class="content-area">
      <div class="competition-list">
        {competitions.map((comp, index) => (
          <div class="competition-card">
            <div class="comp-medal">{medals[index] || '🏅'}</div>
            <div class="comp-icon">{comp.icon}</div>
            <h3>{comp.title}</h3>
            <p class="comp-role">{comp.role}</p>
            <p class="comp-desc">{comp.description}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="navigation-buttons">
      <button id="backBtn" class="stardew-button" data-target="rpg-map">◀ 返回地图</button>
    </div>
  </div>
</section>

<style>
  .fullscreen-page {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .stardew-page {
    background: linear-gradient(to bottom,
      #87CEEB 0%,
      #87CEEB 40%,
      #90EE90 40%,
      #7CB342 100%
    );
  }

  .grass-sky-background {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 20px,
        rgba(124, 179, 66, 0.15) 20px,
        rgba(124, 179, 66, 0.15) 40px
      );
  }

  .content-panel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 700px;
    max-height: 85vh;
    padding: 30px;
    z-index: 10;
  }

  .stardew-title {
    text-align: center;
    margin-bottom: 20px;
  }

  .content-area {
    padding: 10px 0;
    max-height: 55vh;
    overflow-y: auto;
  }

  .competition-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .competition-card {
    background: rgba(255, 255, 255, 0.85);
    border: 3px solid var(--color-wood);
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 0 var(--color-wood-dark);
    position: relative;
  }

  .comp-medal {
    position: absolute;
    top: -10px;
    right: -10px;
    font-size: 2rem;
  }

  .comp-icon {
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .competition-card h3 {
    font-family: 'Gaegu', cursive;
    font-size: 1.3rem;
    color: var(--color-wood-dark);
    margin-bottom: 6px;
  }

  .comp-role {
    font-family: 'Gaegu', cursive;
    font-size: 1rem;
    color: var(--color-grass);
    font-weight: 700;
    margin-bottom: 8px;
  }

  .comp-desc {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .navigation-buttons {
    text-align: center;
    margin-top: 20px;
    padding-top: 15px;
    border-top: 2px dashed var(--color-wood-light);
  }

  /* Scrollbar styling */
  .content-area::-webkit-scrollbar {
    width: 8px;
  }

  .content-area::-webkit-scrollbar-track {
    background: var(--color-parchment);
    border-radius: 4px;
  }

  .content-area::-webkit-scrollbar-thumb {
    background: var(--color-wood);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .content-panel {
      width: 95%;
      padding: 20px;
    }

    .comp-icon {
      font-size: 2rem;
    }

    .competition-card h3 {
      font-size: 1.1rem;
    }

    .comp-medal {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  import { soundEffects } from '../scripts/sound';

  document.addEventListener('DOMContentLoaded', () => {
    const backBtn = document.getElementById('backBtn');
    if (backBtn) {
      backBtn.addEventListener('click', () => {
        soundEffects.playClick();
        const target = backBtn.getAttribute('data-target');
        if (target) {
          document.getElementById(target)?.scrollIntoView({ behavior: 'smooth' });
        }
      });
    }

    document.querySelectorAll('.stardew-button').forEach(btn => {
      btn.addEventListener('click', () => {
        soundEffects.playClick();
      });
    });
  });
</script>