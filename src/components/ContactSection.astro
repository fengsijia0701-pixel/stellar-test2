---
---

<section id="contact" class="py-20 bg-dark text-white">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="font-heading text-4xl font-bold text-white mb-4">
      联系我
    </h2>
    <p class="text-white/60 mb-8 max-w-lg mx-auto">
      对我的作品感兴趣？想聊聊产品/运营/AI 方向的机会？随时联系我~
    </p>

    <!-- Email -->
    <div class="mb-8">
      <button id="copy-email" class="group inline-flex items-center gap-3 px-6 py-3 bg-white/10 hover:bg-white/20 rounded-full transition-colors">
        <svg class="w-5 h-5 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span class="text-white">2806427544@qq.com</span>
        <span class="copy-hint text-sm text-white/50 opacity-0 group-hover:opacity-100 transition-opacity">
          点击复制
        </span>
      </button>
    </div>

    <!-- Toast -->
    <div id="copy-toast" class="fixed bottom-8 left-1/2 transform -translate-x-1/2 px-4 py-2 bg-secondary text-white rounded-full text-sm opacity-0 pointer-events-none transition-opacity duration-300">
      邮箱已复制到剪贴板 ✓
    </div>

    <!-- Social Links -->
    <div class="flex justify-center gap-6">
      <!-- LinkedIn -->
      <a href="#" target="_blank" rel="noopener noreferrer" class="p-3 hover:bg-white/10 rounded-full transition-colors" aria-label="LinkedIn">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <!-- 小红书 -->
      <a href="#" target="_blank" rel="noopener noreferrer" class="p-3 hover:bg-white/10 rounded-full transition-colors" aria-label="小红书">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  const copyEmailBtn = document.getElementById('copy-email');
  const copyToast = document.getElementById('copy-toast');

  copyEmailBtn?.addEventListener('click', async () => {
    const email = '2806427544@qq.com';
    try {
      await navigator.clipboard.writeText(email);
      copyToast?.classList.remove('opacity-0', 'pointer-events-none');
      copyToast?.classList.add('opacity-100');
      setTimeout(() => {
        copyToast?.classList.add('opacity-0', 'pointer-events-none');
        copyToast?.classList.remove('opacity-100');
      }, 2000);
    } catch (err) {
      console.error('Failed to copy email:', err);
    }
  });
</script>