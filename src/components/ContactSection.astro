---

<section class="page-section">
  <div class="bg-sky"></div>
  <div class="bg-grass"></div>

  <div class="wood-frame">
    <div class="parchment">
      <h1 class="title">📮 联系中心</h1>

      <p class="intro">
        对我的作品感兴趣？想聊聊产品/运营/AI 方向的机会？
      </p>

      <div class="email-box">
        <button id="copy-email" class="email-btn">
          <span class="email-icon">✉️</span>
          <span class="email-address">2806427544@qq.com</span>
          <span class="copy-hint">点击复制</span>
        </button>
      </div>

      <div id="copy-toast" class="toast">邮箱已复制 ✓</div>

      <div class="social-links">
        <a href="#" class="social-link" target="_blank">
          <span>🔗</span> LinkedIn
        </a>
        <a href="#" class="social-link" target="_blank">
          <span>📕</span> 小红书
        </a>
      </div>

      <div class="nav-bar">
        <button class="wood-btn" data-action="goto" data-goto="page-map">◀ 返回地图</button>
      </div>
    </div>
  </div>
</section>

<style>
  .page-section {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(180deg, #87CEEB 0%, #B4E7CE 100%);
  }

  .bg-grass {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, #7CB342 0%, #558B2F 100%);
  }

  .wood-frame {
    position: relative;
    z-index: 10;
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 8px;
    padding: 10px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    max-width: 500px;
    width: 90%;
  }

  .parchment {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 30px;
    text-align: center;
  }

  .title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 2rem;
    color: #5D3A1A;
    margin-bottom: 16px;
  }

  .intro {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1rem;
    color: #6B5344;
    margin-bottom: 20px;
  }

  .email-box {
    margin-bottom: 12px;
  }

  .email-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: rgba(255, 255, 255, 0.7);
    border: 3px solid #8B4513;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .email-btn:hover {
    transform: scale(1.02);
    background: rgba(255, 255, 255, 0.9);
  }

  .email-icon {
    font-size: 1.4rem;
  }

  .email-address {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1rem;
    color: #5D3A1A;
  }

  .copy-hint {
    font-size: 0.75rem;
    color: #8B4513;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .email-btn:hover .copy-hint {
    opacity: 1;
  }

  .toast {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 0.9rem;
    color: #FDF5E7;
    background: #7CB342;
    padding: 8px 16px;
    border-radius: 20px;
    display: inline-block;
    margin-bottom: 16px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .toast.show {
    opacity: 1;
  }

  .social-links {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 16px;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.7);
    border: 2px solid #8B4513;
    border-radius: 8px;
    color: #5D3A1A;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .social-link:hover {
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-2px);
  }

  .nav-bar {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 2px dashed #A67C52;
  }

  .wood-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 24px;
    background: linear-gradient(180deg, #8B4513 0%, #6B3E26 100%);
    color: #FDF5E7;
    border: none;
    border-radius: 6px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 3px 0 #5D3A1A;
    transition: all 0.15s ease;
  }

  .wood-btn:hover {
    transform: translateY(-2px);
    background: linear-gradient(180deg, #A0522D 0%, #8B4513 100%);
    box-shadow: 0 5px 0 #5D3A1A;
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-email');
  const toast = document.getElementById('copy-toast');

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('2806427544@qq.com');
      toast?.classList.add('show');
      setTimeout(() => {
        toast?.classList.remove('show');
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
    }
  });
</script>