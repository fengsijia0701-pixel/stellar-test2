  const params = new URLSearchParams(window.location.search);
  const companyId = params.get('experience');

  // Render content
  const container = document.getElementById('detail-content');
  if (container) {
    const exp = experiences.find(e => e.id === companyId);

    if (exp) {
      container.innerHTML = `
        <div class="company-header">
          <div class="company-icon">${exp.icon}</div>
          <h2 class="company-title">${exp.title}</h2>
          <p class="company-subtitle">${exp.subtitle}</p>
          <p class="company-period">${exp.period}</p>
          <span class="company-brief">${exp.brief}</span>
        </div>

        <div class="projects-section">
          <h3 class="projects-title">📂 项目详情</h3>
          ${exp.projects.map(p => `
            <div class="project-card">
              <h4 class="project-name">${p.name}</h4>

              <div class="project-block">
                <div class="project-label">📌 背景</div>
                <div class="project-text">${p.background}</div>
              </div>

              <div class="project-block">
                <div class="project-label">⚡ 挑战</div>
                <div class="project-text">${p.challenge}</div>
              </div>

              <div class="project-block">
                <div class="project-label">💡 解决方案</div>
                <div class="project-text">${p.solution}</div>
              </div>

              <div class="result-block">
                <div class="project-label">🎯 成果</div>
                <div class="project-text">${p.result}</div>
              </div>
