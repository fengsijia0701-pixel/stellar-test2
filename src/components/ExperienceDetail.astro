---
---

<section class="detail-page">
  <div class="bg-sky"></div>
  <div class="bg-grass"></div>

  <div class="wood-frame">
    <div class="parchment">
      <button class="back-btn" data-action="goto" data-goto="page-growth">◀ 返回成长轨迹</button>

      <div id="detail-content">
        <!-- Content injected by JS -->
      </div>
    </div>
  </div>
</section>

<style>
  .detail-page {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(180deg, #87CEEB 0%, #B4E7CE 100%);
  }

  .bg-grass {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, #7CB342 0%, #558B2F 100%);
  }

  .wood-frame {
    position: relative;
    z-index: 10;
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 8px;
    padding: 10px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    max-width: 700px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
  }

  .parchment {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 24px;
    max-height: 85vh;
    overflow-y: auto;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: linear-gradient(180deg, #8B4513 0%, #6B3E26 100%);
    color: #FDF5E6;
    border: none;
    border-radius: 6px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 0.95rem;
    cursor: pointer;
    box-shadow: 0 3px 0 #5D3A1A;
    margin-bottom: 16px;
    transition: all 0.15s ease;
  }

  .back-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 0 #5D3A1A;
  }

  /* Company Header */
  .company-header {
    text-align: center;
    padding-bottom: 16px;
    border-bottom: 3px dashed #A67C52;
    margin-bottom: 20px;
  }

  .company-icon {
    font-size: 3rem;
    margin-bottom: 8px;
  }

  .company-title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.8rem;
    color: #5D3A1A;
    margin-bottom: 4px;
  }

  .company-subtitle {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.1rem;
    color: #8B4513;
    margin-bottom: 8px;
  }

  .company-period {
    font-size: 0.9rem;
    color: #A67C52;
  }

  .company-brief {
    background: #8B4513;
    color: #FDF5E6;
    padding: 8px 16px;
    border-radius: 20px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1rem;
    display: inline-block;
    margin-top: 8px;
  }

  /* Projects */
  .projects-section {
    margin-top: 20px;
  }

  .projects-title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.3rem;
    color: #5D3A1A;
    text-align: center;
    margin-bottom: 16px;
  }

  .project-card {
    background: rgba(255, 255, 255, 0.85);
    border: 3px solid #8B4513;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    box-shadow: 0 4px 0 #5D3A1A;
  }

  .project-name {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.2rem;
    color: #5D3A1A;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .project-name::before {
    content: '📋';
    font-size: 1.2rem;
  }

  .project-block {
    margin-bottom: 12px;
  }

  .project-label {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 0.95rem;
    font-weight: 700;
    color: #8B4513;
    margin-bottom: 4px;
  }

  .project-text {
    font-size: 0.9rem;
    color: #6B5344;
    line-height: 1.5;
  }

  .result-block {
    background: #7CB342;
    color: #FDF5E6;
    padding: 10px 14px;
    border-radius: 8px;
    margin-top: 10px;
  }

  .result-block .project-label {
    color: #FDF5E6;
  }

  .result-block .project-text {
    color: #FDF5E6;
    font-weight: 700;
  }

  /* Scrollbar */
  .parchment::-webkit-scrollbar,
  .wood-frame::-webkit-scrollbar {
    width: 6px;
  }

  .parchment::-webkit-scrollbar-track,
  .wood-frame::-webkit-scrollbar-track {
    background: #F5E6C8;
    border-radius: 4px;
  }

  .parchment::-webkit-scrollbar-thumb,
  .wood-frame::-webkit-scrollbar-thumb {
    background: #8B4513;
    border-radius: 4px;
  }

  @media (max-width: 600px) {
    .wood-frame {
      width: 95%;
      padding: 8px;
    }

    .parchment {
      padding: 16px;
    }

    .company-icon {
      font-size: 2.5rem;
    }

    .company-title {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  // Experience data
  const experiences = [
