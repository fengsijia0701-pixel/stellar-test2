---

<section class="growth-page">
  <div class="bg-sky"></div>
  <div class="bg-grass"></div>

  <div class="decorations">
    <span class="deco" style="top: 8%; left: 5%;">🌲</span>
    <span class="deco" style="top: 12%; right: 6%;">🌳</span>
    <span class="deco" style="bottom: 30%; left: 8%;">🌿</span>
    <span class="deco" style="bottom: 22%; right: 5%;">🍀</span>
  </div>

  <div class="wood-frame">
    <div class="parchment">
      <h1 class="title">🌱 成长轨迹</h1>

      <div class="skill-tree">
        <!-- Finance Branch -->
        <div class="branch">
          <div class="branch-label">💼 金融/咨询</div>
          <div class="nodes">
            <button class="node" data-company="ey">
              <div class="node-icon">📊</div>
              <div class="node-company">安永</div>
              <div class="node-period">2023.12</div>
              <div class="node-tooltip">全球四大会计师事务所之一，专注审计与咨询</div>
            </button>
          </div>
        </div>

        <!-- Medical Branch -->
        <div class="branch">
          <div class="branch-label">🏥 医疗健康</div>
          <div class="nodes">
            <button class="node" data-company="merck">
              <div class="node-icon">💊</div>
              <div class="node-company">默克</div>
              <div class="node-period">2024.05</div>
              <div class="node-tooltip">全球TOP3制药公司，350年历史，专注医药健康</div>
            </button>
            <button class="node" data-company="medtronic">
              <div class="node-icon">🏥</div>
              <div class="node-company">美敦力</div>
              <div class="node-period">2024.09</div>
              <div class="node-tooltip">全球最大医疗器械公司，总部爱尔兰，专注高端医疗设备</div>
            </button>
          </div>
        </div>

        <!-- Internet Branch -->
        <div class="branch">
          <div class="branch-label">🌐 互联网</div>
          <div class="path-line"></div>
          <div class="nodes">
            <button class="node" data-company="hallo">
              <div class="node-icon">🚲</div>
              <div class="node-company">哈啰</div>
              <div class="node-period">2025.02</div>
              <div class="node-tooltip">阿里旗下智能出行平台，国内最大共享单车服务商</div>
            </button>
            <button class="node" data-company="meituan">
              <div class="node-icon">🚴</div>
              <div class="node-company">美团</div>
              <div class="node-period">2025.05</div>
              <div class="node-tooltip">中国最大本地生活服务平台，年活跃用户6亿+</div>
            </button>
            <button class="node" data-company="xiaohongshu">
              <div class="node-icon">📕</div>
              <div class="node-company">小红书</div>
              <div class="node-period">2025.09</div>
              <div class="node-tooltip">中国最大种草社区，2亿月活，专注生活方式分享</div>
            </button>
            <button class="node current" data-company="bytedance">
              <div class="node-icon">🌐</div>
              <div class="node-company">字节跳动</div>
              <div class="node-period">2026.01</div>
              <div class="node-tooltip">全球最大独角兽，TikTok母公司，估值超2000亿美元</div>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Company Detail Popup -->
  <div id="company-popup-overlay" class="popup-overlay" style="display: none;">
    <div id="company-popup" class="popup-card">
      <button class="popup-close">✕</button>
      <div class="popup-header">
        <span class="popup-icon"></span>
        <div class="popup-title">
          <h2 class="popup-company"></h2>
          <p class="popup-role"></p>
        </div>
      </div>
      <p class="popup-period"></p>
      <p class="popup-brief"></p>
      <div class="popup-projects">
        <h3>📂 项目详情</h3>
        <ul class="project-list"></ul>
      </div>
    </div>
  </div>
</section>

<script>
  // Company popup functionality - wait for companyDetails to be available
  function initPopup() {
    const nodes = document.querySelectorAll('.node[data-company]');
    const overlay = document.getElementById('company-popup-overlay');
    const popup = document.getElementById('company-popup');

    if (!overlay || !popup) return;

    const closeBtn = popup.querySelector('.popup-close');

    nodes.forEach(node => {
      node.addEventListener('click', () => {
        const companyId = node.dataset.company;
        const data = (window as any).companyDetails?.[companyId];
        console.log('[POPUP] companyId:', companyId, 'data:', data);
        console.log('[POPUP] window.playSound exists:', typeof (window as any).playSound);
        if (data) {
          popup.querySelector('.popup-icon').textContent = data.icon || '';
          popup.querySelector('.popup-company').textContent = data.name || '';
          popup.querySelector('.popup-role').textContent = data.role || '';
          popup.querySelector('.popup-period').textContent = data.period || '';
          popup.querySelector('.popup-brief').textContent = data.brief || '';

          const projectList = popup.querySelector('.project-list');
          if (data.projects && Array.isArray(data.projects) && data.projects.length > 0) {
            // Check if new format with objects or old format with strings
            if (typeof data.projects[0] === 'object') {
              projectList.innerHTML = data.projects.map((p: any, idx: number) => `
                <li class="project-item" data-index="${idx}">
                  <div class="project-summary">
                    <span class="project-arrow">▶</span>
                    <span class="project-title">${p.title || ''}</span>
                    <span class="project-sep">—</span>
                    <span class="project-highlight-tag">${p.highlight || ''}</span>
                  </div>
                  <div class="project-detail" style="display: none;">
                    <div class="project-desc">${p.desc || ''}</div>
                  </div>
                </li>
              `).join('');

              // Add click handlers for expand/collapse
              projectList.querySelectorAll('.project-summary').forEach(summary => {
                summary.addEventListener('click', (e) => {
                  e.stopPropagation(); // Prevent closing popup
                  const li = summary.closest('.project-item');
                  const detail = li?.querySelector('.project-detail');
                  const arrow = summary.querySelector('.project-arrow');
                  if (detail && arrow) {
                    const isHidden = detail.style.display === 'none';
                    detail.style.display = isHidden ? 'block' : 'none';
                    arrow.textContent = isHidden ? '▼' : '▶';
                    // Play expand/collapse sound
                    if (isHidden) {
                      (window as any).playSound?.('expand');
                    }
                  }
                });
              });
            } else {
              // Legacy string format
              projectList.innerHTML = data.projects.map((p: string) => `<li>${p}</li>`).join('');
            }
          } else {
            projectList.innerHTML = '<li>暂无项目详情</li>';
          }

          // Play popup open sound
          (window as any).playSound?.('popup');
          overlay.style.display = 'flex';
        }
      });
    });

    closeBtn?.addEventListener('click', () => {
      overlay.style.display = 'none';
    });

    // Prevent clicks inside popup card from closing the popup
    popup.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        overlay.style.display = 'none';
      }
    });
  }

  // Try to init immediately, or wait for DOMContentLoaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPopup);
  } else {
    initPopup();
  }
</script>

<style>
  .growth-page {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(180deg, #87CEEB 0%, #B4E7CE 100%);
  }

  .bg-grass {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(180deg, #7CB342 0%, #558B2F 100%);
  }

  .decorations {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .deco {
    position: absolute;
    font-size: 2rem;
    animation: sway 3s ease-in-out infinite;
  }

  @keyframes sway {
    0%, 100% { transform: rotate(-2deg); }
    50% { transform: rotate(2deg); }
  }

  .wood-frame {
    position: relative;
    z-index: 10;
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 8px;
    padding: 10px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .parchment {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 20px 30px;
    max-width: 750px;
    max-height: 88vh;
    overflow-y: auto;
  }

  .title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 2rem;
    color: #5D3A1A;
    text-align: center;
    margin-bottom: 16px;
  }

  .skill-tree {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .branch {
    background: rgba(255, 255, 255, 0.6);
    border-radius: 10px;
    padding: 12px;
  }

  .branch-label {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.6rem;
    font-weight: 700;
    color: white;
    background: #8B4513;
    padding: 5px 10px;
    border-radius: 15px;
    display: inline-block;
    margin-bottom: 10px;
  }

  .nodes {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .node {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #F5E6C8;
    border: 3px solid #8B4513;
    border-radius: 10px;
    padding: 10px 14px;
    min-width: 68px;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 3px 0 #5D3A1A;
    position: relative;
  }

  .node:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 0 #5D3A1A;
  }

  .node.current {
    border-color: #FFD700;
    background: #FFF8E7;
  }

  .node-icon {
    font-size: 1.6rem;
    margin-bottom: 2px;
  }

  .node-company {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.55rem;
    font-weight: 700;
    color: #5D3A1A;
    text-align: center;
    line-height: 1.4;
  }

  .node-period {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.5rem;
    color: #8B4513;
    margin-top: 4px;
  }

  /* Tooltip */
  .node-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: #5D3A1A;
    color: #FDF5E6;
    padding: 8px 14px;
    border-radius: 8px;
    font-family: 'Press Start 2P', cursive;
    font-size: 0.5rem;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    z-index: 100;
    box-shadow: 0 3px 8px rgba(0,0,0,0.3);
  }

  .node-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: #5D3A1A;
  }

  .node:hover .node-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(-4px);
  }

  .node-period {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.85rem;
    color: #8B4513;
  }

  .path-line {
    height: 4px;
    background: #8B4513;
    margin: 6px 0;
    border-radius: 2px;
  }

  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 16px;
    gap: 12px;
  }

  .wood-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: linear-gradient(180deg, #8B4513 0%, #6B3E26 100%);
    color: #FDF5E6;
    border: none;
    border-radius: 6px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 3px 0 #5D3A1A, 0 4px 8px rgba(0, 0, 0, 0.25);
    transition: all 0.15s ease;
  }

  .wood-btn:hover {
    transform: translateY(-2px);
    background: linear-gradient(180deg, #A0522D 0%, #8B4513 100%);
    box-shadow: 0 5px 0 #5D3A1A, 0 6px 12px rgba(0, 0, 0, 0.3);
  }

  .wood-btn:active {
    transform: translateY(1px);
    box-shadow: 0 2px 0 #5D3A1A, 0 3px 6px rgba(0, 0, 0, 0.2);
  }

  /* Company Popup Styles */
  .popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
  }

  .popup-card {
    background: linear-gradient(135deg, var(--color-wood), var(--color-wood-light));
    border: 4px solid var(--color-wood-dark);
    border-radius: 12px;
    padding: 24px 28px;
    max-width: 620px;
    width: 92%;
    max-height: 82vh;
    overflow-y: auto;
    position: relative;
    animation: popupSlideIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes popupSlideIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .popup-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    font-size: 1.3rem;
    cursor: pointer;
    color: var(--color-wood-dark);
    padding: 4px 8px;
  }

  .popup-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .popup-icon {
    font-size: 2.2rem;
  }

  .popup-title h2 {
    font-family: var(--font-game);
    font-size: 1.2rem;
    color: var(--color-cream);
    margin: 0;
  }

  .popup-role {
    font-family: var(--font-game);
    font-size: 0.95rem;
    color: var(--color-parchment);
    margin: 4px 0 0 0;
  }

  .popup-period {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-neon-yellow);
    margin-bottom: 10px;
  }

  .popup-brief {
    font-family: var(--font-game);
    font-size: 0.9rem;
    color: var(--color-cream);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .popup-projects h3 {
    font-family: var(--font-game);
    font-size: 0.95rem;
    color: var(--color-neon-green);
    margin-bottom: 10px;
  }

  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-list li {
    font-family: var(--font-game);
    font-size: 0.85rem;
    color: var(--color-parchment);
    padding: 10px 0;
    border-bottom: 1px solid rgba(139, 90, 43, 0.3);
    line-height: 1.45;
  }

  .project-item {
    padding: 0;
    border-bottom: 1px solid rgba(139, 90, 43, 0.3);
  }

  .project-summary {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 0;
    cursor: pointer;
    transition: background 0.2s;
  }

  .project-summary:hover {
    background: rgba(139, 90, 43, 0.1);
    border-radius: 4px;
    padding-left: 6px;
  }

  .project-arrow {
    font-size: 0.7rem;
    color: var(--color-neon-green);
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .project-title {
    font-family: var(--font-game);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-cream);
    flex-shrink: 0;
  }

  .project-sep {
    color: var(--color-parchment);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .project-highlight-tag {
    font-family: var(--font-game);
    font-size: 0.75rem;
    color: var(--color-neon-cyan);
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .project-detail {
    padding: 0 0 10px 20px;
    border-left: 2px solid var(--color-neon-green);
    margin-left: 8px;
  }

  .project-desc {
    font-family: var(--font-game);
    font-size: 0.8rem;
    color: var(--color-parchment);
    line-height: 1.6;
  }

  .project-highlight {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--color-neon-yellow);
    background: rgba(0, 0, 0, 0.3);
    padding: 4px 8px;
    border-radius: 4px;
    display: inline-block;
    word-break: break-word;
  }
</style>