<section class="growth-page">
  <div class="bg-sky"></div>
  <div class="bg-grass"></div>

  <div class="decorations">
    <span class="deco" style="top: 8%; left: 5%;">🌲</span>
    <span class="deco" style="top: 12%; right: 6%;">🌳</span>
    <span class="deco" style="bottom: 30%; left: 8%;">🌿</span>
    <span class="deco" style="bottom: 22%; right: 5%;">🍀</span>
  </div>

  <div class="wood-frame">
    <div class="parchment">
      <h1 class="title">🌱 成长轨迹</h1>

      <div class="skill-tree">
        <!-- Finance Branch -->
        <div class="branch">
          <div class="branch-label">💼 金融/咨询</div>
          <div class="nodes">
            <div class="node">
              <div class="node-icon">📊</div>
              <div class="node-company">安永</div>
              <div class="node-period">2023.12</div>
            </div>
          </div>
        </div>

        <!-- Medical Branch -->
        <div class="branch">
          <div class="branch-label">🏥 医疗健康</div>
          <div class="nodes">
            <div class="node">
              <div class="node-icon">💊</div>
              <div class="node-company">默克</div>
              <div class="node-period">2024.05</div>
            </div>
            <div class="node">
              <div class="node-icon">🏥</div>
              <div class="node-company">美敦力</div>
              <div class="node-period">2024.09</div>
            </div>
          </div>
        </div>

        <!-- Internet Branch -->
        <div class="branch">
          <div class="branch-label">🌐 互联网</div>
          <div class="path-line"></div>
          <div class="nodes">
            <div class="node">
              <div class="node-icon">🚲</div>
              <div class="node-company">哈啰</div>
              <div class="node-period">2025.02</div>
            </div>
            <div class="node">
              <div class="node-icon">🚴</div>
              <div class="node-company">美团</div>
              <div class="node-period">2025.05</div>
            </div>
            <div class="node">
              <div class="node-icon">📕</div>
              <div class="node-company">小红书</div>
              <div class="node-period">2025.09</div>
            </div>
            <div class="node current">
              <div class="node-icon">🌐</div>
              <div class="node-company">字节跳动</div>
              <div class="node-period">2026.01</div>
            </div>
          </div>
        </div>
      </div>

      <div class="nav-buttons">
        <button class="wood-btn" data-action="prev">◀ 上一步</button>
        <button class="wood-btn" data-action="next">继续 ▶</button>
      </div>
    </div>
  </div>
</section>

<style>
  .growth-page {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(180deg, #87CEEB 0%, #B4E7CE 100%);
  }

  .bg-grass {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 45%;
    background: linear-gradient(180deg, #7CB342 0%, #558B2F 100%);
  }

  .decorations {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .deco {
    position: absolute;
    font-size: 2rem;
    animation: sway 3s ease-in-out infinite;
  }

  @keyframes sway {
    0%, 100% { transform: rotate(-2deg); }
    50% { transform: rotate(2deg); }
  }

  .wood-frame {
    position: relative;
    z-index: 10;
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 8px;
    padding: 10px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .parchment {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 20px 30px;
    max-width: 750px;
    max-height: 88vh;
    overflow-y: auto;
  }

  .title {
    font-family: 'Gaegu', cursive;
    font-size: 2rem;
    color: #5D3A1A;
    text-align: center;
    margin-bottom: 16px;
  }

  .skill-tree {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .branch {
    background: rgba(255, 255, 255, 0.6);
    border-radius: 10px;
    padding: 12px;
  }

  .branch-label {
    font-family: 'Gaegu', cursive;
    font-size: 0.95rem;
    font-weight: 700;
    color: white;
    background: #8B4513;
    padding: 3px 12px;
    border-radius: 15px;
    display: inline-block;
    margin-bottom: 10px;
  }

  .nodes {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .node {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #F5E6C8;
    border: 3px solid #8B4513;
    border-radius: 10px;
    padding: 10px 14px;
    min-width: 68px;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 3px 0 #5D3A1A;
  }

  .node:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 0 #5D3A1A;
  }

  .node.current {
    border-color: #FFD700;
    background: #FFF8E7;
  }

  .node-icon {
    font-size: 1.6rem;
    margin-bottom: 2px;
  }

  .node-company {
    font-family: 'Gaegu', cursive;
    font-size: 0.85rem;
    font-weight: 700;
    color: #5D3A1A;
    text-align: center;
  }

  .node-period {
    font-size: 0.7rem;
    color: #8B4513;
  }

  .path-line {
    height: 4px;
    background: #8B4513;
    margin: 6px 0;
    border-radius: 2px;
  }

  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 16px;
    gap: 12px;
  }

  .wood-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    background: linear-gradient(180deg, #8B4513 0%, #6B3E26 100%);
    color: #FDF5E6;
    border: none;
    border-radius: 6px;
    font-family: 'Gaegu', cursive;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 3px 0 #5D3A1A, 0 4px 8px rgba(0, 0, 0, 0.25);
    transition: all 0.15s ease;
  }

  .wood-btn:hover {
    transform: translateY(-2px);
    background: linear-gradient(180deg, #A0522D 0%, #8B4513 100%);
    box-shadow: 0 5px 0 #5D3A1A, 0 6px 12px rgba(0, 0, 0, 0.3);
  }

  .wood-btn:active {
    transform: translateY(1px);
    box-shadow: 0 2px 0 #5D3A1A, 0 3px 6px rgba(0, 0, 0, 0.2);
  }
</style>