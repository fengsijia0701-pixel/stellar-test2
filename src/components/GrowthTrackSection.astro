---
---

<section class="growth-page">
  <div class="wood-frame">
    <div class="folder-tab">📁 GROWTH TRACK</div>
    <div class="folder-inner">
      <h1 class="growth-title">🌱 成长轨迹</h1>

      <!-- 互联网 -->
      <div class="timeline-section">
        <div class="section-label-en">// INTERNET 🌐</div>
        <div class="timeline">
          <div class="timeline-item current" data-company="bytedance">
            <div class="timeline-date-en">2026.01 — NOW</div>
            <div class="timeline-company"><span class="timeline-dot-label">🌐</span>字节跳动 TikTok — 印尼电商策略实习生<span class="current-badge">NOW</span></div>
            <div class="node-tooltip">全球最大独角兽，TikTok母公司，估值超2000亿美元</div>
          </div>
          <div class="timeline-item" data-company="xiaohongshu">
            <div class="timeline-date-en">2025.09 — 2025.12</div>
            <div class="timeline-company"><span class="timeline-dot-label">📕</span>小红书 — 商业产品实习生</div>
            <div class="node-tooltip">中国最大种草社区，2亿月活，专注生活方式分享</div>
          </div>
          <div class="timeline-item" data-company="meituan">
            <div class="timeline-date-en">2025.05 — 2025.08</div>
            <div class="timeline-company"><span class="timeline-dot-label">🚴</span>美团 — 到店餐饮实习生</div>
            <div class="node-tooltip">中国最大本地生活服务平台，年活跃用户6亿+</div>
          </div>
          <div class="timeline-item" data-company="hallo">
            <div class="timeline-date-en">2025.02 — 2025.04</div>
            <div class="timeline-company"><span class="timeline-dot-label">🚲</span>哈啰 — 策略运营实习生</div>
            <div class="node-tooltip">阿里旗下智能出行平台，国内最大共享单车服务商</div>
          </div>
        </div>
      </div>

      <!-- 医疗健康 -->
      <div class="timeline-section">
        <div class="section-label-en">// MEDICAL 🏥</div>
        <div class="timeline">
          <div class="timeline-item" data-company="medtronic">
            <div class="timeline-date-en">2024.09 — 2025.01</div>
            <div class="timeline-company"><span class="timeline-dot-label">🏥</span>美敦力 — 战略市场部实习生</div>
            <div class="node-tooltip">全球最大医疗器械公司，总部爱尔兰，专注高端医疗设备</div>
          </div>
          <div class="timeline-item" data-company="merck">
            <div class="timeline-date-en">2024.05 — 2024.08</div>
            <div class="timeline-company"><span class="timeline-dot-label">💊</span>默克 — 市场部实习生</div>
            <div class="node-tooltip">全球TOP3制药公司，350年历史，专注医药健康</div>
          </div>
        </div>
      </div>

      <!-- 金融咨询 -->
      <div class="timeline-section">
        <div class="section-label-en">// FINANCE 💼</div>
        <div class="timeline">
          <div class="timeline-item" data-company="ey">
            <div class="timeline-date-en">2023.12 — 2024.04</div>
            <div class="timeline-company"><span class="timeline-dot-label">📊</span>安永 — 审计部实习生</div>
            <div class="node-tooltip">全球四大会计师事务所之一，专注审计与咨询</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation Arrows -->
  <div class="nav-arrows">
    <button class="nav-arrow left" id="growth-nav-prev" aria-label="上一页">◀</button>
    <button class="nav-arrow right" id="growth-nav-next" aria-label="下一页">▶</button>
  </div>

  <!-- Company Detail Popup -->
  <div id="company-popup-overlay" class="popup-overlay" style="display: none;">
    <div id="company-popup" class="popup-card">
      <button class="popup-close">✕</button>
      <div class="popup-header">
        <span class="popup-icon"></span>
        <div class="popup-title">
          <h2 class="popup-company"></h2>
          <p class="popup-role"></p>
        </div>
      </div>
      <p class="popup-period"></p>
      <p class="popup-brief"></p>
      <div class="popup-projects">
        <h3>📂 项目详情</h3>
        <ul class="project-list"></ul>
      </div>
    </div>
  </div>
</section>

<script>
  function initPopup() {
    const items = document.querySelectorAll('.timeline-item[data-company]');
    const overlay = document.getElementById('company-popup-overlay');
    const popup = document.getElementById('company-popup');

    if (!overlay || !popup) return;

    const closeBtn = popup.querySelector('.popup-close');

    items.forEach(item => {
      item.addEventListener('click', () => {
        const companyId = item.dataset.company;
        const data = (window as any).companyDetails?.[companyId];
        if (data) {
          popup.querySelector('.popup-icon').textContent = data.icon || '';
          popup.querySelector('.popup-company').textContent = data.name || '';
          popup.querySelector('.popup-role').textContent = data.role || '';
          popup.querySelector('.popup-period').textContent = data.period || '';
          popup.querySelector('.popup-brief').textContent = data.brief || '';

          const projectList = popup.querySelector('.project-list');
          if (data.projects && Array.isArray(data.projects) && data.projects.length > 0) {
            if (typeof data.projects[0] === 'object') {
              projectList.innerHTML = data.projects.map((p: any, idx: number) => `
                <li class="project-item" data-index="${idx}">
                  <div class="project-summary">
                    <span class="project-arrow">▶</span>
                    <span class="project-title">${p.title || ''}</span>
                    <span class="project-sep">—</span>
                    <span class="project-highlight-tag">${p.highlight || ''}</span>
                  </div>
                  <div class="project-detail" style="display: none;">
                    <div class="project-desc">${p.desc || ''}</div>
                  </div>
                </li>
              `).join('');

              projectList.querySelectorAll('.project-summary').forEach(summary => {
                summary.addEventListener('click', (e) => {
                  e.stopPropagation();
                  const li = summary.closest('.project-item');
                  const detail = li?.querySelector('.project-detail');
                  const arrow = summary.querySelector('.project-arrow');
                  if (detail && arrow) {
                    const isHidden = detail.style.display === 'none';
                    detail.style.display = isHidden ? 'block' : 'none';
                    arrow.textContent = isHidden ? '▼' : '▶';
                    if (isHidden) {
                      (window as any).playSound?.('expand');
                    }
                  }
                });
              });
            } else {
              projectList.innerHTML = data.projects.map((p: string) => `<li>${p}</li>`).join('');
            }
          } else {
            projectList.innerHTML = '<li>暂无项目详情</li>';
          }

          (window as any).playSound?.('popup');
          overlay.style.display = 'flex';
        }
      });
    });

    closeBtn?.addEventListener('click', () => {
      overlay.style.display = 'none';
    });

    popup.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        overlay.style.display = 'none';
      }
    });
  }

  // Navigation
  document.getElementById('growth-nav-prev')?.addEventListener('click', () => {
    (window as any).playSound?.('transition');
    (window as any).navigateTo?.('page-whoami');
  });
  document.getElementById('growth-nav-next')?.addEventListener('click', () => {
    (window as any).playSound?.('transition');
    (window as any).navigateTo?.('page-map');
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPopup);
  } else {
    initPopup();
  }
</script>

<style>
  .growth-page {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  .wood-frame {
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 10px;
    padding: 10px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    max-width: 460px;
    width: 90%;
  }

  .folder-tab {
    background: linear-gradient(180deg, #5D4037 0%, #4E342E 100%);
    color: #FDF5E6;
    padding: 8px 18px;
    display: inline-block;
    border-radius: 5px 5px 0 0;
    font-family: 'Press Start 2P', cursive;
    font-size: 0.45rem;
    letter-spacing: 1px;
    margin-bottom: -3px;
  }

  .folder-inner {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 18px;
    color: #5D3A1A;
    max-height: 85vh;
    overflow-y: auto;
  }

  .growth-title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.4rem;
    text-align: center;
    margin-bottom: 15px;
  }

  .section-label-en {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.5rem;
    color: #8B4513;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
    padding-bottom: 4px;
    border-bottom: 2px solid #8B4513;
  }

  .timeline-section {
    margin-bottom: 15px;
  }

  .timeline {
    position: relative;
    padding-left: 18px;
    margin-top: 8px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 0;
    bottom: 0;
    width: 3px;
    background: #c9b896;
    border-radius: 2px;
  }

  .timeline-item {
    position: relative;
    margin-bottom: 10px;
    padding-left: 8px;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .timeline-item:hover {
    transform: translateX(4px);
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -18px;
    top: 8px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid #8B4513;
  }

  .timeline-item.internet::before { background: #64B5F6; }
  .timeline-item.medical::before { background: #81C784; }
  .timeline-item.finance::before { background: #FFD700; }
  .timeline-item.current::before {
    background: #FFD700;
    box-shadow: 0 0 8px rgba(255,215,0,0.6);
  }

  .timeline-date-en {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.5rem;
    color: #8B4513;
    margin-bottom: 2px;
  }

  .timeline-company {
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1.05rem;
    color: #5D3A1A;
  }

  .timeline-dot-label {
    font-size: 0.9rem;
    margin-right: 4px;
  }

  .current-badge {
    display: inline-block;
    background: #FFD700;
    color: #5D3A1A;
    font-family: 'Press Start 2P', cursive;
    font-size: 0.4rem;
    padding: 2px 6px;
    border-radius: 4px;
    margin-left: 6px;
  }

  /* Tooltip */
  .node-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: #5D3A1A;
    color: #FDF5E6;
    padding: 8px 14px;
    border-radius: 8px;
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 0.9rem;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    z-index: 100;
    box-shadow: 0 3px 8px rgba(0,0,0,0.3);
  }

  .node-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: #5D3A1A;
  }

  .timeline-item:hover .node-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(-4px);
  }

  /* Navigation Arrows */
  .nav-arrows {
    position: fixed;
    bottom: 80px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    pointer-events: none;
    z-index: 100;
  }

  .nav-arrow {
    pointer-events: auto;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8B4513 0%, #6B3E26 100%);
    border: 3px solid var(--color-neon-green);
    color: var(--color-neon-green);
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    transition: all 0.2s;
  }

  .nav-arrow:hover {
    transform: scale(1.1);
    border-color: var(--color-neon-yellow);
    color: var(--color-neon-yellow);
    box-shadow: 0 0 20px rgba(255, 255, 0, 0.3);
  }

  /* Popup Styles */
  .popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 0.3s ease;
  }

  .popup-card {
    background: linear-gradient(135deg, var(--color-wood), var(--color-wood-light));
    border: 4px solid var(--color-wood-dark);
    border-radius: 12px;
    padding: 24px 28px;
    max-width: 620px;
    width: 92%;
    max-height: 82vh;
    overflow-y: auto;
    position: relative;
    animation: popupSlideIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes popupSlideIn {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .popup-close {
    position: absolute;
    top: 12px;
    right: 12px;
    background: none;
    border: none;
    font-size: 1.3rem;
    cursor: pointer;
    color: var(--color-wood-dark);
    padding: 4px 8px;
  }

  .popup-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .popup-icon {
    font-size: 2.2rem;
  }

  .popup-title h2 {
    font-family: var(--font-game);
    font-size: 1.2rem;
    color: var(--color-cream);
    margin: 0;
  }

  .popup-role {
    font-family: var(--font-game);
    font-size: 0.95rem;
    color: var(--color-parchment);
    margin: 4px 0 0 0;
  }

  .popup-period {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-neon-yellow);
    margin-bottom: 10px;
  }

  .popup-brief {
    font-family: var(--font-game);
    font-size: 0.9rem;
    color: var(--color-cream);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .popup-projects h3 {
    font-family: var(--font-game);
    font-size: 0.95rem;
    color: var(--color-neon-green);
    margin-bottom: 10px;
  }

  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-item {
    padding: 0;
    border-bottom: 1px solid rgba(139, 90, 43, 0.3);
  }

  .project-summary {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    padding: 10px 0;
    cursor: pointer;
    transition: background 0.2s;
  }

  .project-summary:hover {
    background: rgba(139, 90, 43, 0.1);
    border-radius: 4px;
    padding-left: 6px;
  }

  .project-arrow {
    font-size: 0.7rem;
    color: var(--color-neon-green);
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .project-title {
    font-family: var(--font-game);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-cream);
    flex-shrink: 0;
  }

  .project-sep {
    color: var(--color-parchment);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .project-highlight-tag {
    font-family: var(--font-game);
    font-size: 0.75rem;
    color: var(--color-neon-cyan);
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .project-detail {
    padding: 0 0 10px 20px;
    border-left: 2px solid var(--color-neon-green);
    margin-left: 8px;
  }

  .project-desc {
    font-family: var(--font-game);
    font-size: 0.8rem;
    color: var(--color-parchment);
    line-height: 1.6;
  }
</style>