---
import timelineData from '../data/timeline.json';

// Time order (earliest to latest)
const chronologicalOrder = [
  '安永',         // 2023.12 - Finance
  '默克',         // 2024.05 - Medical
  '美敦力',       // 2024.09 - Medical
  '哈啰',         // 2025.02 - Internet
  '美团',         // 2025.05 - Internet
  '小红书',       // 2025.09 - Internet
  '字节跳动'      // 2026.01 - Internet
];

// Company industry mapping
const companyToIndustry: Record<string, 'internet' | 'medical' | 'finance'> = {
  '字节跳动': 'internet',
  '小红书': 'internet',
  '美团': 'internet',
  '哈啰': 'internet',
  '美敦力': 'medical',
  '默克': 'medical',
  '安永': 'finance'
};

// Industry config
const industryConfig = {
  internet: {
    name: '互联网',
    icon: '🌐',
    color: 'accent',
    gradient: 'from-accent/30 to-highlight/30',
    border: 'border-accent',
    glow: 'shadow-accent/30'
  },
  medical: {
    name: '医疗健康',
    icon: '🏥',
    color: 'secondary',
    gradient: 'from-secondary/30 to-accent/30',
    border: 'border-secondary',
    glow: 'shadow-secondary/30'
  },
  finance: {
    name: '金融/咨询',
    icon: '💼',
    color: 'sky',
    gradient: 'from-sky/30 to-secondary/30',
    border: 'border-sky',
    glow: 'shadow-sky/30'
  }
};

// Build experience map
const experienceMap = new Map(
  timelineData.experience.map(exp => [exp.company, exp])
);

// Build skill tree structure
const skillTree = chronologicalOrder.map((companyName, index) => {
  const exp = experienceMap.get(companyName);
  const industry = companyToIndustry[companyName];
  const config = industryConfig[industry];
  const isLast = index === chronologicalOrder.length - 1;
  const isFirst = index === 0;

  return {
    company: companyName,
    period: exp?.period || '',
    role: exp?.subtitle || '',
    icon: exp?.icon || '📦',
    brief: exp?.brief || '',
    projects: exp?.projects || [],
    industry,
    config,
    index,
    isLast,
    isFirst,
    status: isLast ? 'current' : 'completed'
  };
});

// Group by industry for track display
const tracks = {
  finance: skillTree.filter(n => n.industry === 'finance'),
  medical: skillTree.filter(n => n.industry === 'medical'),
  internet: skillTree.filter(n => n.industry === 'internet')
};

const colorMap = {
  accent: { bg: 'bg-accent/20', border: 'border-accent', text: 'text-accent', bar: 'bg-accent' },
  sky: { bg: 'bg-sky/20', border: 'border-sky', text: 'text-sky', bar: 'bg-sky' },
  secondary: { bg: 'bg-secondary/20', border: 'border-secondary', text: 'text-secondary', bar: 'bg-secondary' }
};
---

<section class="py-16 bg-bgLight relative overflow-hidden">
  <!-- Background RPG decorative elements -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-20 left-10 text-6xl animate-float">⚔️</div>
    <div class="absolute top-40 right-20 text-4xl animate-float" style="animation-delay: 1s">🛡️</div>
    <div class="absolute bottom-20 left-1/4 text-5xl animate-float" style="animation-delay: 2s">💎</div>
    <div class="absolute top-1/3 right-1/4 text-3xl animate-float" style="animation-delay: 0.5s">⭐</div>
  </div>

  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="font-heading text-4xl font-bold text-dark mb-4 flex items-center justify-center gap-3">
        <span class="text-3xl">🎮</span>
        <span>成长轨迹</span>
        <span class="text-3xl">🗺️</span>
      </h2>
      <p class="text-dark/60 text-lg max-w-2xl mx-auto">
        每一次转折都是技能树的分支，每一段经历都是升级路上的经验值
      </p>
    </div>

    <!-- Skill Tree Container -->
    <div class="relative">
      <!-- Main skill tree path -->
      <div class="bg-white rounded-stardew border-2 border-dark/10 p-8 shadow-stardew">
        <!-- Path header with status -->
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-2">
            <span class="px-3 py-1 bg-accent/20 text-accent text-sm font-medium rounded-full">
              已解锁 {skillTree.filter(n => n.status === 'completed').length} / {skillTree.length}
            </span>
          </div>
          <div class="text-sm text-dark/50">
            继续探索 →
          </div>
        </div>

        <!-- RPG Skill Tree Visualization -->
        <div class="relative py-8">
          <!-- Central skill tree trunk (vertical line) -->
          <div class="absolute left-1/2 top-0 bottom-0 w-2 bg-gradient-to-b from-sky via-secondary to-accent rounded-full opacity-20 transform -translate-x-1/2"></div>

          <!-- Industry tracks arranged like game skill branches -->
          <div class="grid grid-cols-1 gap-12 relative">
            {/* Finance Track */}
            <div class="relative">
              <div class={`flex items-center gap-4 mb-4`}>
                <span class={`px-3 py-1 rounded-full text-sm font-medium ${colorMap.sky.bg} ${colorMap.sky.text}`}>
                  💼 金融/咨询
                </span>
              </div>
              <div class="flex flex-wrap items-center gap-4 relative">
                {/* Connection line */}
                <div class="absolute top-6 left-0 h-1 bg-gradient-to-r from-sky/50 to-sky/20 rounded-full"
                     style="width: 100%;" />

                {tracks.finance.map((node, idx) => (
                  <div class="relative z-10 flex flex-col items-center">
                    {/* Skill node */}
                    <button
                      class={`skill-node w-32 h-32 rounded-xl border-2 ${node.config.border} ${node.status === 'current' ? node.config.glow + ' shadow-lg' : ''} bg-gradient-to-br ${node.config.gradient} p-2 flex flex-col items-center justify-center transition-all duration-300 hover:scale-105 hover:shadow-xl group relative`}
                      data-company={node.company}
                      data-period={node.period}
                      data-role={node.role}
                      data-icon={node.icon}
                      data-color={node.config.color}
                      data-brief={node.brief}
                      data-projects={JSON.stringify(node.projects)}
                      data-status={node.status}
                    >
                      {/* Status indicator */}
                      {node.status === 'current' && (
                        <div class="absolute -top-2 -right-2 w-6 h-6 bg-highlight rounded-full flex items-center justify-center text-xs shadow-lg animate-pulse">
                          ✨
                        </div>
                      )}
                      {node.status === 'completed' && (
                        <div class="absolute -top-2 -right-2 w-6 h-6 bg-accent rounded-full flex items-center justify-center text-xs shadow-lg">
                          ✓
                        </div>
                      )}

                      <!-- Icon -->
                      <span class="text-3xl mb-1">{node.icon}</span>

                      <!-- Company name -->
                      <span class="font-heading font-bold text-dark text-sm text-center leading-tight">
                        {node.company}
                      </span>

                      <!-- Period -->
                      <span class="text-xs text-dark/60 mt-1">{node.period.split(' - ')[0]}</span>

                      <!-- Hover glow effect -->
                      <div class={`absolute inset-0 rounded-xl bg-gradient-to-br ${node.config.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10 blur-lg`}></div>
                    </button>

                    {/* Arrow connector */}
                    {idx < tracks.finance.length - 1 && (
                      <div class="absolute top-6 -right-4 text-dark/30 text-2xl">
                        →
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>

            {/* Medical Track */}
            <div class="relative">
              <div class={`flex items-center gap-4 mb-4`}>
                <span class={`px-3 py-1 rounded-full text-sm font-medium ${colorMap.secondary.bg} ${colorMap.secondary.text}`}>
                  🏥 医疗健康
                </span>
              </div>
              <div class="flex flex-wrap items-center gap-4 relative">
                {/* Connection line */}
                <div class="absolute top-6 left-0 h-1 bg-gradient-to-r from-secondary/50 to-secondary/20 rounded-full"
                     style="width: 100%;" />

                {tracks.medical.map((node, idx) => (
                  <div class="relative z-10 flex flex-col items-center">
                    <button
                      class={`skill-node w-32 h-32 rounded-xl border-2 ${node.config.border} ${node.status === 'current' ? node.config.glow + ' shadow-lg' : ''} bg-gradient-to-br ${node.config.gradient} p-2 flex flex-col items-center justify-center transition-all duration-300 hover:scale-105 hover:shadow-xl group relative`}
                      data-company={node.company}
                      data-period={node.period}
                      data-role={node.role}
                      data-icon={node.icon}
                      data-color={node.config.color}
                      data-brief={node.brief}
                      data-projects={JSON.stringify(node.projects)}
                      data-status={node.status}
                    >
                      {node.status === 'current' && (
                        <div class="absolute -top-2 -right-2 w-6 h-6 bg-highlight rounded-full flex items-center justify-center text-xs shadow-lg animate-pulse">
                          ✨
                        </div>
                      )}
                      {node.status === 'completed' && (
                        <div class="absolute -top-2 -right-2 w-6 h-6 bg-accent rounded-full flex items-center justify-center text-xs shadow-lg">
                          ✓
                        </div>
                      )}

                      <span class="text-3xl mb-1">{node.icon}</span>
                      <span class="font-heading font-bold text-dark text-sm text-center leading-tight">
                        {node.company}
                      </span>
                      <span class="text-xs text-dark/60 mt-1">{node.period.split(' - ')[0]}</span>

                      <div class={`absolute inset-0 rounded-xl bg-gradient-to-br ${node.config.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10 blur-lg`}></div>
                    </button>

                    {idx < tracks.medical.length - 1 && (
                      <div class="absolute top-6 -right-4 text-dark/30 text-2xl">
                        →
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>

            {/* Internet Track */}
            <div class="relative">
              <div class={`flex items-center gap-4 mb-4`}>
                <span class={`px-3 py-1 rounded-full text-sm font-medium ${colorMap.accent.bg} ${colorMap.accent.text}`}>
                  🌐 互联网
                </span>
              </div>
              <div class="flex flex-wrap items-center gap-4 relative">
                {/* Connection line */}
                <div class="absolute top-6 left-0 h-1 bg-gradient-to-r from-accent/50 to-highlight/20 rounded-full"
                     style="width: 100%;" />

                {tracks.internet.map((node, idx) => (
                  <div class="relative z-10 flex flex-col items-center">
                    <button
                      class={`skill-node w-32 h-32 rounded-xl border-2 ${node.config.border} ${node.status === 'current' ? node.config.glow + ' shadow-lg' : ''} bg-gradient-to-br ${node.config.gradient} p-2 flex flex-col items-center justify-center transition-all duration-300 hover:scale-105 hover:shadow-xl group relative`}
                      data-company={node.company}
                      data-period={node.period}
                      data-role={node.role}
                      data-icon={node.icon}
                      data-color={node.config.color}
                      data-brief={node.brief}
                      data-projects={JSON.stringify(node.projects)}
                      data-status={node.status}
                    >
                      {node.status === 'current' && (
                        <div class="absolute -top-2 -right-2 w-6 h-6 bg-highlight rounded-full flex items-center justify-center text-xs shadow-lg animate-pulse">
                          ✨
                        </div>
                      )}
                      {node.status === 'completed' && (
                        <div class="absolute -top-2 -right-2 w-6 h-6 bg-accent rounded-full flex items-center justify-center text-xs shadow-lg">
                          ✓
                        </div>
                      )}

                      <span class="text-3xl mb-1">{node.icon}</span>
                      <span class="font-heading font-bold text-dark text-sm text-center leading-tight">
                        {node.company}
                      </span>
                      <span class="text-xs text-dark/60 mt-1">{node.period.split(' - ')[0]}</span>

                      <div class={`absolute inset-0 rounded-xl bg-gradient-to-br ${node.config.gradient} opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10 blur-lg`}></div>
                    </button>

                    {idx < tracks.internet.length - 1 && (
                      <div class="absolute top-6 -right-4 text-dark/30 text-2xl">
                        →
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Progress indicator -->
          <div class="mt-12 flex items-center justify-center gap-4">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 bg-accent rounded-full"></span>
              <span class="text-sm text-dark/60">已完成</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 bg-highlight rounded-full animate-pulse"></span>
              <span class="text-sm text-dark/60">当前</span>
            </div>
          </div>
        </div>

        <!-- Navigation -->
        <div class="mt-12 flex justify-between items-center pt-8 border-t border-dark/10">
          <a href="/" class="flex items-center gap-2 text-dark/60 hover:text-accent transition-colors">
            <span>←</span>
            <span>返回地图</span>
          </a>
          <a href="/#projects" class="flex items-center gap-2 px-4 py-2 bg-accent/20 text-accent rounded-full hover:bg-accent/30 transition-colors">
            <span>继续探索</span>
            <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Click-to-expand Modal (reused from IndustryTimeline) -->
<div id="growth-modal" class="fixed inset-0 z-50 hidden">
  <div class="modal-backdrop absolute inset-0 bg-dark/60 backdrop-blur-sm" />
  <div class="modal-drawer absolute right-0 top-0 bottom-0 w-full max-w-2xl bg-cardBg transform translate-x-full transition-transform duration-500 overflow-y-auto">
    <div class="p-8">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h3 id="modal-company" class="font-heading text-2xl font-bold text-dark" />
          <p id="modal-role" class="text-dark/60 mt-1" />
        </div>
        <button id="modal-close" class="p-2 hover:bg-dark/10 rounded-full transition-colors">
          <svg class="w-6 h-6 text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="modal-projects" class="space-y-8" />
    </div>
  </div>
</div>

<style>
  .skill-node {
    transform: perspective(1000px) rotateX(5deg);
  }

  .skill-node:hover {
    transform: perspective(1000px) rotateX(5deg) translateY(-4px);
  }

  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 10px rgba(255, 200, 0, 0.5);
    }
    50% {
      box-shadow: 0 0 20px rgba(255, 200, 0, 0.8);
    }
  }

  .animate-pulse-glow {
    animation: pulse-glow 2s ease-in-out infinite;
  }
</style>

<script>
  // Company info database
  const companyInfo: Record<string, { description: string; scale: string; position: string }> = {
    '字节跳动': {
      description: '全球最大短视频平台 TikTok 母公司',
      scale: '市值超 2000 亿美元，员工超 15 万人',
      position: '全球最具价值独角兽之一'
    },
    '小红书': {
      description: '月活 2.6 亿的生活方式分享平台',
      scale: '估值超 200 亿美元',
      position: '国内头部社交电商平台'
    },
    '美团': {
      description: '国内最大本地生活服务平台',
      scale: '年营收超 2000 亿元',
      position: '外卖/酒旅/到店龙头'
    },
    '哈啰': {
      description: '阿里旗下出行科技公司',
      scale: '哈啰单车覆盖超 400 城市',
      position: '共享单车行业头部'
    },
    '美敦力': {
      description: '全球最大医疗器械公司',
      scale: '市值超 1000 亿美元',
      position: '心脏支架/胰岛素泵等领域全球第一'
    },
    '默克': {
      description: '全球领先科技公司',
      scale: '年营收超 200 亿欧元',
      position: '生命科学/医药健康领域龙头'
    },
    '安永': {
      description: '全球四大会计师事务所之一',
      scale: '覆盖 150+ 国家，30 万+ 员工',
      position: '全球顶级审计/咨询机构'
    }
  };

  // Modal functionality
  const modal = document.getElementById('growth-modal');
  const modalBackdrop = modal?.querySelector('.modal-backdrop');
  const modalDrawer = modal?.querySelector('.modal-drawer');
  const modalCompany = document.getElementById('modal-company');
  const modalRole = document.getElementById('modal-role');
  const modalProjects = document.getElementById('modal-projects');
  const modalClose = document.getElementById('modal-close');

  function openModal(card: Element) {
    const data = card.getAttribute('data-projects');
    const company = card.getAttribute('data-company');
    const period = card.getAttribute('data-period');
    const role = card.getAttribute('data-role');
    const color = card.getAttribute('data-color');

    if (!data || !company || !role) return;

    const projects = JSON.parse(data);

    if (modalCompany) modalCompany.textContent = company;
    if (modalRole) modalRole.textContent = `${role} · ${period}`;

    if (modalProjects && projects.length > 0) {
      renderProjects(projects, color || 'accent');
    }

    modal?.classList.remove('hidden');
    setTimeout(() => {
      modalDrawer?.classList.remove('translate-x-full');
    }, 10);
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modalDrawer?.classList.add('translate-x-full');
    setTimeout(() => {
      modal?.classList.add('hidden');
    }, 500);
    document.body.style.overflow = '';
  }

  function renderProjects(projects: any[], color: string) {
    if (!modalProjects) return;

    const colorMap: Record<string, { bg: string, border: string, text: string }> = {
      accent: { bg: 'bg-accent/20', border: 'border-accent', text: 'text-accent' },
      sky: { bg: 'bg-sky/20', border: 'border-sky', text: 'text-sky' },
      secondary: { bg: 'bg-secondary/20', border: 'border-secondary', text: 'text-secondary' },
      highlight: { bg: 'bg-highlight/30', border: 'border-highlight', text: 'text-dark' },
    };
    const colors = colorMap[color] || colorMap.accent;

    modalProjects.innerHTML = projects.map((p: any) => `
      <div class="project-item border-l-4 ${colors.border} pl-6 py-4 bg-white/50 rounded-r-stardew">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">📦</span>
          <h4 class="font-heading text-xl font-bold text-dark">${p.name}</h4>
        </div>
        <div class="space-y-4 text-sm">
          <div class="flex gap-2">
            <span class="font-medium text-dark/50 min-w-16">背景</span>
            <span class="text-dark/70">${p.background}</span>
          </div>
          <div class="flex gap-2">
            <span class="font-medium text-dark/50 min-w-16">挑战</span>
            <span class="text-dark/70">${p.challenge}</span>
          </div>
          <div class="flex gap-2">
            <span class="font-medium text-dark/50 min-w-16">方案</span>
            <span class="text-dark/70">${p.solution}</span>
          </div>
          <div class="flex gap-2 items-start">
            <span class="font-medium ${colors.text} min-w-16">成果</span>
            <span class="${colors.text} font-medium">${p.result}</span>
          </div>
        </div>
      </div>
    `).join('');
  }

  // Attach click events to skill nodes
  document.querySelectorAll('.skill-node').forEach(node => {
    node.addEventListener('click', () => {
      openModal(node);
    });
  });

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>