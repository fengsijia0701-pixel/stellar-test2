---
import timelineData from '../data/timeline.json';

// 按行业分组
const industries = {
  internet: {
    name: '互联网/科技',
    icon: '🌐',
    color: 'accent',
    companies: [] as typeof timelineData.experience
  },
  medical: {
    name: '医疗健康',
    icon: '🏥',
    color: 'secondary',
    companies: [] as typeof timelineData.experience
  },
  finance: {
    name: '金融/咨询',
    icon: '💼',
    color: 'sky',
    companies: [] as typeof timelineData.experience
  }
};

// 根据公司名称推断行业
const companyToIndustry: Record<string, keyof typeof industries> = {
  '字节跳动': 'internet',
  '小红书': 'internet',
  '美团': 'internet',
  '哈啰': 'internet',
  '美敦力': 'medical',
  '默克': 'medical',
  '安永': 'finance'
};

// 填充数据
timelineData.experience.forEach(exp => {
  const industry = companyToIndustry[exp.company];
  if (industry && industries[industry]) {
    industries[industry].companies.push(exp);
  }
});

// 按时间排序（从早到晚）
Object.values(industries).forEach(industry => {
  industry.companies.sort((a, b) => {
    const parseYear = (period: string) => {
      const start = period.split(' - ')[0];
      return parseFloat(start);
    };
    return parseYear(a.period) - parseYear(b.period);
  });
});

// 计算时长
const calculateDuration = (period: string): string => {
  const [start, end] = period.split(' - ');
  const startDate = new Date(start.replace('.', '-'));
  const endDate = end.includes('至今') ? new Date() : new Date(end.replace('.', '-'));
  const months = Math.round((endDate.getTime() - startDate.getTime()) / (1000 * 60 * 60 * 24 * 30));
  if (months >= 12) {
    const years = Math.floor(months / 12);
    const remainingMonths = months % 12;
    return remainingMonths > 0 ? `${years}年${remainingMonths}个月` : `${years}年`;
  }
  return `${months}个月`;
};

const colorMap = {
  accent: { bg: 'bg-accent/20', border: 'border-accent', text: 'text-accent', bar: 'bg-accent' },
  sky: { bg: 'bg-sky/20', border: 'border-sky', text: 'text-sky', bar: 'bg-sky' },
  secondary: { bg: 'bg-secondary/20', border: 'border-secondary', text: 'text-secondary', bar: 'bg-secondary' }
};
---

<section class="py-16 bg-cream">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="font-heading text-3xl font-bold text-dark text-center mb-4">
      🌱 成长轨迹
    </h2>
    <p class="text-dark/60 text-center mb-12 max-w-2xl mx-auto">
      从互联网到医疗健康再到金融咨询，每一段经历都是升级路上的宝贵经验
    </p>

    <div class="space-y-12">
      {Object.values(industries).map((industry) => (
        <div class="bg-white rounded-stardew border-2 border-dark/10 p-6 shadow-stardew">
          {/* 行业标题 */}
          <div class="flex items-center gap-3 mb-6">
            <span class="text-3xl">{industry.icon}</span>
            <h3 class={`font-heading text-xl font-bold ${colorMap[industry.color as keyof typeof colorMap].text}`}>
              {industry.name}
            </h3>
            <span class={`px-3 py-1 rounded-full text-sm ${colorMap[industry.color as keyof typeof colorMap].bg} ${colorMap[industry.color as keyof typeof colorMap].text}`}>
              {industry.companies.length} 段经历
            </span>
          </div>

          {/* 公司路径 */}
          <div class="relative">
            {/* 连接线 */}
            <div class={`absolute top-6 left-0 right-0 h-1 ${colorMap[industry.color as keyof typeof colorMap].bar}/30 rounded`}
                 style="left: 5%; right: 5%;" />

            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 relative">
              {industry.companies.map((company, idx) => (
                <div class="relative">
                  {/* 路径节点 */}
                  <div class={`absolute top-6 w-3 h-3 rounded-full ${colorMap[industry.color as keyof typeof colorMap].bar} z-10`}
                       style={`left: ${5 + idx * 30}%`} />

                  {/* 公司卡片 */}
                  <button
                    class={`mt-8 p-4 rounded-stardew border-2 ${colorMap[industry.color as keyof typeof colorMap].border} ${colorMap[industry.color as keyof typeof colorMap].bg} hover:shadow-stardew transition-all duration-300 hover:-translate-y-1 text-left w-full experience-card`}
                    data-company={company.company}
                    data-period={company.period}
                    data-role={company.subtitle}
                    data-icon={company.icon}
                    data-color={industry.color}
                    data-brief={company.brief}
                    data-projects={JSON.stringify(company.projects || [])}>
                    <div class="flex items-center gap-2 mb-2">
                      <span class="text-2xl">{company.icon}</span>
                      <span class="font-heading font-bold text-dark text-sm">{company.company}</span>
                    </div>
                    <p class="text-dark/70 text-xs">{company.subtitle}</p>
                    <div class="flex items-center gap-2 mt-2">
                      <p class={`${colorMap[industry.color as keyof typeof colorMap].text} text-xs font-medium`}>
                        {company.period}
                      </p>
                      <span class="text-xs text-dark/50">
                        ({calculateDuration(company.period)})
                      </span>
                    </div>
                    <p class="text-dark/60 text-xs mt-2 line-clamp-2">{company.brief}</p>
                  </button>
                </div>
              ))}
            </div>
          </div>

          {/* 成长进度条 */}
          <div class="mt-6">
            <div class="flex items-center justify-between text-xs text-dark/60 mb-2">
              <span>成长进度</span>
              <span>{industry.companies.reduce((acc, c) => acc + (c.projects?.length || 0), 0)} 个项目</span>
            </div>
            <div class={`h-2 rounded-full ${colorMap[industry.color as keyof typeof colorMap].bar}/20 overflow-hidden`}>
              <div class={`h-full ${colorMap[industry.color as keyof typeof colorMap].bar} rounded-full transition-all duration-500`}
                   style={`width: ${Math.min(100, industry.companies.length * 25)}%`} />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Click-to-expand Modal -->
<div id="experience-modal" class="fixed inset-0 z-50 hidden">
  <div class="modal-backdrop absolute inset-0 bg-dark/60 backdrop-blur-sm" />
  <div class="modal-drawer absolute right-0 top-0 bottom-0 w-full max-w-2xl bg-cardBg transform translate-x-full transition-transform duration-500 overflow-y-auto">
    <div class="p-8">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h3 id="modal-company" class="font-heading text-2xl font-bold text-dark" />
          <p id="modal-role" class="text-dark/60 mt-1" />
        </div>
        <button id="modal-close" class="p-2 hover:bg-dark/10 rounded-full transition-colors">
          <svg class="w-6 h-6 text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="modal-projects" class="space-y-8" />
    </div>
  </div>
</div>

<!-- Company Info Popup -->
<div id="company-popup" class="fixed z-50 hidden pointer-events-none">
  <div class="bg-white rounded-xl border-2 border-dark/10 shadow-elevated p-4 min-w-[280px] max-w-[320px]">
    <h4 id="popup-company-name" class="font-heading font-bold text-dark text-lg mb-2"></h4>
    <p id="popup-description" class="text-dark/80 text-sm mb-2"></p>
    <div class="space-y-1 text-xs text-dark/60">
      <p><span class="font-medium text-dark/70">规模：</span><span id="popup-scale"></span></p>
      <p><span class="font-medium text-dark/70">地位：</span><span id="popup-position"></span></p>
    </div>
  </div>
</div>

<style>
  #company-popup {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  #company-popup.hidden {
    opacity: 0;
    transform: translateY(4px);
  }
  #company-popup:not(.hidden) {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  declare global {
    interface Window {
      companyInfo: Record<string, { description: string; scale: string; position: string }>;
    }
  }

  window.companyInfo = {
    '字节跳动': {
      description: '全球最大短视频平台 TikTok 母公司',
      scale: '市值超 2000 亿美元，员工超 15 万人',
      position: '全球最具价值独角兽之一'
    },
    '小红书': {
      description: '月活 2.6 亿的生活方式分享平台',
      scale: '估值超 200 亿美元',
      position: '国内头部社交电商平台'
    },
    '美团': {
      description: '国内最大本地生活服务平台',
      scale: '年营收超 2000 亿元',
      position: '外卖/酒旅/到店龙头'
    },
    '哈啰': {
      description: '阿里旗下出行科技公司',
      scale: '哈啰单车覆盖超 400 城市',
      position: '共享单车行业头部'
    },
    '美敦力': {
      description: '全球最大医疗器械公司',
      scale: '市值超 1000 亿美元',
      position: '心脏支架/胰岛素泵等领域全球第一'
    },
    '默克': {
      description: '全球领先科技公司',
      scale: '年营收超 200 亿欧元',
      position: '生命科学/医药健康领域龙头'
    },
    '安永': {
      description: '全球四大会计师事务所之一',
      scale: '覆盖 150+ 国家，30 万+ 员工',
      position: '全球顶级审计/咨询机构'
    }
  };

  // ========== Hover Popup (Company Info) ==========
  const popup = document.getElementById('company-popup');
  const popupCompanyName = document.getElementById('popup-company-name');
  const popupDescription = document.getElementById('popup-description');
  const popupScale = document.getElementById('popup-scale');
  const popupPosition = document.getElementById('popup-position');

  function showCompanyPopup(companyName: string, event: MouseEvent) {
    const info = window.companyInfo[companyName];
    if (!info || !popup || !popupCompanyName || !popupDescription || !popupScale || !popupPosition) return;

    popupCompanyName.textContent = companyName;
    popupDescription.textContent = info.description;
    popupScale.textContent = info.scale;
    popupPosition.textContent = info.position;

    popup.classList.remove('hidden');

    const target = event.currentTarget as HTMLElement;
    const rect = target.getBoundingClientRect();
    const popupRect = popup.getBoundingClientRect();

    let left = rect.left + rect.width / 2 - popupRect.width / 2;
    let top = rect.bottom + 10;

    // Keep popup within viewport
    if (left < 10) left = 10;
    if (left + popupRect.width > window.innerWidth - 10) {
      left = window.innerWidth - popupRect.width - 10;
    }
    if (top + popupRect.height > window.innerHeight - 10) {
      top = rect.top - popupRect.height - 10;
    }

    popup.style.left = `${left}px`;
    popup.style.top = `${top}px`;
  }

  function hideCompanyPopup() {
    if (popup) {
      popup.classList.add('hidden');
    }
  }

  // ========== Click-to-expand Modal ==========
  const modal = document.getElementById('experience-modal');
  const modalBackdrop = modal?.querySelector('.modal-backdrop');
  const modalDrawer = modal?.querySelector('.modal-drawer');
  const modalCompany = document.getElementById('modal-company');
  const modalRole = document.getElementById('modal-role');
  const modalProjects = document.getElementById('modal-projects');
  const modalClose = document.getElementById('modal-close');

  function openExperienceModal(card: Element) {
    const data = card.getAttribute('data-projects');
    const company = card.getAttribute('data-company');
    const period = card.getAttribute('data-period');
    const role = card.getAttribute('data-role');
    const color = card.getAttribute('data-color');

    if (!data || !company || !role) return;

    const projects = JSON.parse(data);

    if (modalCompany) modalCompany.textContent = company;
    if (modalRole) modalRole.textContent = `${role} · ${period}`;

    if (modalProjects && projects.length > 0) {
      renderProjects(projects, color || 'accent');
    }

    modal?.classList.remove('hidden');
    setTimeout(() => {
      modalDrawer?.classList.remove('translate-x-full');
    }, 10);
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modalDrawer?.classList.add('translate-x-full');
    setTimeout(() => {
      modal?.classList.add('hidden');
    }, 500);
    document.body.style.overflow = '';
  }

  function renderProjects(projects: any[], color: string) {
    if (!modalProjects) return;

    const colorMap: Record<string, { bg: string, border: string, text: string }> = {
      accent: { bg: 'bg-accent/20', border: 'border-accent', text: 'text-accent' },
      sky: { bg: 'bg-sky/20', border: 'border-sky', text: 'text-sky' },
      secondary: { bg: 'bg-secondary/20', border: 'border-secondary', text: 'text-secondary' },
      highlight: { bg: 'bg-highlight/30', border: 'border-highlight', text: 'text-dark' },
    };
    const colors = colorMap[color] || colorMap.accent;

    modalProjects.innerHTML = projects.map((p) => `
      <div class="project-item border-l-4 ${colors.border} pl-6 py-4 bg-white/50 rounded-r-stardew">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">📦</span>
          <h4 class="font-heading text-xl font-bold text-dark">${p.name}</h4>
        </div>
        <div class="space-y-4 text-sm">
          <div class="flex gap-2">
            <span class="font-medium text-dark/50 min-w-16">背景</span>
            <span class="text-dark/70">${p.background}</span>
          </div>
          <div class="flex gap-2">
            <span class="font-medium text-dark/50 min-w-16">挑战</span>
            <span class="text-dark/70">${p.challenge}</span>
          </div>
          <div class="flex gap-2">
            <span class="font-medium text-dark/50 min-w-16">方案</span>
            <span class="text-dark/70">${p.solution}</span>
          </div>
          <div class="flex gap-2 items-start">
            <span class="font-medium ${colors.text} min-w-16">成果</span>
            <span class="${colors.text} font-medium">${p.result}</span>
          </div>
        </div>
      </div>
    `).join('');
  }

  // Attach click events to experience cards
  document.querySelectorAll('.experience-card').forEach(card => {
    // Click opens modal (not hover popup)
    card.addEventListener('click', (e) => {
      e.stopPropagation();
      openExperienceModal(card);
    });

    // Hover shows company info popup
    const companyName = card.getAttribute('data-company');
    if (companyName) {
      card.addEventListener('mouseenter', (e: MouseEvent) => showCompanyPopup(companyName, e));
      card.addEventListener('mouseleave', hideCompanyPopup);
    }
  });

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>