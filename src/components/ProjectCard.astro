---
interface Props {
  title: string;
  description: string;
  url: string;
  tags: string[];
  color: string;
}

const { title, description, url, tags, color } = Astro.props;

const colorClasses = {
  primary: 'bg-primary/10 text-primary',
  secondary: 'bg-secondary/10 text-secondary',
  accent: 'bg-accent/10 text-accent',
}[color] || 'bg-primary/10 text-primary';
---

<div class={`project-card group relative bg-white rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-dark/5`}>
  <h3 class="font-heading text-xl font-semibold text-dark">{title}</h3>
  <p class="text-dark/60 mt-2 text-sm leading-relaxed">{description}</p>

  <div class="flex flex-wrap gap-2 mt-4">
    {tags.map((tag) => (
      <span class={`px-3 py-1 rounded-full text-xs font-medium ${colorClasses}`}>
        {tag}
      </span>
    ))}
  </div>

  <a href={url} target="_blank" rel="noopener noreferrer"
    class="mt-6 inline-flex items-center gap-2 text-dark hover:text-primary transition-colors text-sm font-medium">
    <span>去看看</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>