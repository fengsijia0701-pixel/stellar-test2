---
interface Props {
  title: string;
  description: string;
  url: string;
  tags: string[];
  color: string;
  icon?: string;
  features?: string[];
}

const { title, description, url, tags, color, icon = "🚀", features = [] } = Astro.props;

const colorClasses = {
  primary: { bg: 'bg-primary/10', text: 'text-primary', border: 'border-primary/20' },
  secondary: { bg: 'bg-secondary/20', text: 'text-secondary', border: 'border-secondary/40' },
  accent: { bg: 'bg-accent/20', text: 'text-accent', border: 'border-accent/40' },
  highlight: { bg: 'bg-highlight/30', text: 'text-dark', border: 'border-highlight/50' },
  sky: { bg: 'bg-sky/20', text: 'text-sky', border: 'border-sky/40' },
}[color] || { bg: 'bg-secondary/20', text: 'text-secondary', border: 'border-secondary/40' };
---

<div class={`project-card group relative bg-cardBg rounded-stardew p-6 shadow-sm hover:shadow-stardew-lg transition-all duration-300 hover:-translate-y-2 border-2 ${colorClasses.border}`}>
  <div class="flex items-start gap-3 mb-3">
    <span class="text-3xl">{icon}</span>
    <div>
      <h3 class="font-heading text-xl font-semibold text-dark">{title}</h3>
    </div>
  </div>
  <p class="text-dark/70 mt-2 text-sm leading-relaxed">{description}</p>

  {features.length > 0 && (
    <ul class="mt-4 space-y-2">
      {features.map((feature) => (
        <li class="flex items-center gap-2 text-sm text-dark/70">
          <span class="w-1.5 h-1.5 rounded-full bg-secondary" />
          {feature}
        </li>
      ))}
    </ul>
  )}

  <div class="flex flex-wrap gap-2 mt-4">
    {tags.map((tag) => (
      <span class={`px-3 py-1 rounded-full text-xs font-medium ${colorClasses.bg} ${colorClasses.text}`}>
        {tag}
      </span>
    ))}
  </div>

  <a href={url} target="_blank" rel="noopener noreferrer"
    class="mt-6 inline-flex items-center gap-2 text-dark hover:text-primary transition-colors text-sm font-medium">
    <span>去看看</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
    </svg>
  </a>
</div>