---
import timeline from '../data/timeline.json';

const projects = timeline.projects;

const colorMap = {
  primary: { bg: 'bg-primary/10', text: 'text-primary', border: 'border-primary/30' },
  secondary: { bg: 'bg-secondary/20', text: 'text-secondary', border: 'border-secondary/40' },
  accent: { bg: 'bg-accent/20', text: 'text-accent', border: 'border-accent/40' },
  highlight: { bg: 'bg-highlight/30', text: 'text-dark', border: 'border-highlight/50' },
  sky: { bg: 'bg-sky/20', text: 'text-sky', border: 'border-sky/40' },
};
---

<div class="min-h-screen bg-gradient-to-b from-bgLight to-white">
  <!-- Navigation Bar -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md shadow-sm border-b-2 border-secondary/20">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-dark hover:text-primary transition-colors font-heading font-bold text-lg">
        <span class="text-xl">⬅️</span>
        <span>返回地图</span>
      </a>
      <div class="flex items-center gap-2">
        <span class="text-2xl">📋</span>
        <span class="font-heading text-dark">项目经历</span>
      </div>
      <div class="w-24"></div>
    </div>
  </nav>

  <!-- Page Header -->
  <header class="pt-24 pb-12 text-center relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full overflow-hidden -z-10 opacity-30">
      <div class="absolute top-10 left-10 text-6xl animate-float">🛍️</div>
      <div class="absolute top-20 right-20 text-4xl animate-float" style="animation-delay: 0.5s">📕</div>
      <div class="absolute bottom-10 left-1/4 text-5xl animate-float" style="animation-delay: 1s">💼</div>
    </div>
    <div class="inline-block bg-gradient-to-r from-highlight/20 via-accent/20 to-secondary/20 rounded-full px-6 py-2 mb-4">
      <span class="text-lg">🎯</span>
    </div>
    <h1 class="font-heading text-4xl md:text-5xl font-bold text-dark mb-4">
      项目经历
    </h1>
    <p class="text-dark/60 text-lg max-w-xl mx-auto">
      从私域电商到个人 IP 运营，实践出真知
    </p>
  </header>

  <!-- Projects List -->
  <main class="max-w-4xl mx-auto px-4 pb-16">
    <div class="space-y-8">
      {projects.map((project, index) => {
        const colors = colorMap[project.color as keyof typeof colorMap] || colorMap.secondary;
        return (
          <div class={`group relative bg-cardBg rounded-stardew p-6 md:p-8 shadow-sm hover:shadow-stardew-lg transition-all duration-300 border-2 ${colors.border} ${index === 0 ? 'ring-2 ring-highlight/50' : ''}`}>
            {/* Index Badge */}
            <div class={`absolute -top-3 -left-3 w-8 h-8 rounded-full flex items-center justify-center text-white font-bold text-sm ${index === 0 ? 'bg-highlight' : 'bg-secondary'}`}>
              {index + 1}
            </div>

            {/* Project Icon */}
            <div class="flex items-start gap-4 mb-4">
              <span class="text-5xl">{project.icon}</span>
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <h3 class="font-heading text-2xl font-bold text-dark">{project.title}</h3>
                  <span class={`px-3 py-1 rounded-full text-xs font-medium ${colors.bg} ${colors.text}`}>
                    {project.role}
                  </span>
                </div>
                <p class="text-dark/60 text-sm mb-2">{project.subtitle}</p>
                <span class="text-xs text-dark/40">{project.period}</span>
              </div>
            </div>

            {/* Description */}
            <p class="text-dark/70 leading-relaxed mb-4">{project.description}</p>

            {/* Highlights */}
            <div class="flex flex-wrap gap-3">
              {project.highlights.map((highlight) => (
                <div class="flex items-center gap-2 px-3 py-1.5 bg-secondary/10 rounded-lg">
                  <span class="w-1.5 h-1.5 rounded-full bg-secondary" />
                  <span class="text-sm text-dark/70">{highlight}</span>
                </div>
              ))}
            </div>

            {/* RPG Quest Indicator */}
            {index === 0 && (
              <div class="mt-6 pt-4 border-t border-secondary/20">
                <div class="flex items-center gap-2 text-sm text-highlight">
                  <span>🏅</span>
                  <span class="font-medium">主要项目</span>
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>

    <!-- RPG Decoration -->
    <div class="mt-16 text-center">
      <div class="inline-flex items-center gap-4 px-6 py-3 bg-highlight/10 rounded-full">
        <span class="text-2xl">📊</span>
        <span class="text-dark/60 text-sm font-medium">累计 13000+ 订单，520+ 粉丝</span>
        <span class="text-2xl">🎪</span>
      </div>
    </div>
  </main>
</div>