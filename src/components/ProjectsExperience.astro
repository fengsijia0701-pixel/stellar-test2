---
import timeline from '../data/timeline.json';

const projects = timeline.projects;
---

<section class="page-section">
  <div class="bg-sky"></div>
  <div class="bg-grass"></div>

  <div class="wood-frame">
    <div class="parchment">
      <h1 class="title">🛍️ 项目经历</h1>

      <div class="content">
        {projects.map((project) => (
          <div class="project-item">
            <div class="project-icon">{project.icon}</div>
            <div class="project-info">
              <h3 class="project-title">{project.title}</h3>
              <p class="project-sub">{project.subtitle}</p>
              <p class="project-desc">{project.description}</p>
              <div class="project-stats">
                {project.highlights?.map((h) => (
                  <span class="stat-tag">⭐ {h}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="nav-bar">
        <button class="wood-btn" data-action="goto" data-goto="page-map">◀ 返回地图</button>
      </div>
    </div>
  </div>
</section>

<style>
  .page-section {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(180deg, #87CEEB 0%, #B4E7CE 100%);
  }

  .bg-grass {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, #7CB342 0%, #558B2F 100%);
  }

  .wood-frame {
    position: relative;
    z-index: 10;
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 8px;
    padding: 10px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    max-width: 700px;
    width: 90%;
  }

  .parchment {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 24px;
    max-height: 85vh;
    overflow-y: auto;
  }

  .title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 2rem;
    color: #5D3A1A;
    text-align: center;
    margin-bottom: 16px;
  }

  .content {
    max-height: 55vh;
    overflow-y: auto;
    padding-right: 8px;
  }

  .project-item {
    background: rgba(255, 255, 255, 0.85);
    border: 3px solid #8B4513;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
    box-shadow: 0 4px 0 #5D3A1A;
  }

  .project-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .project-info {
    flex: 1;
  }

  .project-title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.3rem;
    color: #5D3A1A;
    margin-bottom: 4px;
  }

  .project-sub {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 0.95rem;
    color: #8B4513;
    margin-bottom: 8px;
  }

  .project-desc {
    font-size: 0.9rem;
    color: #6B5344;
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .project-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .stat-tag {
    background: #7CB342;
    color: #FFF8E7;
    padding: 4px 12px;
    border-radius: 15px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 0.8rem;
  }

  .nav-bar {
    text-align: center;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 2px dashed #A67C52;
  }

  .wood-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 24px;
    background: linear-gradient(180deg, #8B4513 0%, #6B3E26 100%);
    color: #FDF5E6;
    border: none;
    border-radius: 6px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 3px 0 #5D3A1A;
    transition: all 0.15s ease;
  }

  .wood-btn:hover {
    transform: translateY(-2px);
    background: linear-gradient(180deg, #A0522D 0%, #8B4513 100%);
  }

  @media (max-width: 500px) {
    .project-item {
      flex-direction: column;
      text-align: center;
    }

    .project-stats {
      justify-content: center;
    }
  }
</style>