---
import timeline from '../data/timeline.json';

const projects = timeline.projects;
---

<section id="projects-experience" class="fullscreen-page stardew-page">
  <div class="grass-sky-background"></div>

  <div class="stardew-panel content-panel">
    <h1 class="stardew-title">🛍️ 项目经历</h1>

    <div class="content-area">
      <div class="project-list">
        {projects.map((project, index) => (
          <div class="project-item">
            <div class="project-icon">{project.icon}</div>
            <div class="project-info">
              <h3>{project.title}</h3>
              <p class="project-subtitle">{project.subtitle}</p>
              <p class="project-desc">{project.description}</p>
              <div class="project-stats">
                {project.highlights.map((highlight) => (
                  <span class="stat-tag">⭐ {highlight}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="navigation-buttons">
      <button id="backBtn" class="stardew-button" data-target="rpg-map">◀ 返回地图</button>
    </div>
  </div>
</section>

<style>
  .fullscreen-page {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .stardew-page {
    background: linear-gradient(to bottom,
      #87CEEB 0%,
      #87CEEB 40%,
      #90EE90 40%,
      #7CB342 100%
    );
  }

  .grass-sky-background {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 20px,
        rgba(124, 179, 66, 0.15) 20px,
        rgba(124, 179, 66, 0.15) 40px
      );
  }

  .content-panel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 650px;
    max-height: 85vh;
    padding: 30px;
    z-index: 10;
  }

  .stardew-title {
    text-align: center;
    margin-bottom: 20px;
  }

  .content-area {
    padding: 10px 0;
    max-height: 55vh;
    overflow-y: auto;
  }

  .project-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .project-item {
    background: rgba(255, 255, 255, 0.85);
    border: 3px solid var(--color-wood);
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 4px 0 var(--color-wood-dark);
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .project-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  .project-info {
    flex: 1;
  }

  .project-info h3 {
    font-family: 'Gaegu', cursive;
    font-size: 1.4rem;
    color: var(--color-wood-dark);
    margin-bottom: 4px;
  }

  .project-subtitle {
    font-family: 'Gaegu', cursive;
    font-size: 1rem;
    color: var(--color-wood);
    margin-bottom: 8px;
  }

  .project-desc {
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.9rem;
    color: var(--color-text);
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .project-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .stat-tag {
    background: var(--color-grass);
    color: var(--color-cream);
    padding: 4px 12px;
    border-radius: 15px;
    font-family: 'Gaegu', cursive;
    font-size: 0.85rem;
  }

  .navigation-buttons {
    text-align: center;
    margin-top: 20px;
    padding-top: 15px;
    border-top: 2px dashed var(--color-wood-light);
  }

  /* Scrollbar styling */
  .content-area::-webkit-scrollbar {
    width: 8px;
  }

  .content-area::-webkit-scrollbar-track {
    background: var(--color-parchment);
    border-radius: 4px;
  }

  .content-area::-webkit-scrollbar-thumb {
    background: var(--color-wood);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .content-panel {
      width: 95%;
      padding: 20px;
    }

    .project-item {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .project-icon {
      font-size: 2rem;
    }

    .project-info h3 {
      font-size: 1.2rem;
    }
  }
</style>

<script>
  import { soundEffects } from '../scripts/sound';

  document.addEventListener('DOMContentLoaded', () => {
    const backBtn = document.getElementById('backBtn');
    if (backBtn) {
      backBtn.addEventListener('click', () => {
        soundEffects.playClick();
        const target = backBtn.getAttribute('data-target');
        if (target) {
          document.getElementById(target)?.scrollIntoView({ behavior: 'smooth' });
        }
      });
    }

    document.querySelectorAll('.stardew-button').forEach(btn => {
      btn.addEventListener('click', () => {
        soundEffects.playClick();
      });
    });
  });
</script>