---
import projects from '../data/projects.json';
---

<section id="projects-space" class="fullscreen-page stardew-page">
  <div class="grass-sky-background"></div>

  <div class="stardew-panel content-panel">
    <h1 class="stardew-title">📦 项目空间</h1>

    <div class="content-area">
      {projects.map((project) => (
        <div class="project-card">
          <div class="project-icon">{project.icon}</div>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="project-features">
            {project.features.map((feature) => (
              <span class="feature-tag">{feature}</span>
            ))}
          </div>
          <a href={project.url} target="_blank" class="stardew-button">
            访问 →
          </a>
        </div>
      ))}
    </div>

    <div class="navigation-buttons">
      <button id="backBtn" class="stardew-button" data-target="rpg-map">◀ 返回地图</button>
    </div>
  </div>
</section>

<style>
  .fullscreen-page {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .stardew-page {
    background: linear-gradient(to bottom,
      #87CEEB 0%,
      #87CEEB 40%,
      #90EE90 40%,
      #7CB342 100%
    );
  }

  .grass-sky-background {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 20px,
        rgba(124, 179, 66, 0.15) 20px,
        rgba(124, 179, 66, 0.15) 40px
      );
  }

  .content-panel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 600px;
    max-height: 85vh;
    padding: 30px;
    z-index: 10;
  }

  .stardew-title {
    text-align: center;
    margin-bottom: 20px;
  }

  .content-area {
    padding: 10px 0;
    max-height: 55vh;
    overflow-y: auto;
  }

  .project-card {
    background: rgba(255, 255, 255, 0.85);
    border: 3px solid var(--color-wood);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
    box-shadow: 0 4px 0 var(--color-wood-dark);
    text-align: center;
  }

  .project-icon {
    font-size: 3rem;
    margin-bottom: 10px;
  }

  .project-card h3 {
    font-family: 'Gaegu', cursive;
    font-size: 1.5rem;
    color: var(--color-wood-dark);
    margin-bottom: 8px;
  }

  .project-card p {
    font-family: 'Noto Sans SC', sans-serif;
    color: var(--color-text);
    font-size: 0.95rem;
    margin-bottom: 12px;
  }

  .project-features {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .feature-tag {
    background: var(--color-wood);
    color: var(--color-cream);
    padding: 4px 12px;
    border-radius: 15px;
    font-family: 'Gaegu', cursive;
    font-size: 0.85rem;
  }

  .project-card .stardew-button {
    font-size: 1rem;
    padding: 10px 24px;
  }

  .navigation-buttons {
    text-align: center;
    margin-top: 20px;
    padding-top: 15px;
    border-top: 2px dashed var(--color-wood-light);
  }

  /* Scrollbar styling */
  .content-area::-webkit-scrollbar {
    width: 8px;
  }

  .content-area::-webkit-scrollbar-track {
    background: var(--color-parchment);
    border-radius: 4px;
  }

  .content-area::-webkit-scrollbar-thumb {
    background: var(--color-wood);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .content-panel {
      width: 95%;
      padding: 20px;
    }

    .project-icon {
      font-size: 2.5rem;
    }

    .project-card h3 {
      font-size: 1.3rem;
    }
  }
</style>

<script>
  import { soundEffects } from '../scripts/sound';

  document.addEventListener('DOMContentLoaded', () => {
    const backBtn = document.getElementById('backBtn');
    if (backBtn) {
      backBtn.addEventListener('click', () => {
        soundEffects.playClick();
        const target = backBtn.getAttribute('data-target');
        if (target) {
          document.getElementById(target)?.scrollIntoView({ behavior: 'smooth' });
        }
      });
    }

    // Add click sound to all buttons
    document.querySelectorAll('.stardew-button').forEach(btn => {
      btn.addEventListener('click', () => {
        soundEffects.playClick();
      });
    });
  });
</script>