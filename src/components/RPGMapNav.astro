---
const mapLocations = [
  {
    id: 'about',
    name: '关于我',
    icon: '👩‍💼',
    description: '了解我的背景',
    targetId: 'about',
    position: 'top-24 left-1/4'
  },
  {
    id: 'experience',
    name: '经历',
    icon: '📋',
    description: '工作经历',
    targetId: 'who-am-i',
    position: 'top-1/3 right-1/4'
  },
  {
    id: 'skills',
    name: '技能',
    icon: '📊',
    description: '技能面板',
    targetId: 'skills',
    position: 'bottom-1/3 left-1/3'
  },
  {
    id: 'projects',
    name: '项目',
    icon: '🚀',
    description: '作品集',
    targetId: 'projects',
    position: 'bottom-24 right-1/3'
  },
  {
    id: 'contact',
    name: '联系',
    icon: '💬',
    description: '联系方式',
    targetId: 'contact',
    position: 'bottom-1/4 left-1/2'
  }
];
---

<section id="rpg-map" class="min-h-screen relative overflow-hidden bg-gradient-to-b from-sky/10 via-white to-secondary/5">
  <!-- Map Header -->
  <header class="pt-8 pb-4 text-center relative z-10">
    <div class="inline-flex items-center gap-3 bg-white/80 backdrop-blur-sm rounded-full px-6 py-3 shadow-sm border border-secondary/20">
      <span class="text-2xl">🗺️</span>
      <h1 class="font-heading text-2xl font-bold text-dark">探索地图</h1>
      <span class="text-sm text-dark/50">选择目的地开始冒险</span>
    </div>
  </header>

  <!-- RPG Map Container -->
  <div class="relative max-w-5xl mx-auto px-4" style="min-height: 60vh;">
    <!-- Ground/Path decorations -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <!-- Dirt path connecting locations -->
      <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none">
        <path
          d="M25% 20% Q 35% 30%, 33% 40%"
          stroke="#d4a574"
          stroke-width="40"
          fill="none"
          stroke-linecap="round"
          opacity="0.4"
        />
        <path
          d="M33% 40% Q 60% 35%, 75% 33%"
          stroke="#d4a574"
          stroke-width="35"
          fill="none"
          stroke-linecap="round"
          opacity="0.4"
        />
        <path
          d="M75% 33% Q 65% 50%, 60% 65%"
          stroke="#d4a574"
          stroke-width="30"
          fill="none"
          stroke-linecap="round"
          opacity="0.4"
        />
        <path
          d="M60% 65% Q 50% 70%, 50% 75%"
          stroke="#d4a574"
          stroke-width="25"
          fill="none"
          stroke-linecap="round"
          opacity="0.4"
        />
        <path
          d="M33% 40% Q 25% 55%, 33% 65%"
          stroke="#d4a574"
          stroke-width="25"
          fill="none"
          stroke-linecap="round"
          opacity="0.4"
        />
      </svg>

      <!-- Trees and decorations -->
      <div class="absolute top-16 right-16 text-4xl opacity-60">🌲</div>
      <div class="absolute top-32 left-8 text-3xl opacity-50">🌳</div>
      <div class="absolute bottom-32 right-12 text-4xl opacity-60">🌲</div>
      <div class="absolute bottom-16 left-16 text-3xl opacity-50">🌻</div>
      <div class="absolute top-1/2 right-8 text-2xl opacity-40">🍀</div>
      <div class="absolute top-1/3 left-4 text-2xl opacity-40">🌼</div>

      <!-- Floating particles -->
      <div class="absolute top-20 left-1/3 w-2 h-2 bg-highlight/50 rounded-full animate-float"></div>
      <div class="absolute top-40 right-1/4 w-3 h-3 bg-secondary/40 rounded-full animate-float" style="animation-delay: 0.5s"></div>
      <div class="absolute bottom-40 left-1/4 w-2 h-2 bg-primary/50 rounded-full animate-float" style="animation-delay: 1s"></div>
    </div>

    <!-- Map Locations -->
    {mapLocations.map((location) => (
      <div
        class={`absolute ${location.position} group cursor-pointer`}
        data-target={location.targetId}
      >
        <!-- Location Marker -->
        <div class="relative">
          <!-- Glow effect on hover -->
          <div class="absolute inset-0 bg-highlight/30 rounded-full blur-xl scale-150 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

          <!-- Main marker -->
          <div class="relative w-20 h-20 bg-white rounded-full shadow-stardew flex items-center justify-center border-4 border-secondary/30 group-hover:border-primary group-hover:scale-110 transition-all duration-300 group-hover:-translate-y-1">
            <span class="text-4xl group-hover:scale-110 transition-transform duration-300">{location.icon}</span>
          </div>

          <!-- Location name popup -->
          <div class="absolute top-full mt-3 left-1/2 -translate-x-1/2 whitespace-nowrap opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
            <div class="bg-dark/90 text-light text-sm px-4 py-2 rounded-lg shadow-lg">
              <div class="font-medium">{location.name}</div>
              <div class="text-xs text-white/70">{location.description}</div>
            </div>
            <!-- Arrow pointing up -->
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 translate-y-1 w-0 h-0 border-l-8 border-r-8 border-b-8 border-transparent border-b-dark/90"></div>
          </div>
        </div>

        <!-- Click ripple effect handled by JS -->
      </div>
    ))}

    <!-- Hero Character (pixel style) at center-ish -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20">
      <div class="pixel-hero relative">
        <div class="pixel-hero-sprite">
          <!-- Hair -->
          <div class="pixel-hero-hair"></div>
          <!-- Face -->
          <div class="pixel-hero-face">
            <div class="pixel-hero-eyes">
              <div class="pixel-hero-eye left"></div>
              <div class="pixel-hero-eye right"></div>
            </div>
          </div>
          <!-- Body -->
          <div class="pixel-hero-body"></div>
        </div>
        <div class="pixel-hero-shadow"></div>
      </div>
    </div>
  </div>

  <!-- Bottom hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-center">
    <p class="text-sm text-dark/40 animate-pulse">点击地图上的标记探索不同区域</p>
    <div class="flex justify-center gap-2 mt-2">
      <span class="text-lg animate-bounce" style="animation-delay: 0s">👇</span>
      <span class="text-lg animate-bounce" style="animation-delay: 0.2s">👇</span>
      <span class="text-lg animate-bounce" style="animation-delay: 0.4s">👇</span>
    </div>
  </div>
</section>

<style>
  /* Hero pixel character styles */
  .pixel-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pixel-hero-sprite {
    position: relative;
    width: 32px;
    height: 48px;
    animation: heroBounce 1s ease-in-out infinite;
  }

  @keyframes heroBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .pixel-hero-hair {
    position: absolute;
    top: 0;
    left: 4px;
    width: 24px;
    height: 16px;
    background: transparent;
    box-shadow:
      4px 0 0 #4a3728,
      8px 0 0 #4a3728,
      12px 0 0 #4a3728,
      16px 0 0 #4a3728,
      0 4px 0 #4a3728,
      4px 4px 0 #5c4033,
      8px 4px 0 #5c4033,
      12px 4px 0 #5c4033,
      16px 4px 0 #4a3728,
      20px 4px 0 #4a3728,
      0 8px 0 #4a3728,
      20px 8px 0 #4a3728;
  }

  .pixel-hero-face {
    position: absolute;
    top: 12px;
    left: 6px;
    width: 20px;
    height: 14px;
    background: #fdbf8f;
  }

  .pixel-hero-eyes {
    position: absolute;
    top: 4px;
    width: 100%;
  }

  .pixel-hero-eye {
    position: absolute;
    width: 3px;
    height: 3px;
    background: #3d2914;
    top: 2px;
  }

  .pixel-hero-eye.left { left: 4px; }
  .pixel-hero-eye.right { right: 4px; }

  .pixel-hero-body {
    position: absolute;
    top: 26px;
    left: 4px;
    width: 24px;
    height: 18px;
    background: transparent;
    box-shadow:
      4px 0 0 #e8a0a0,
      8px 0 0 #e8a0a0,
      12px 0 0 #f0b0b0,
      16px 0 0 #e8a0a0,
      20px 0 0 #e8a0a0,
      0 8px 0 #e8a0a0,
      4px 8px 0 #e8a0a0,
      8px 8px 0 #e8a0a0,
      12px 8px 0 #e8a0a0,
      16px 8px 0 #e8a0a0,
      20px 8px 0 #e8a0a0;
  }

  .pixel-hero-shadow {
    width: 30px;
    height: 6px;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 50%;
    margin-top: 2px;
    animation: shadowPulse 1s ease-in-out infinite;
  }

  @keyframes shadowPulse {
    0%, 100% { transform: scale(1); opacity: 0.15; }
    50% { transform: scale(0.9); opacity: 0.2; }
  }

  .pixel-hero-sprite {
    transform: scale(2);
    transform-origin: top center;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mapLocations = document.querySelectorAll('#rpg-map [data-target]');

    mapLocations.forEach((location) => {
      location.addEventListener('click', () => {
        const targetId = location.getAttribute('data-target');
        if (targetId) {
          const targetSection = document.getElementById(targetId);
          if (targetSection) {
            // Hide RPG map first
            const rpgMap = document.getElementById('rpg-map');
            if (rpgMap) {
              rpgMap.style.transition = 'opacity 0.4s ease-out';
              rpgMap.style.opacity = '0';

              setTimeout(() => {
                rpgMap.style.display = 'none';
                targetSection.scrollIntoView({ behavior: 'smooth' });

                // Show section content if it was hidden
                targetSection.style.opacity = '0';
                targetSection.style.display = 'block';
                setTimeout(() => {
                  targetSection.style.transition = 'opacity 0.4s ease-out';
                  targetSection.style.opacity = '1';
                }, 100);
              }, 400);
            } else {
              targetSection.scrollIntoView({ behavior: 'smooth' });
            }
          }
        }
      });
    });
  });
</script>
