---
const locations = [
  {
    id: 'about',
    name: '关于我',
    icon: '🏠',
    description: '了解我的背景与经历',
    position: 'top-left',
    color: 'primary'
  },
  {
    id: 'projects',
    name: '项目空间',
    icon: '📦',
    description: '探索我的工作成果',
    position: 'top-right',
    color: 'secondary'
  },
  {
    id: 'skills',
    name: '技能大陆',
    icon: '⚔️',
    description: '解锁职场关键技能',
    position: 'bottom-left',
    color: 'accent'
  },
  {
    id: 'contact',
    name: '联系中心',
    icon: '📮',
    description: '与我取得联系',
    position: 'bottom-right',
    color: 'highlight'
  }
];

const positionStyles = {
  'top-left': 'top-16 left-16 md:top-24 md:left-24',
  'top-right': 'top-16 right-16 md:top-24 md:right-24',
  'bottom-left': 'bottom-16 left-16 md:bottom-24 md:left-24',
  'bottom-right': 'bottom-16 right-16 md:bottom-24 md:right-24'
};

const colorStyles = {
  primary: {
    bg: 'bg-primary/20',
    border: 'border-primary/50',
    hover: 'hover:bg-primary/30 hover:border-primary',
    glow: 'shadow-primary/30'
  },
  secondary: {
    bg: 'bg-secondary/20',
    border: 'border-secondary/50',
    hover: 'hover:bg-secondary/30 hover:border-secondary',
    glow: 'shadow-secondary/30'
  },
  accent: {
    bg: 'bg-accent/20',
    border: 'border-accent/50',
    hover: 'hover:bg-accent/30 hover:border-accent',
    glow: 'shadow-accent/30'
  },
  highlight: {
    bg: 'bg-highlight/20',
    border: 'border-highlight/50',
    hover: 'hover:bg-highlight/30 hover:border-highlight',
    glow: 'shadow-highlight/30'
  }
};
---

<div id="rpg-map" class="min-h-screen bg-gradient-to-b from-bgLight to-white relative overflow-hidden map-background">
  <!-- Game Title Header -->
  <header class="absolute top-0 left-0 right-0 z-20 pt-8 px-4 text-center">
    <div class="inline-flex items-center gap-3 bg-white/80 backdrop-blur-md rounded-full px-6 py-2 shadow-lg">
      <span class="text-2xl">🗺️</span>
      <h1 class="font-heading text-xl md:text-2xl font-bold text-dark">
        冯思佳的世界
      </h1>
      <span class="text-sm text-dark/50">v1.0</span>
    </div>
  </header>

  <!-- Decorative Elements - Trees and Bushes -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-green-500/20 to-transparent z-10 pointer-events-none" />

  <!-- Floating decorations -->
  <div class="absolute top-32 left-10 text-4xl opacity-40 animate-float">🌲</div>
  <div class="absolute top-40 right-16 text-3xl opacity-30 animate-float" style="animation-delay: 0.5s">🌳</div>
  <div class="absolute bottom-40 left-20 text-3xl opacity-30 animate-float" style="animation-delay: 1s">🌲</div>
  <div class="absolute bottom-32 right-32 text-4xl opacity-40 animate-float" style="animation-delay: 1.5s">🌿</div>
  <div class="absolute top-1/2 left-8 text-2xl opacity-20 animate-float" style="animation-delay: 2s">🍀</div>
  <div class="absolute top-1/3 right-12 text-2xl opacity-20 animate-float" style="animation-delay: 2.5s">🌸</div>

  <!-- Path/Road connecting locations - SVG -->
  <div class="absolute inset-0 z-10 pointer-events-none">
    <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
      <!-- Diagonal paths connecting locations -->
      <path d="M 20 25 Q 50 50 80 25" stroke="#d4c4a8" stroke-width="3" fill="none" stroke-dasharray="5,3" opacity="0.5"/>
      <path d="M 20 75 Q 50 50 80 75" stroke="#d4c4a8" stroke-width="3" fill="none" stroke-dasharray="5,3" opacity="0.5"/>
      <path d="M 25 20 Q 50 50 25 80" stroke="#d4c4a8" stroke-width="3" fill="none" stroke-dasharray="5,3" opacity="0.5"/>
      <path d="M 75 20 Q 50 50 75 80" stroke="#d4c4a8" stroke-width="3" fill="none" stroke-dasharray="5,3" opacity="0.5"/>
    </svg>
  </div>

  <!-- Center Character/Avatar -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-15">
    <div class="relative">
      <!-- Character glow effect -->
      <div class="absolute inset-0 w-32 h-32 bg-primary/30 rounded-full blur-2xl animate-pulse" />
      <!-- Character -->
      <div class="relative w-32 h-32 rounded-stardew bg-gradient-to-br from-primary via-accent to-secondary p-1 shadow-xl hover:scale-110 transition-transform duration-300 cursor-pointer">
        <div class="w-full h-full rounded-stardew bg-cardBg flex items-center justify-center">
          <span class="text-5xl">👩‍🌾</span>
        </div>
      </div>
      <!-- Character label -->
      <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-dark/80 text-white text-xs px-3 py-1 rounded-full whitespace-nowrap">
        你在这里
      </div>
    </div>
  </div>

  <!-- Location Cards -->
  {locations.map((location) => {
    const posStyle = positionStyles[location.position as keyof typeof positionStyles];
    const colStyle = colorStyles[location.color as keyof typeof colorStyles];
    return (
      <button
        data-target={location.id}
        class={`absolute ${posStyle} group z-20 transition-all duration-500 hover:scale-110 hover:z-30 cursor-pointer ripple`}
      >
        <div class={`relative p-4 md:p-6 rounded-stardew bg-white/90 backdrop-blur-md border-2 ${colStyle.border} ${colStyle.hover} shadow-lg ${colStyle.glow} transition-all duration-300`}>
          <!-- Icon -->
          <div class={`w-12 h-12 md:w-16 md:h-16 rounded-full ${colStyle.bg} flex items-center justify-center mb-2 md:mb-3 group-hover:scale-110 transition-transform duration-300`}>
            <span class="text-2xl md:text-4xl">{location.icon}</span>
          </div>

          <!-- Content -->
          <div class="text-center">
            <h3 class="font-heading font-bold text-dark text-sm md:text-lg mb-1">
              {location.name}
            </h3>
            <p class="text-xs text-dark/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:block">
              {location.description}
            </p>
          </div>

          <!-- Hover indicator -->
          <div class="absolute -top-2 -right-2 w-6 h-6 bg-highlight rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">
            <span class="text-white text-xs">→</span>
          </div>
        </div>

        <!-- Location name tooltip on hover -->
        <div class={`absolute top-full left-1/2 -translate-x-1/2 mt-2 ${colStyle.bg} px-3 py-1 rounded-full text-xs font-medium text-dark opacity-0 group-hover:opacity-100 transition-all duration-300 transform -translate-y-2 group-hover:translate-y-0 whitespace-nowrap`}>
          前往 {location.name}
        </div>
      </button>
    );
  })}

  <!-- Bottom hint -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-20">
    <div class="flex items-center gap-2 text-dark/40 text-sm">
      <span class="animate-bounce">👆</span>
      <span>选择一个地点开始探索</span>
    </div>
  </div>

  <!-- Sparkle decorations -->
  <div class="absolute top-20 left-1/4 w-2 h-2 sparkle" style="animation-delay: 0.3s;"></div>
  <div class="absolute top-32 right-1/3 w-2 h-2 sparkle" style="animation-delay: 1.2s;"></div>
  <div class="absolute bottom-40 left-1/3 w-2 h-2 sparkle" style="animation-delay: 0.7s;"></div>
  <div class="absolute bottom-20 right-1/4 w-2 h-2 sparkle" style="animation-delay: 1.8s;"></div>
  <div class="absolute top-1/2 left-20 w-2 h-2 sparkle" style="animation-delay: 2.3s;"></div>
  <div class="absolute top-1/3 right-24 w-2 h-2 sparkle" style="animation-delay: 0.4s;"></div>

  <!-- Decorative corner elements -->
  <div class="absolute top-0 left-0 w-48 h-48 bg-gradient-to-br from-primary/10 to-transparent pointer-events-none" />
  <div class="absolute top-0 right-0 w-48 h-48 bg-gradient-to-bl from-secondary/10 to-transparent pointer-events-none" />
  <div class="absolute bottom-0 left-0 w-48 h-48 bg-gradient-to-tr from-accent/10 to-transparent pointer-events-none" />
  <div class="absolute bottom-0 right-0 w-48 h-48 bg-gradient-to-tl from-highlight/10 to-transparent pointer-events-none" />
</div>

<style>
  /* Pixel art border effect */
  .rounded-stardew {
    border-radius: 12px;
    box-shadow:
      0 4px 0 rgba(58, 46, 42, 0.1),
      0 8px 16px rgba(58, 46, 42, 0.1);
  }

  /* Location card hover effect */
  button:hover .rounded-stardew {
    box-shadow:
      0 4px 0 rgba(58, 46, 42, 0.15),
      0 12px 24px rgba(58, 46, 42, 0.15);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mapContainer = document.getElementById('rpg-map');
    if (!mapContainer) return;

    const locationButtons = mapContainer.querySelectorAll('button[data-target]');

    locationButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId) return;

        const targetSection = document.getElementById(targetId);
        if (!targetSection) return;

        // Fade out RPG map
        mapContainer.style.transition = 'opacity 0.4s ease-out';
        mapContainer.style.opacity = '0';

        setTimeout(() => {
          mapContainer.style.display = 'none';

          // Scroll to target section
          targetSection.scrollIntoView({ behavior: 'smooth' });

          // Fade in target section
          targetSection.style.opacity = '0';
          targetSection.style.display = 'block';
          setTimeout(() => {
            targetSection.style.transition = 'opacity 0.4s ease-out';
            targetSection.style.opacity = '1';
          }, 100);
        }, 400);
      });
    });
  });
</script>
