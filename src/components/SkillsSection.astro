---
import skillsData from '../data/skills.json';

const categories = [
  { key: 'product', icon: '💼', label: '产品经理' },
  { key: 'ecommerce', icon: '🛒', label: '电商运营' },
  { key: 'commercial', icon: '📊', label: '商业化运营' },
  { key: 'marketing', icon: '📢', label: '市场营销' },
];

const levelColors: Record<string, string> = {
  '熟练': 'proficient',
  '掌握': 'intermediate',
  '了解': 'basic'
};
---

<section class="page-section">
  <div class="bg-sky"></div>
  <div class="bg-grass"></div>

  <div class="wood-frame">
    <div class="parchment">
      <h1 class="title">⚔️ 技能大陆</h1>

      <div class="content">
        <div class="skills-grid">
          {categories.map((cat) => {
            const category = skillsData[cat.key as keyof typeof skillsData];
            return (
              <div class="skill-card">
                <h3 class="skill-title">{cat.icon} {cat.label}</h3>
                <div class="skill-tags">
                  {category?.skills?.map((skill: any) => (
                    <span class={`tag ${levelColors[skill.level as string] || 'basic'}`}>
                      {skill.name}
                    </span>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <div class="nav-bar">
        <button class="wood-btn" data-action="goto" data-goto="page-map">◀ 返回地图</button>
      </div>
    </div>
  </div>
</section>

<style>
  .page-section {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    background: linear-gradient(180deg, #87CEEB 0%, #B4E7CE 100%);
  }

  .bg-grass {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(180deg, #7CB342 0%, #558B2F 100%);
  }

  .wood-frame {
    position: relative;
    z-index: 10;
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 8px;
    padding: 10px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    max-width: 700px;
    width: 90%;
  }

  .parchment {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 24px;
    max-height: 85vh;
    overflow-y: auto;
  }

  .title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 2rem;
    color: #5D3A1A;
    text-align: center;
    margin-bottom: 16px;
  }

  .content {
    max-height: 55vh;
    overflow-y: auto;
    padding-right: 8px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  @media (max-width: 550px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }

  .skill-card {
    background: rgba(255, 255, 255, 0.85);
    border: 3px solid #8B4513;
    border-radius: 12px;
    padding: 16px;
    box-shadow: 0 4px 0 #5D3A1A;
  }

  .skill-title {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.1rem;
    color: #5D3A1A;
    text-align: center;
    margin-bottom: 10px;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
  }

  .tag {
    padding: 5px 12px;
    border-radius: 20px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-weight: 700;
    font-size: 0.85rem;
  }

  .tag.proficient {
    background: #8B4513;
    color: #FFF8E7;
  }

  .tag.intermediate {
    background: #7CB342;
    color: #FFF8E7;
  }

  .tag.basic {
    background: #A67C52;
    color: #FFF8E7;
  }

  .nav-bar {
    text-align: center;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 2px dashed #A67C52;
  }

  .wood-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 24px;
    background: linear-gradient(180deg, #8B4513 0%, #6B3E26 100%);
    color: #FDF5E6;
    border: none;
    border-radius: 6px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 3px 0 #5D3A1A;
    transition: all 0.15s ease;
  }

  .wood-btn:hover {
    transform: translateY(-2px);
    background: linear-gradient(180deg, #A0522D 0%, #8B4513 100%);
  }

  .content::-webkit-scrollbar {
    width: 6px;
  }

  .content::-webkit-scrollbar-track {
    background: #F5E6C8;
    border-radius: 4px;
  }

  .content::-webkit-scrollbar-thumb {
    background: #8B4513;
    border-radius: 4px;
  }
</style>