<section class="welcome-page">
  <!-- Sky and Grass Background -->
  <div class="sky-bg"></div>
  <div class="grass-bg"></div>

  <!-- Floating Decorations -->
  <div class="decorations">
    <span class="deco" style="top: 8%; left: 5%;">🌸</span>
    <span class="deco" style="top: 15%; right: 8%;">🌼</span>
    <span class="deco" style="top: 25%; left: 12%;">✨</span>
    <span class="deco" style="bottom: 35%; left: 8%;">🍀</span>
    <span class="deco" style="bottom: 28%; right: 10%;">🌻</span>
    <span class="deco" style="top: 35%; right: 5%;">⭐</span>
  </div>

  <!-- Wood Frame Panel -->
  <div class="wood-frame">
    <div class="parchment">
      <!-- Pixel Character -->
      <div class="character-wrapper">
        <div class="pixel-character">
          <!-- Hair -->
          <div class="hair"></div>
          <!-- Face -->
          <div class="face">
            <div class="glasses">
              <div class="lens left"></div>
              <div class="lens right"></div>
              <div class="bridge"></div>
            </div>
            <div class="eyes">
              <div class="eye left"></div>
              <div class="eye right"></div>
            </div>
            <div class="mouth"></div>
          </div>
          <!-- Body -->
          <div class="body"></div>
        </div>
        <!-- Music Notes -->
        <div class="notes">
          <span class="note n1">♪</span>
          <span class="note n2">♫</span>
          <span class="note n3">♪</span>
        </div>
      </div>

      <!-- Title -->
      <h1 class="title-small">你好，我是</h1>
      <h2 class="title-name">冯思佳</h2>

      <!-- Subtitle -->
      <p class="subtitle">产品 / 运营 / 市场营销</p>

      <!-- Start Button -->
      <button class="wood-btn" data-action="next">
        <span>🎵</span> 开始探索
      </button>
    </div>
  </div>
</section>

<style>
  .welcome-page {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Sky Background */
  .sky-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 70%;
    background: linear-gradient(180deg, #87CEEB 0%, #B4E7CE 100%);
  }

  /* Grass Background */
  .grass-bg {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 35%;
    background: linear-gradient(180deg, #7CB342 0%, #558B2F 100%);
  }

  .grass-bg::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 20px;
    background: repeating-linear-gradient(
      90deg,
      #81C784 0px,
      #81C784 8px,
      transparent 8px,
      transparent 20px
    );
  }

  /* Decorations */
  .decorations {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .deco {
    position: absolute;
    font-size: 2rem;
    animation: float 3s ease-in-out infinite;
    filter: drop-shadow(2px 2px 2px rgba(0,0,0,0.2));
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* Wood Frame Panel */
  .wood-frame {
    position: relative;
    z-index: 10;
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 8px;
    padding: 10px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.4),
      inset 0 2px 4px rgba(255, 255, 255, 0.2);
  }

  .wood-frame::before {
    content: '';
    position: absolute;
    top: 4px;
    left: 4px;
    right: 4px;
    bottom: 4px;
    border: 3px solid #5D3A1A;
    border-radius: 4px;
    pointer-events: none;
  }

  /* Parchment */
  .parchment {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 40px 60px;
    text-align: center;
    min-width: 380px;
  }

  /* Character Wrapper */
  .character-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: 20px;
  }

  /* Pixel Character - Complete body */
  .pixel-character {
    position: relative;
    width: 64px;
    height: 96px;
    margin: 0 auto;
  }

  /* Hair - brown curly */
  .hair {
    position: absolute;
    top: 0;
    left: 4px;
    width: 56px;
    height: 40px;
    background: transparent;
    box-shadow:
      /* Top row */
      8px 0 0 #4a3728, 16px 0 0 #4a3728, 24px 0 0 #4a3728, 32px 0 0 #4a3728, 40px 0 0 #4a3728, 48px 0 0 #4a3728,
      /* Row 2 */
      0 8px 0 #4a3728, 56px 8px 0 #4a3728,
      /* Row 3 */
      0 16px 0 #4a3728, 8px 16px 0 #5c4033, 16px 16px 0 #5c4033, 24px 16px 0 #6b4c3a, 32px 16px 0 #5c4033, 40px 16px 0 #5c4033, 48px 16px 0 #4a3728, 56px 16px 0 #4a3728,
      /* Row 4 - sides */
      0 24px 0 #4a3728, 8px 24px 0 #4a3728, 48px 24px 0 #4a3728, 56px 24px 0 #4a3728,
      /* Row 5 */
      0 32px 0 #4a3728, 8px 32px 0 #4a3728, 48px 32px 0 #4a3728, 56px 32px 0 #4a3728;
  }

  /* Face - connected to hair */
  .face {
    position: absolute;
    top: 24px;
    left: 8px;
    width: 48px;
    height: 40px;
    background: #fdbf8f;
    box-shadow:
      /* Eyes */
      8px 8px 0 #3d2914, 32px 8px 0 #3d2914,
      /* Cheeks */
      4px 16px 0 #ffb6a3, 36px 16px 0 #ffb6a3;
  }

  /* Glasses */
  .glasses {
    position: absolute;
    top: 4px;
    left: 0;
    width: 48px;
    height: 12px;
  }

  .lens {
    position: absolute;
    top: 0;
    width: 16px;
    height: 12px;
    border: 3px solid #3d2914;
    border-radius: 3px;
  }

  .lens.left { left: 2px; }
  .lens.right { right: 2px; }

  .bridge {
    position: absolute;
    top: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 3px;
    background: #3d2914;
  }

  /* Eyes */
  .eyes {
    position: absolute;
    top: 12px;
    left: 0;
    width: 48px;
  }

  .eye {
    position: absolute;
    width: 4px;
    height: 4px;
    background: #1a1a1a;
    border-radius: 50%;
  }

  .eye.left { left: 12px; }
  .eye.right { right: 12px; }

  /* Mouth - singing */
  .mouth {
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 6px;
    background: #3d2914;
    border-radius: 0 0 50% 50%;
    animation: sing 0.4s ease-in-out infinite;
  }

  @keyframes sing {
    0%, 100% { height: 4px; }
    50% { height: 8px; }
  }

  /* Body */
  .body {
    position: absolute;
    top: 56px;
    left: 8px;
    width: 48px;
    height: 40px;
    background: #e8a0a0;
    box-shadow:
      /* Collar */
      16px 0 0 #d88888, 24px 0 0 #d88888,
      /* Shirt */
      0 8px 0 #e8a0a0, 8px 8px 0 #e8a0a0, 16px 8px 0 #e8a0a0, 24px 8px 0 #f0b0b0, 32px 8px 0 #e8a0a0, 40px 8px 0 #e8a0a0,
      0 16px 0 #e8a0a0, 8px 16px 0 #e8a0a0, 16px 16px 0 #e8a0a0, 24px 16px 0 #e8a0a0, 32px 16px 0 #e8a0a0, 40px 16px 0 #e8a0a0,
      /* Pants */
      8px 24px 0 #5c4033, 16px 24px 0 #5c4033, 24px 24px 0 #5c4033, 32px 24px 0 #5c4033,
      8px 32px 0 #5c4033, 32px 32px 0 #5c4033;
  }

  /* Music Notes */
  .notes {
    position: absolute;
    top: 0;
    left: 70px;
    width: 60px;
    height: 80px;
  }

  .note {
    position: absolute;
    font-size: 1.4rem;
    animation: floatNote 2s ease-out infinite;
    opacity: 0;
  }

  .n1 { left: 0; top: 20px; animation-delay: 0s; }
  .n2 { left: 25px; top: 10px; animation-delay: 0.5s; font-size: 1.2rem; }
  .n3 { left: 45px; top: 25px; animation-delay: 1s; }

  @keyframes floatNote {
    0% { opacity: 0; transform: translateY(0) scale(0.8); }
    20% { opacity: 1; }
    100% { opacity: 0; transform: translateY(-30px) scale(0.5); }
  }

  /* Title */
  .title-small {
    font-family: var(--font-game);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-wood-dark);
    margin: 0 0 4px 0;
  }

  .title-name {
    font-family: var(--font-game);
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--color-wood);
    margin: 0 0 12px 0;
    text-shadow: 2px 2px 0 rgba(139, 90, 43, 0.2);
  }

  .subtitle {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--color-wood-dark);
    letter-spacing: 2px;
    margin: 0 0 24px 0;
  }

  /* Wood Button */
  .wood-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: linear-gradient(180deg, var(--color-wood) 0%, var(--color-wood-dark) 100%);
    color: var(--color-cream);
    border: none;
    border-radius: 6px;
    font-family: var(--font-game);
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow:
      0 4px 0 var(--color-wood-dark),
      0 6px 12px rgba(0, 0, 0, 0.3),
      0 0 15px rgba(139, 90, 43, 0.3);
    transition: all 0.15s ease;
  }

  .wood-btn:hover {
    transform: translateY(-2px);
    background: linear-gradient(180deg, var(--color-wood-light) 0%, var(--color-wood) 100%);
    box-shadow:
      0 6px 0 var(--color-wood-dark),
      0 8px 16px rgba(0, 0, 0, 0.35),
      0 0 25px rgba(139, 90, 43, 0.5);
  }

  .wood-btn:active {
    transform: translateY(2px);
    box-shadow:
      0 2px 0 var(--color-wood-dark),
      0 4px 8px rgba(0, 0, 0, 0.25);
  }

  /* Responsive */
  @media (max-width: 500px) {
    .parchment {
      min-width: auto;
      padding: 30px 40px;
    }

    .title-name {
      font-size: 2.2rem;
    }
  }
</style>