<section class="welcome-page">
  <div class="wood-frame">
    <div class="folder-tab">📁 WELCOME</div>
    <div class="folder-inner">
      <!-- 像素女孩 -->
      <div class="pixel-girl">
        <div class="hair"></div>
        <div class="face">
          <div class="glasses">
            <div class="lens left"></div>
            <div class="lens right"></div>
            <div class="bridge"></div>
          </div>
          <div class="eyes">
            <div class="eye left"></div>
            <div class="eye right"></div>
          </div>
          <div class="blush left"></div>
          <div class="blush right"></div>
          <div class="mouth"></div>
        </div>
        <div class="body"></div>
        <div class="notes">
          <span class="note n1">♪</span>
          <span class="note n2">♫</span>
          <span class="note n3">♪</span>
        </div>
      </div>

      <div class="welcome-title-zh">你好，我是</div>
      <div class="welcome-title-en">ABOUT ME</div>
      <div class="welcome-name">冯思佳</div>
      <div class="welcome-divider"></div>
      <div class="welcome-subtitle">PRODUCT / OPS / MARKETING</div>
      <button class="wood-btn" data-action="next">
        <span>🎵</span> 开始探索
      </button>
    </div>
  </div>
</section>

<style>
  .welcome-page {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  .wood-frame {
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 10px;
    padding: 10px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    max-width: 400px;
    width: 90%;
  }

  .folder-tab {
    background: linear-gradient(180deg, #5D4037 0%, #4E342E 100%);
    color: #FDF5E6;
    padding: 8px 18px;
    display: inline-block;
    border-radius: 5px 5px 0 0;
    font-family: 'Press Start 2P', cursive;
    font-size: 0.45rem;
    letter-spacing: 1px;
    margin-bottom: -3px;
  }

  .folder-inner {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 24px;
    color: #5D3A1A;
    text-align: center;
  }

  .welcome-title-zh {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.6rem;
    color: #5D3A1A;
  }

  .welcome-title-en {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.4rem;
    color: #8B4513;
    letter-spacing: 2px;
    margin-top: 4px;
  }

  .welcome-name {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 2.4rem;
    color: #5D3A1A;
    margin-top: 8px;
  }

  .welcome-divider {
    width: 80px;
    height: 3px;
    background: #8B4513;
    margin: 12px auto;
  }

  .welcome-subtitle {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.5rem;
    color: #8B4513;
    letter-spacing: 1px;
  }

  .wood-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    padding: 12px 28px;
    background: linear-gradient(180deg, #8B4513 0%, #6B3E26 100%);
    color: #FDF5E6;
    border: none;
    border-radius: 6px;
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.1rem;
    cursor: pointer;
    box-shadow: 0 4px 0 #5D3A1A;
    transition: all 0.15s;
  }

  .wood-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 0 #5D3A1A;
  }

  .wood-btn:active {
    transform: translateY(2px);
    box-shadow: 0 2px 0 #5D3A1A;
  }

  /* 像素女孩 */
  .pixel-girl {
    position: relative;
    width: 64px;
    height: 96px;
    margin: 0 auto 15px;
  }

  .pixel-girl .hair {
    position: absolute;
    top: 0;
    left: 4px;
    width: 56px;
    height: 40px;
    background: transparent;
    box-shadow:
      8px 0 0 #1a1a1a, 16px 0 0 #1a1a1a, 24px 0 0 #1a1a1a, 32px 0 0 #1a1a1a, 40px 0 0 #1a1a1a, 48px 0 0 #1a1a1a,
      0 8px 0 #1a1a1a, 56px 8px 0 #1a1a1a,
      0 16px 0 #1a1a1a, 8px 16px 0 #2d2d2d, 16px 16px 0 #2d2d2d, 24px 16px 0 #1a1a1a, 32px 16px 0 #2d2d2d, 40px 16px 0 #2d2d2d, 48px 16px 0 #1a1a1a, 56px 16px 0 #1a1a1a,
      0 24px 0 #1a1a1a, 8px 24px 0 #1a1a1a, 48px 24px 0 #1a1a1a, 56px 24px 0 #1a1a1a,
      0 32px 0 #1a1a1a, 8px 32px 0 #1a1a1a, 48px 32px 0 #1a1a1a, 56px 32px 0 #1a1a1a;
  }

  .pixel-girl .face {
    position: absolute;
    top: 24px;
    left: 8px;
    width: 48px;
    height: 32px;
    background: #FDD8D8;
  }

  .pixel-girl .glasses {
    position: absolute;
    top: 0;
    left: 0;
    width: 48px;
    height: 12px;
  }

  .pixel-girl .lens {
    position: absolute;
    top: 0;
    width: 16px;
    height: 12px;
    border: 3px solid #333;
    border-radius: 3px;
  }

  .pixel-girl .lens.left { left: 2px; }
  .pixel-girl .lens.right { right: 2px; }

  .pixel-girl .bridge {
    position: absolute;
    top: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 3px;
    background: #333;
  }

  .pixel-girl .eyes {
    position: absolute;
    top: 12px;
    left: 0;
    width: 48px;
  }

  .pixel-girl .eye {
    position: absolute;
    top: 0;
    width: 4px;
    height: 4px;
    background: #1a1a1a;
    border-radius: 50%;
  }

  .pixel-girl .eye.left { left: 12px; }
  .pixel-girl .eye.right { right: 12px; }

  .pixel-girl .blush {
    position: absolute;
    top: 20px;
    width: 6px;
    height: 4px;
    background: #FFB6C1;
    border-radius: 50%;
    opacity: 0.7;
  }

  .pixel-girl .blush.left { left: 4px; }
  .pixel-girl .blush.right { right: 4px; }

  .pixel-girl .mouth {
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 6px;
    background: #c44569;
    border-radius: 0 0 50% 50%;
    animation: sing 0.4s ease-in-out infinite;
  }

  @keyframes sing {
    0%, 100% { height: 4px; }
    50% { height: 8px; }
  }

  .pixel-girl .body {
    position: absolute;
    top: 52px;
    left: 8px;
    width: 48px;
    height: 36px;
    background: #9B59B6;
    box-shadow:
      16px 0 0 #8E44AD, 24px 0 0 #8E44AD,
      0 8px 0 #9B59B6, 8px 8px 0 #9B59B6, 16px 8px 0 #9B59B6, 24px 8px 0 #9B59B6, 32px 8px 0 #9B59B6, 40px 8px 0 #9B59B6,
      0 16px 0 #9B59B6, 8px 16px 0 #9B59B6, 16px 16px 0 #9B59B6, 24px 16px 0 #9B59B6, 32px 16px 0 #9B59B6, 40px 16px 0 #9B59B6,
      8px 24px 0 #8E44AD, 16px 24px 0 #8E44AD, 24px 24px 0 #8E44AD, 32px 24px 0 #8E44AD,
      8px 32px 0 #8E44AD, 32px 32px 0 #8E44AD;
  }

  .pixel-girl .notes {
    position: absolute;
    top: 5px;
    left: 65px;
    width: 50px;
    height: 60px;
  }

  .pixel-girl .note {
    position: absolute;
    font-size: 1.2rem;
    animation: floatNote 2s ease-out infinite;
    opacity: 0;
  }

  .pixel-girl .n1 { left: 0; top: 10px; animation-delay: 0s; }
  .pixel-girl .n2 { left: 20px; top: 0; animation-delay: 0.5s; font-size: 1rem; }
  .pixel-girl .n3 { left: 35px; top: 15px; animation-delay: 1s; }

  @keyframes floatNote {
    0% { opacity: 0; transform: translateY(0) scale(0.8); }
    20% { opacity: 1; }
    100% { opacity: 0; transform: translateY(-25px) scale(0.5); }
  }
</style>