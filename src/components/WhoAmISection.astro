---
---

<section class="whoami-page">
  <div class="wood-frame">
    <div class="folder-tab">📁 ABOUT ME</div>
    <div class="folder-inner">
      <div class="main-title">
        <div class="main-title-zh">🌻 我是谁</div>
        <span class="main-title-en">ABOUT ME</span>
      </div>

      <div class="quote-section">
        <div class="quote-text">相信好的产品力 + 运营力 + 数据力，能够创造可持续的增长飞轮。</div>
      </div>

      <div class="resume-section">
        <div class="resume-label-en">// EDUCATION</div>
        <div class="edu-item">
          <span>🎓</span>
          <span>香港大学 市场营销硕士</span>
        </div>
      </div>

      <div class="resume-section">
        <div class="resume-label-en">// INTERNSHIP EXPERIENCE</div>
        <div class="exp-list">
          <div class="exp-item">
            <span class="exp-icon">🟊</span>
            <span>字节跳动 TikTok — 印尼电商策略实习生</span>
          </div>
          <div class="exp-item">
            <span class="exp-icon">📕</span>
            <span>小红书 — 商业产品实习生</span>
          </div>
          <div class="exp-item">
            <span class="exp-icon">🔴</span>
            <span>美团 / 哈啰 / 美敦力 / 默克 / 安永</span>
          </div>
        </div>
      </div>

      <div class="two-col">
        <div class="resume-section">
          <div class="resume-label-en">// SKILLS</div>
          <div class="skill-list">
            <div class="skill-item">
              <span class="skill-tag tech"><span class="en-text">AI Coding</span></span>
            </div>
            <div class="skill-item">
              <span class="skill-tag tech"><span class="en-text">Python</span></span>
            </div>
            <div class="skill-item">
              <span class="skill-tag tech"><span class="en-text">MySQL</span></span>
            </div>
          </div>
        </div>

        <div class="resume-section">
          <div class="resume-label-en">// CERTIFICATIONS</div>
          <div class="skill-list">
            <div class="skill-item">
              <span class="skill-tag cert"><span class="en-text">IELTS 7.5</span></span>
            </div>
            <div class="skill-item">
              <span class="skill-tag cert"><span class="en-text">ACCA</span></span>
            </div>
          </div>
        </div>
      </div>

      <div class="resume-section">
        <div class="resume-label-en">// HOBBIES</div>
        <div class="hobby-list">
          <span class="hobby-tag">🎵 R&B爱好者</span>
          <span class="hobby-tag">📚 史穿研究ing</span>
          <span class="hobby-tag">🎮 戴夫抓鱼者</span>
          <span class="hobby-tag">🌟 内娱一点通</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation Arrows -->
  <div class="nav-arrows">
    <button class="nav-arrow left" id="whoami-nav-prev" aria-label="上一页">◀</button>
    <button class="nav-arrow right" id="whoami-nav-next" aria-label="下一页">▶</button>
  </div>
</section>

<script>
  document.getElementById('whoami-nav-prev')?.addEventListener('click', () => {
    (window as any).playSound?.('transition');
    (window as any).navigateTo?.('page-welcome');
  });
  document.getElementById('whoami-nav-next')?.addEventListener('click', () => {
    (window as any).playSound?.('transition');
    (window as any).navigateTo?.('page-growth');
  });
</script>

<style>
  .whoami-page {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  .wood-frame {
    background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #6B3E26 100%);
    border-radius: 12px;
    padding: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    max-width: 800px;
    width: 90%;
  }

  .folder-tab {
    background: linear-gradient(180deg, #5D4037 0%, #4E342E 100%);
    color: #F5E6C8;
    padding: 10px 24px;
    display: inline-block;
    border-radius: 6px 6px 0 0;
    font-family: 'Press Start 2P', cursive;
    font-size: 0.5rem;
    letter-spacing: 1px;
    margin-bottom: -4px;
    box-shadow: inset 0 -2px 0 rgba(0,0,0,0.2);
  }

  .folder-inner {
    background: linear-gradient(180deg, #F5E6C8 0%, #E8DCC8 100%);
    border-radius: 4px;
    padding: 24px 28px;
    color: #5D3A1A;
    min-height: 500px;
    max-height: 85vh;
    overflow-y: auto;
  }

  .main-title {
    text-align: center;
    margin-bottom: 20px;
  }

  .main-title-zh {
    font-family: 'ZCOOL QingKe HuangYou', cursive;
    font-size: 1.8rem;
    color: #5D3A1A;
    margin-bottom: 4px;
  }

  .main-title-en {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.5rem;
    color: #8B4513;
    letter-spacing: 2px;
  }

  .quote-section {
    background: linear-gradient(135deg, #5D4037 0%, #4E342E 100%);
    border-radius: 6px;
    padding: 14px 18px;
    margin-bottom: 20px;
    position: relative;
  }

  .quote-text {
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1.15rem;
    color: #F5E6C8;
    text-align: center;
    line-height: 1.6;
  }

  .resume-section {
    margin-bottom: 18px;
  }

  .resume-label-en {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.45rem;
    color: #8B4513;
    letter-spacing: 1px;
    margin-bottom: 8px;
    padding-bottom: 4px;
    border-bottom: 2px solid #8B4513;
  }

  .exp-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .exp-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1.05rem;
    color: #5D3A1A;
    line-height: 1.4;
  }

  .exp-icon {
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  @media (max-width: 600px) {
    .two-col {
      grid-template-columns: 1fr;
    }
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .en-text {
    font-family: 'Press Start 2P', cursive;
    font-size: 0.45rem;
    letter-spacing: 0.5px;
  }

  .skill-tag {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 4px;
  }

  .skill-tag.tech {
    background: linear-gradient(135deg, #9575CD, #7E57C2);
    color: white;
  }

  .skill-tag.cert {
    background: linear-gradient(135deg, #FFD700, #FFC107);
    color: #5D3A1A;
  }

  .hobby-list {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .hobby-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(135deg, #F48FB1, #F06292);
    color: white;
    padding: 6px 14px;
    border-radius: 20px;
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1rem;
  }

  .edu-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Ma Shan Zheng', cursive;
    font-size: 1.05rem;
    color: #5D3A1A;
    background: rgba(139, 69, 19, 0.1);
    padding: 8px 12px;
    border-radius: 6px;
    border-left: 3px solid #8B4513;
  }

  /* Navigation Arrows */
  .nav-arrows {
    position: fixed;
    bottom: 80px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    padding: 0 20px;
    pointer-events: none;
    z-index: 100;
  }

  .nav-arrow {
    pointer-events: auto;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8B4513 0%, #6B3E26 100%);
    border: 3px solid var(--color-neon-green);
    color: var(--color-neon-green);
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
    transition: all 0.2s;
  }

  .nav-arrow:hover {
    transform: scale(1.1);
    border-color: var(--color-neon-yellow);
    color: var(--color-neon-yellow);
    box-shadow: 0 0 20px rgba(255, 255, 0, 0.3);
  }

  .nav-arrow:active {
    transform: scale(0.95);
  }
</style>