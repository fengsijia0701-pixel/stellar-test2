---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到">
  <div class="min-h-screen flex items-center justify-center bg-bgLight">
    <div class="text-center px-4">
      <h1 class="text-9xl font-heading font-bold text-primary">404</h1>
      <p class="text-2xl font-heading text-dark mt-4">哎呀，页面走丢了~</p>
      <p class="text-dark/60 mt-2">你想要的页面可能搬家了，或者根本不存在</p>
      <a href="/" class="inline-block mt-8 px-6 py-3 bg-primary text-white rounded-full font-medium hover:scale-105 transition-transform">
        返回首页
      </a>
    </div>
  </div>
</BaseLayout>