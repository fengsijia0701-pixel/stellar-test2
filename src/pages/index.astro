---
import BaseLayout from '../layouts/BaseLayout.astro';
import WelcomeSection from '../components/WelcomeSection.astro';
import WhoAmISection from '../components/WhoAmISection.astro';
import GrowthTrackSection from '../components/GrowthTrackSection.astro';
import RPGMapSection from '../components/RPGMapSection.astro';
import ProjectsSpace from '../components/ProjectsSpace.astro';
import ProjectsExperience from '../components/ProjectsExperience.astro';
import CompetitionsSection from '../components/CompetitionsSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ContactSection from '../components/ContactSection.astro';
import ExperienceDetail from '../components/ExperienceDetail.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>冯思佳 | 产品/运营/市场营销</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Page Container - Full Screen Pages -->
  <div id="app">
    <!-- Page 1: Welcome -->
    <section id="page-welcome" class="page active" data-lock-scroll="true">
      <WelcomeSection />
    </section>

    <!-- Page 2: Who Am I -->
    <section id="page-whoami" class="page" data-lock-scroll="true">
      <WhoAmISection />
    </section>

    <!-- Page 3: Growth Track -->
    <section id="page-growth" class="page" data-lock-scroll="true">
      <GrowthTrackSection />
    </section>

    <!-- Page 4: RPG Map -->
    <section id="page-map" class="page" data-lock-scroll="true">
      <RPGMapSection />
    </section>

    <!-- Branch Pages -->
    <section id="page-projects-space" class="page" data-lock-scroll="true">
      <ProjectsSpace />
    </section>

    <section id="page-projects-experience" class="page" data-lock-scroll="true">
      <ProjectsExperience />
    </section>

    <section id="page-competitions" class="page" data-lock-scroll="true">
      <CompetitionsSection />
    </section>

    <section id="page-skills" class="page" data-lock-scroll="true">
      <SkillsSection />
    </section>

    <section id="page-contact" class="page" data-lock-scroll="true">
      <ContactSection />
    </section>

    <!-- Experience Detail Page -->
    <section id="page-experience" class="page" data-lock-scroll="true">
      <ExperienceDetail />
    </section>
  </div>

  <style is:global>
    :root {
      /* 像素复古游戏风色彩 */
      --color-bg-dark: #0f1f0f;
      --color-bg-forest: #1a2f1a;
      --color-grass: #2d5a27;
      --color-dirt: #3d2817;

      /* 霓虹强调色 */
      --color-neon-green: #00ff88;
      --color-neon-yellow: #ffff00;
      --color-neon-cyan: #00ffff;
      --color-neon-magenta: #ff00ff;
      --color-neon-orange: #ff8e53;

      /* 星露谷经典色 */
      --color-wood: #8B5A2B;
      --color-wood-dark: #5D4037;
      --color-wood-light: #A67C52;
      --color-sky: #87CEEB;
      --color-grass-stardew: #7CB342;
      --color-gold: #FFD700;
      --color-parchment: #F5E6C8;
      --color-cream: #FFF8E7;
      --color-text: #E8DCC8;

      /* 字体 */
      --font-pixel: 'Press Start 2P', cursive;
      --font-game: 'Rajdhani', 'Noto Sans SC', sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      font-family: var(--font-game);
      overflow: hidden;
      height: 100%;
      width: 100%;
      background: var(--color-bg-dark);
      color: var(--color-text);
    }

    body {
      overflow: hidden;
    }

    /* Page Container */
    #app {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    /* Page Base */
    .page {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.4s ease, visibility 0.4s;
      overflow: hidden;
    }

    .page.active {
      opacity: 1;
      visibility: visible;
    }

    /* Fullscreen sections */
    .fullscreen-section {
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    /* Scroll locked state */
    body.scroll-locked {
      overflow: hidden;
      position: fixed;
      width: 100%;
      height: 100%;
    }

    /* Path Navigation - Fixed at bottom */
    #path-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 55px;
      z-index: 100;
      background: linear-gradient(180deg, #3d2817, #2a1a0f);
      border-top: 3px solid #8B4513;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      touch-action: none;
    }

    .path-container {
      position: relative;
      width: 320px;
      height: 50px;
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .nav-arrow-btn {
      width: 44px;
      height: 44px;
      border-radius: 8px;
      background: linear-gradient(135deg, #2d5a27, #1a3a1a);
      border: 3px solid #00ff88;
      color: #00ff88;
      font-size: 1.4rem;
      font-weight: bold;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
      box-shadow: 0 0 15px rgba(0,255,136,0.4), 0 4px 0 #1a2f1a;
      text-shadow: 0 0 10px #00ff88;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
    }

    .nav-arrow-btn:hover {
      transform: translateY(-2px);
      border-color: #ffff00;
      color: #ffff00;
      box-shadow: 0 0 20px rgba(255,255,0,0.5), 0 6px 0 #1a2f1a;
      text-shadow: 0 0 10px #ffff00;
    }

    .nav-arrow-btn:active {
      transform: translateY(2px);
      box-shadow: 0 0 10px rgba(0,255,136,0.3), 0 2px 0 #1a2f1a;
    }

    .nav-arrow-btn:disabled {
      opacity: 0.3;
      cursor: not-allowed;
      transform: none;
    }

    .path-trail {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-progress-track {
      width: 100%;
      height: 10px;
      background: #1a2f1a;
      border: 2px solid #2d5a27;
      border-radius: 5px;
      position: relative;
      overflow: hidden;
    }

    .nav-progress-fill {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #ffff00, #ffcc00);
      border-radius: 3px;
      transition: width 0.3s ease-out;
      box-shadow: 0 0 10px rgba(255,255,0,0.5);
    }

    .char-on-path {
      position: absolute;
      left: 8px;
      font-size: 1.5rem;
      cursor: grab;
      user-select: none;
      transition: left 0.3s ease-out;
      z-index: 10;
      filter: drop-shadow(0 0 8px rgba(255,255,0,0.8));
    }

    .char-on-path:active {
      cursor: grabbing;
    }

    .char-on-path.dragging {
      transition: none;
      filter: drop-shadow(0 0 15px rgba(255,255,0,1));
    }

    .nav-hint {
      font-family: var(--font-game);
      font-size: 0.7rem;
      color: #90EE90;
      letter-spacing: 1px;
    }
  </style>

  <script >
    // Sound Effects Class
    class SoundEffects {
      audioContext = null;

      init() {
        if (!this.audioContext) {
          this.audioContext = new (window.AudioContext || (window).webkitAudioContext)();
        }
      }

      playClick() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(800, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(400, this.audioContext.currentTime + 0.1);
        osc.type = 'square';
        gain.gain.setValueAtTime(0.1, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.1);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.1);
      }

      playPageTransition() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(400, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(800, this.audioContext.currentTime + 0.2);
        osc.type = 'square';
        gain.gain.setValueAtTime(0.1, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.2);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.2);
      }

      playSuccess() {
        this.init();
        const notes = [523, 659, 784];
        notes.forEach((freq, i) => {
          const osc = this.audioContext.createOscillator();
          const gain = this.audioContext.createGain();
          osc.connect(gain);
          gain.connect(this.audioContext.destination);
          osc.frequency.value = freq;
          osc.type = 'square';
          gain.gain.setValueAtTime(0.08, this.audioContext.currentTime + i * 0.1);
          gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + i * 0.1 + 0.15);
          osc.start(this.audioContext.currentTime + i * 0.1);
          osc.stop(this.audioContext.currentTime + i * 0.1 + 0.15);
        });
      }
    }

    const sound = new SoundEffects();
    (window).sound = sound;

    // Page Navigation
    class PageNavigator {
      private currentPage: string = 'page-welcome';
      private pageOrder: string[] = [
        'page-welcome',
        'page-whoami',
        'page-growth',
        'page-experience',
        'page-map',
        'page-projects-space',
        'page-projects-experience',
        'page-competitions',
        'page-skills',
        'page-contact'
      ];

      constructor() {
        this.init();
      }

      init() {
        // Lock scroll on first page
        this.lockScroll();

        // Listen for navigation events
        document.addEventListener('navigate', ((e: CustomEvent) => {
          const target = e.detail?.target;
          if (target) {
            this.goTo(target);
          }
        }) as EventListener);

        // Handle all button clicks with data-action
        document.addEventListener('click', (e) => {
          console.log('[CLICK] Event captured at document level');
          const target = e.target as HTMLElement;
          console.log('[CLICK] target:', target.tagName, 'class:', target.className);
          const button = target.closest('[data-action]') as HTMLElement;
          console.log('[CLICK] button found:', button?.className, 'action:', button?.dataset.action);
          if (button) {
            const action = button.dataset.action;
            console.log('[CLICK] action:', action);
            if (action === 'next') {
              console.log('[CLICK] Calling this.next()');
              this.next();
            } else if (action === 'prev') {
              this.prev();
            } else if (action === 'goto') {
              const targetPage = button.dataset.goto;
              const company = button.dataset.company;
              if (targetPage) {
                if (company && targetPage === 'page-experience') {
                  window.location.href = `?experience=${company}`;
                } else {
                  this.goTo(targetPage);
                }
              }
            }
          }
        });

        // Initialize sound on first click
        document.addEventListener('click', () => sound.init(), { once: true });
      }

      lockScroll() {
        document.body.classList.add('scroll-locked');
      }

      unlockScroll() {
        document.body.classList.remove('scroll-locked');
      }

      goTo(pageId: string) {
        const current = document.getElementById(this.currentPage);
        const target = document.getElementById(pageId);

        if (!target || current?.id === pageId) return;

        // Play transition sound
        sound.playPageTransition();

        // Animate out current
        if (current) {
          current.classList.add('page-exit');
          current.classList.remove('active');
          setTimeout(() => {
            current.classList.remove('page-exit');
            current.style.display = 'none';
          }, 300);
        }

        // Animate in target
        setTimeout(() => {
          target.style.display = 'block';
          target.classList.add('active', 'page-enter');

          setTimeout(() => {
            target.classList.remove('page-enter');
          }, 400);

          this.currentPage = pageId;

          // Lock scroll if page has lock flag
          const shouldLock = target.dataset.lockScroll === 'true';
          if (shouldLock) {
            this.lockScroll();
          } else {
            this.unlockScroll();
          }
        }, 300);
      }

      next() {
        const currentIndex = this.pageOrder.indexOf(this.currentPage);
        if (currentIndex < this.pageOrder.length - 1) {
          this.goTo(this.pageOrder[currentIndex + 1]);
        }
      }

      prev() {
        const currentIndex = this.pageOrder.indexOf(this.currentPage);
        if (currentIndex > 0) {
          this.goTo(this.pageOrder[currentIndex - 1]);
        }
      }
    }

    // Initialize
    const pageNavigator = new PageNavigator();
    (window as any).pageNavigator = pageNavigator;
    (window).navigateTo = (pageId: string) => pageNavigator.goTo(pageId);

    // Handle hash navigation
    if (window.location.hash) {
      const pageId = 'page-' + window.location.hash.substring(1);
      setTimeout(() => pageNavigator.goTo(pageId), 100);
    }

    // Update path nav on page change
    const originalGoTo = pageNavigator.goTo.bind(pageNavigator);
    pageNavigator.goTo = function(pageId: string) {
      originalGoTo(pageId);
      updatePathNav(pageId);
    };

    function updatePathNav(pageId: string) {
      const steps = document.querySelectorAll('.path-step');
      const currentIndex = pageNavigator.pageOrder.indexOf(pageId);
      steps.forEach((step, i) => {
        step.classList.remove('current');
        if (i < currentIndex) {
          step.classList.add('visited');
        } else {
          step.classList.remove('visited');
        }
        if (i === currentIndex) {
          step.classList.add('current');
        }
      });
      // Move char to current position
      const char = document.querySelector('.char-on-path') as HTMLElement;
      if (char) {
        const stepWidth = 22; // gap + width
        char.style.transform = `translateX(${currentIndex * stepWidth - 2}px)`;
      }
    }

    // Swipe navigation - Full-screen swipe gesture (not on drag character)
    let swipeStartX = 0;
    let swipeStartY = 0;

    document.addEventListener('touchstart', (e) => {
      // Only track if not touching the path-char element
      if (!e.target.closest('#path-char')) {
        swipeStartX = e.touches[0].clientX;
        swipeStartY = e.touches[0].clientY;
        console.log('[SWIPE START] x:', swipeStartX, 'y:', swipeStartY);
      }
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      // Skip if was touching the path-char element
      if (e.target.closest('#path-char')) return;
      const swipeEndX = e.changedTouches[0].clientX;
      const swipeEndY = e.changedTouches[0].clientY;
      const deltaX = swipeEndX - swipeStartX;
      const deltaY = Math.abs(swipeEndY - swipeStartY);
      console.log('[SWIPE END] deltaX:', deltaX, 'deltaY:', deltaY, 'threshold check:', Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY);

      if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY) {
        if (deltaX < 0) {
          console.log('[SWIPE] Going to next page via swipe');
          pageNavigator.next();
        } else {
          console.log('[SWIPE] Going to previous page via swipe');
          pageNavigator.prev();
        }
      }
    }, { passive: true });

    // Initialize path nav
    updatePathNav('page-welcome');

    // Arrow button navigation - direct page switching
    const prevBtn = document.getElementById('nav-prev-btn');
    const nextBtn = document.getElementById('nav-next-btn');
    const pages = ['page-welcome','page-whoami','page-growth','page-experience','page-map','page-projects-space','page-projects-experience','page-competitions','page-skills','page-contact'];

    function getCurrentPageId() {
      const active = document.querySelector('.page.active');
      return active?.id || 'page-welcome';
    }

    function updateNavButtons() {
      const currentId = getCurrentPageId();
      const currentIndex = pages.indexOf(currentId);
      if (prevBtn) prevBtn.disabled = currentIndex <= 0;
      if (nextBtn) nextBtn.disabled = currentIndex >= pages.length - 1;
      console.log('[NAV] updateNavButtons: currentId=', currentId, 'index=', currentIndex);
    }

    prevBtn?.addEventListener('click', () => {
      console.log('[ARROW] Prev button clicked!');
      const currentId = getCurrentPageId();
      const currentIndex = pages.indexOf(currentId);
      console.log('[NAV] Prev clicked: currentId=', currentId, 'index=', currentIndex);
      if (currentIndex > 0) {
        const prevPageId = pages[currentIndex - 1];
        console.log('[NAV] Going to:', prevPageId);
        pageNavigator.goTo(prevPageId);
        updateNavButtons();
      }
    });

    nextBtn?.addEventListener('click', () => {
      const currentId = getCurrentPageId();
      const currentIndex = pages.indexOf(currentId);
      console.log('[NAV] Next clicked: currentId=', currentId, 'index=', currentIndex);
      if (currentIndex < pages.length - 1) {
        const nextPageId = pages[currentIndex + 1];
        console.log('[NAV] Going to:', nextPageId);
        pageNavigator.goTo(nextPageId);
        updateNavButtons();
      }
    });

    // Initial button state
    updateNavButtons();
  </script>

  <style is:global>
    .page-enter {
      animation: pixelEnter 0.4s ease-out forwards;
    }

    .page-exit {
      animation: pixelExit 0.3s ease-in forwards;
    }

    @keyframes pixelEnter {
      0% {
        opacity: 0;
        transform: translateX(40px);
        filter: blur(4px);
      }
      100% {
        opacity: 1;
        transform: translateX(0);
        filter: blur(0);
      }
    }

    @keyframes pixelExit {
      0% {
        opacity: 1;
        transform: translateX(0);
        filter: blur(0);
      }
      100% {
        opacity: 0;
        transform: translateX(-40px);
        filter: blur(4px);
      }
    }

    /* Scanlines overlay */
    body::after {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: repeating-linear-gradient(
        0deg,
        rgba(0, 0, 0, 0.08) 0px,
        rgba(0, 0, 0, 0.08) 1px,
        transparent 1px,
        transparent 2px
      );
      pointer-events: none;
      z-index: 9998;
    }

    /* Pixel glow effects */
    .pixel-glow-green {
      color: #00ff88;
      text-shadow: 0 0 5px #00ff88, 0 0 10px #00ff88, 2px 2px 0 #000;
    }

    .pixel-glow-yellow {
      color: #ffff00;
      text-shadow: 0 0 5px #ffff00, 0 0 10px #ffff00, 2px 2px 0 #5d4a00;
    }

    .pixel-glow-cyan {
      color: #00ffff;
      text-shadow: 0 0 5px #00ffff, 0 0 10px #00ffff, 2px 2px 0 #005555;
    }
  </style>

  <!-- Path Navigation - Fixed at bottom -->
  <div id="path-nav">
    <div class="path-container">
      <button class="nav-arrow-btn left" id="nav-prev-btn" aria-label="上一页">◀</button>
      <div class="path-trail">
        <div class="nav-progress-track">
          <div class="nav-progress-fill" id="nav-progress-fill"></div>
        </div>
      </div>
      <button class="nav-arrow-btn right" id="nav-next-btn" aria-label="下一页">▶</button>
    </div>
    <div class="nav-hint">点击箭头切换</div>
  </div>

  <script>
    // Simple arrow button navigation
    const prevBtn = document.getElementById("nav-prev-btn");
    const nextBtn = document.getElementById("nav-next-btn");
    const pages = ["page-welcome","page-whoami","page-growth","page-experience","page-map","page-projects-space","page-projects-experience","page-competitions","page-skills","page-contact"];

    function getCurrentPageId() {
      const active = document.querySelector(".page.active");
      return active?.id || "page-welcome";
    }

    prevBtn?.addEventListener("click", () => {
      const currentId = getCurrentPageId();
      const currentIndex = pages.indexOf(currentId);
      if (currentIndex > 0) {
        pageNavigator.goTo(pages[currentIndex - 1]);
      }
    });

    nextBtn?.addEventListener("click", () => {
      const currentId = getCurrentPageId();
      const currentIndex = pages.indexOf(currentId);
      if (currentIndex < pages.length - 1) {
        pageNavigator.goTo(pages[currentIndex + 1]);
      }
    });
  </script>
</body>
</html>
