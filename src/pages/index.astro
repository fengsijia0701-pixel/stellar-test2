---
import BaseLayout from '../layouts/BaseLayout.astro';
import WelcomeSection from '../components/WelcomeSection.astro';
import WhoAmISection from '../components/WhoAmISection.astro';
import GrowthTrackSection from '../components/GrowthTrackSection.astro';
import RPGMapSection from '../components/RPGMapSection.astro';
import ProjectsSpace from '../components/ProjectsSpace.astro';
import ProjectsExperience from '../components/ProjectsExperience.astro';
import CompetitionsSection from '../components/CompetitionsSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ContactSection from '../components/ContactSection.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>冯思佳 | 产品/运营/市场营销</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=ZCOOL+QingKe+HuangYou&family=Ma+Shan+Zheng&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Page Container - Full Screen Pages -->
  <div id="app">
    <!-- Page 1: Welcome -->
    <section id="page-welcome" class="page active" data-lock-scroll="true">
      <WelcomeSection />
    </section>

    <!-- Page 2: Who Am I -->
    <section id="page-whoami" class="page" data-lock-scroll="true">
      <WhoAmISection />
    </section>

    <!-- Page 3: Growth Track -->
    <section id="page-growth" class="page" data-lock-scroll="true">
      <GrowthTrackSection />
    </section>

    <!-- Page 4: RPG Map -->
    <section id="page-map" class="page" data-lock-scroll="true">
      <RPGMapSection />
    </section>

    <!-- Branch Pages -->
    <section id="page-projects-space" class="page" data-lock-scroll="true">
      <ProjectsSpace />
    </section>

    <section id="page-projects-experience" class="page" data-lock-scroll="true">
      <ProjectsExperience />
    </section>

    <section id="page-competitions" class="page" data-lock-scroll="true">
      <CompetitionsSection />
    </section>

    <section id="page-skills" class="page" data-lock-scroll="true">
      <SkillsSection />
    </section>

    <section id="page-contact" class="page" data-lock-scroll="true">
      <ContactSection />
    </section>
  </div>

  <style is:global>
    :root {
      /* 像素复古游戏风色彩 */
      --color-bg-dark: #0f1f0f;
      --color-bg-forest: #1a2f1a;
      --color-grass: #2d5a27;
      --color-dirt: #3d2817;

      /* 霓虹强调色 */
      --color-neon-green: #00ff88;
      --color-neon-yellow: #ffff00;
      --color-neon-cyan: #00ffff;
      --color-neon-magenta: #ff00ff;
      --color-neon-orange: #ff8e53;

      /* 星露谷经典色 */
      --color-wood: #8B5A2B;
      --color-wood-dark: #5D4037;
      --color-wood-light: #A67C52;
      --color-sky: #87CEEB;
      --color-grass-stardew: #7CB342;
      --color-gold: #FFD700;
      --color-parchment: #F5E6C8;
      --color-cream: #FFF8E7;
      --color-text: #E8DCC8;

      /* 字体 - 方案A: ZCOOL QingKe HuangYou(标题) + Ma Shan Zheng(正文) */
      --font-pixel: 'Press Start 2P', cursive;
      --font-title: 'ZCOOL QingKe HuangYou', cursive;
      --font-body: 'Ma Shan Zheng', cursive;
      --font-game: 'ZCOOL QingKe HuangYou', cursive;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      font-family: var(--font-body);
      overflow: hidden;
      height: 100%;
      width: 100%;
      background: var(--color-bg-dark);
      color: var(--color-text);
    }

    body {
      overflow: hidden;
    }

    /* Page Container */
    #app {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    /* Page Base */
    .page {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.4s ease, visibility 0.4s;
      overflow: hidden;
    }

    .page.active {
      opacity: 1;
      visibility: visible;
    }

    /* Fullscreen sections */
    .fullscreen-section {
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    /* Scroll locked state */
    body.scroll-locked {
      overflow: hidden;
      position: fixed;
      width: 100%;
      height: 100%;
    }

    /* Path Navigation - Fixed at bottom */
    #path-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 55px;
      z-index: 100;
      background: linear-gradient(180deg, #3d2817, #2a1a0f);
      border-top: 3px solid #8B4513;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      touch-action: none;
    }

    .path-container {
      position: relative;
      width: 320px;
      height: 50px;
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .nav-arrow-btn {
      width: 44px;
      height: 44px;
      border-radius: 8px;
      background: linear-gradient(135deg, #2d5a27, #1a3a1a);
      border: 3px solid #00ff88;
      color: #00ff88;
      font-size: 1.4rem;
      font-weight: bold;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s ease;
      box-shadow: 0 0 15px rgba(0,255,136,0.4), 0 4px 0 #1a2f1a;
      text-shadow: 0 0 10px #00ff88;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
    }

    .nav-arrow-btn:hover {
      transform: translateY(-2px);
      border-color: #ffff00;
      color: #ffff00;
      box-shadow: 0 0 20px rgba(255,255,0,0.5), 0 6px 0 #1a2f1a;
      text-shadow: 0 0 10px #ffff00;
    }

    .nav-arrow-btn:active {
      transform: translateY(2px);
      box-shadow: 0 0 10px rgba(0,255,136,0.3), 0 2px 0 #1a2f1a;
    }

    .nav-arrow-btn:disabled {
      opacity: 0.3;
      cursor: not-allowed;
      transform: none;
    }

    .path-trail {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-progress-track {
      width: 100%;
      height: 10px;
      background: #1a2f1a;
      border: 2px solid #2d5a27;
      border-radius: 5px;
      position: relative;
      overflow: hidden;
    }

    .nav-progress-fill {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #ffff00, #ffcc00);
      border-radius: 3px;
      transition: width 0.3s ease-out;
      box-shadow: 0 0 10px rgba(255,255,0,0.5);
    }

    .char-on-path {
      position: absolute;
      left: 8px;
      font-size: 1.5rem;
      cursor: grab;
      user-select: none;
      transition: left 0.3s ease-out;
      z-index: 10;
      filter: drop-shadow(0 0 8px rgba(255,255,0,0.8));
    }

    .char-on-path:active {
      cursor: grabbing;
    }

    .char-on-path.dragging {
      transition: none;
      filter: drop-shadow(0 0 15px rgba(255,255,0,1));
    }

    .nav-hint {
      font-family: var(--font-game);
      font-size: 0.7rem;
      color: #90EE90;
      letter-spacing: 1px;
    }

    .music-toggle-btn {
      position: absolute;
      top: 8px;
      right: 12px;
      background: rgba(45, 90, 39, 0.8);
      border: 2px solid #00ff88;
      border-radius: 50%;
      width: 36px;
      height: 36px;
      font-size: 1.2rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      z-index: 10;
    }

    .music-toggle-btn:hover {
      transform: scale(1.1);
      border-color: #ffff00;
      box-shadow: 0 0 10px rgba(0, 255, 136, 0.5);
    }

    .music-toggle-btn.playing {
      animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 5px rgba(0, 255, 136, 0.5); }
      50% { box-shadow: 0 0 15px rgba(0, 255, 136, 0.8); }
    }
  </style>

  <script >
    // Sound Effects Class - Stardew Valley Style
    class SoundEffects {
      audioContext = null;
      bgMusicPlaying = false;
      bgOscillators = [];

      init() {
        if (!this.audioContext) {
          this.audioContext = new (window.AudioContext || (window as any).webkitAudioContext)();
        }
      }

      // 点击 - 游戏化"咔"音效 (短促清脆)
      playClick() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(880, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(440, this.audioContext.currentTime + 0.05);
        osc.type = 'square';
        gain.gain.setValueAtTime(0.15, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.05);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.05);
      }

      // 页面切换 - 清晰"噗"音
      playPageTransition() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(300, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(600, this.audioContext.currentTime + 0.15);
        osc.type = 'triangle';
        gain.gain.setValueAtTime(0.12, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.2);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.2);
      }

      // 弹窗打开 - 温暖"叮铃"
      playPopup() {
        this.init();
        const notes = [523, 659, 784];
        notes.forEach((freq, i) => {
          const osc = this.audioContext.createOscillator();
          const gain = this.audioContext.createGain();
          osc.connect(gain);
          gain.connect(this.audioContext.destination);
          osc.frequency.value = freq;
          osc.type = 'sine';
          gain.gain.setValueAtTime(0, this.audioContext.currentTime + i * 0.08);
          gain.gain.linearRampToValueAtTime(0.1, this.audioContext.currentTime + i * 0.08 + 0.02);
          gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + i * 0.08 + 0.4);
          osc.start(this.audioContext.currentTime + i * 0.08);
          osc.stop(this.audioContext.currentTime + i * 0.08 + 0.4);
        });
      }

      // 展开项目 - 纸张"沙沙"
      playExpand() {
        this.init();
        const noise = this.createNoise(0.15);
        const filter = this.audioContext.createBiquadFilter();
        filter.type = 'highpass';
        filter.frequency.value = 2000;
        const gain = this.audioContext.createGain();
        noise.connect(filter);
        filter.connect(gain);
        gain.connect(this.audioContext.destination);
        gain.gain.setValueAtTime(0.06, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.15);
        noise.start();
        noise.stop(this.audioContext.currentTime + 0.15);
      }

      // 成功反馈 - 愉悦"叮~"
      playSuccess() {
        this.init();
        const notes = [523, 659, 784, 1047];
        notes.forEach((freq, i) => {
          const osc = this.audioContext.createOscillator();
          const gain = this.audioContext.createGain();
          osc.connect(gain);
          gain.connect(this.audioContext.destination);
          osc.frequency.value = freq;
          osc.type = 'sine';
          gain.gain.setValueAtTime(0.1, this.audioContext.currentTime + i * 0.1);
          gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + i * 0.1 + 0.3);
          osc.start(this.audioContext.currentTime + i * 0.1);
          osc.stop(this.audioContext.currentTime + i * 0.1 + 0.3);
        });
      }

      // 返回地图 - 柔和"嗖"音
      playReturn() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(500, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(250, this.audioContext.currentTime + 0.2);
        osc.type = 'sine';
        gain.gain.setValueAtTime(0.12, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.2);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.2);
      }

      // 创建白噪音
      createNoise(duration: number) {
        const bufferSize = this.audioContext.sampleRate * duration;
        const buffer = this.audioContext.createBuffer(1, bufferSize, this.audioContext.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }
        const source = this.audioContext.createBufferSource();
        source.buffer = buffer;
        return source;
      }

      // 治愈钢琴曲风格背景音乐
      playBgMusic() {
        if (this.bgMusicPlaying) return;
        this.init();
        this.bgMusicPlaying = true;

        const ctx = this.audioContext;
        this.bgOscillators = [];

        // 钢琴音色合成 - 使用谐波叠加模拟钢琴
        const playPianoNote = (freq: number, startTime: number, duration: number, volume: number) => {
          // 基频 + 谐波 (模拟钢琴音色)
          const harmonics = [1, 2, 3, 4, 6];
          const gains = [1, 0.5, 0.25, 0.125, 0.08];

          harmonics.forEach((harmonic, i) => {
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();

            osc.type = 'sine';
            osc.frequency.value = freq * harmonic;

            // ADSR  envelope (Attack, Decay, Sustain, Release)
            const attack = 0.02;
            const decay = 0.1;
            const sustain = volume * gains[i] * 0.6;
            const release = 0.3;
            const sustainTime = duration - attack - decay - release;

            gain.gain.setValueAtTime(0, startTime);
            gain.gain.linearRampToValueAtTime(volume * gains[i], startTime + attack);
            gain.gain.linearRampToValueAtTime(sustain, startTime + attack + decay);
            gain.gain.setValueAtTime(sustain, startTime + attack + decay + Math.max(0, sustainTime));
            gain.gain.linearRampToValueAtTime(0, startTime + duration);

            osc.connect(gain);
            gain.connect(ctx.destination);

            osc.start(startTime);
            osc.stop(startTime + duration);

            this.bgOscillators.push({ osc, gain, lfo: null });
          });
        };

        // 治愈系钢琴旋律 - 简单循环的温柔曲子
        // C major: C D E F G A B C  (简化的星空BGM风格旋律片段)
        const melody = [
          { note: 261.63, beat: 1 },  // C4
          { note: 329.63, beat: 0.5 }, // E4
          { note: 392.00, beat: 0.5 }, // G4
          { note: 329.63, beat: 1 },  // E4
          { note: 293.66, beat: 1 },  // D4
          { note: 246.94, beat: 0.5 }, // B3
          { note: 261.63, beat: 0.5 }, // C4
          { note: 220.00, beat: 1 },  // A3
          { note: 261.63, beat: 1 },  // C4
          { note: 196.00, beat: 0.5 }, // G3
          { note: 220.00, beat: 0.5 }, // A3
          { note: 246.94, beat: 1 },  // B3
          { note: 293.66, beat: 1 },  // D4
          { note: 261.63, beat: 1.5 }, // C4
          { note: 246.94, beat: 0.5 }, // B3
          { note: 261.63, beat: 2 },  // C4
        ];

        // 和弦进程 (每4小节循环)
        const chords = [
          [130.81, 164.81, 196.00], // C major (左手的低音和弦)
          [146.83, 174.61, 220.00], // D minor
          [130.81, 164.81, 196.00], // C major
          [98.00, 123.47, 146.83],  // G major
        ];

        const BPM = 60;
        const beatDuration = 60 / BPM;
        let melodyIndex = 0;
        let chordIndex = 0;
        let elapsed = 0;

        // 播放左手的低音和弦 (每2拍一次)
        const playBassNote = () => {
          if (!this.bgMusicPlaying) return;

          const chord = chords[chordIndex % chords.length];
          const startTime = ctx.currentTime + elapsed;

          // 左手低音 - 更低的八度
          chord.forEach((freq, i) => {
            playPianoNote(freq * 0.5, startTime, beatDuration * 3, 0.04);
          });

          chordIndex++;
          elapsed += beatDuration * 4;

          setTimeout(playBassNote, beatDuration * 4 * 1000);
        };

        // 播放右手旋律
        const playMelodyNote = () => {
          if (!this.bgMusicPlaying) return;

          const noteData = melody[melodyIndex % melody.length];
          const startTime = ctx.currentTime + elapsed;

          playPianoNote(noteData.note, startTime, beatDuration * noteData.beat * 0.9, 0.08);

          elapsed += beatDuration * noteData.beat;
          melodyIndex++;

          if (elapsed < beatDuration * 64) { // 播放64拍后重复
            setTimeout(playMelodyNote, beatDuration * noteData.beat * 1000);
          } else {
            // 重置并循环
            elapsed = 0;
            melodyIndex = 0;
            chordIndex = 0;
            setTimeout(playBassNote, 100);
            setTimeout(playMelodyNote, 100);
          }
        };

        // 持续的低音垫音
        const padFreqs = [32.70, 65.41]; // C1, C2 - 超低音垫底
        padFreqs.forEach((freq) => {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = 'sine';
          osc.frequency.value = freq;
          osc.connect(gain);
          gain.connect(ctx.destination);

          gain.gain.value = 0;
          gain.gain.linearRampToValueAtTime(0.015, ctx.currentTime + 3);

          this.bgOscillators.push({ osc, gain, lfo: null });
          osc.start();
        });

        // 开始播放
        setTimeout(playBassNote, 500);
        setTimeout(playMelodyNote, 500);
      }

      stopBgMusic() {
        this.bgMusicPlaying = false;
        if (this.bgOscillators && this.bgOscillators.length > 0) {
          this.bgOscillators.forEach(({ osc, gain }) => {
            try {
              gain.gain.linearRampToValueAtTime(0, this.audioContext.currentTime + 0.8);
              setTimeout(() => {
                try { osc.stop(); } catch(e) {}
              }, 900);
            } catch(e) {}
          });
          this.bgOscillators = [];
        }
      }
    }

    const sound = new SoundEffects();
    (window as any).sound = sound;
    (window as any).playSound = (type: string) => {
      if ((window as any).sound) {
        switch(type) {
          case 'click': (window as any).sound.playClick(); break;
          case 'transition': (window as any).sound.playPageTransition(); break;
          case 'popup': (window as any).sound.playPopup(); break;
          case 'expand': (window as any).sound.playExpand(); break;
          case 'success': (window as any).sound.playSuccess(); break;
          case 'return': (window as any).sound.playReturn(); break;
        }
      }
    };
    (window as any).playBgMusic = () => { if ((window as any).sound) (window as any).sound.playBgMusic(); };
    (window as any).stopBgMusic = () => { if ((window as any).sound) (window as any).stopBgMusic(); };

    // Page Navigation
    class PageNavigator {
      private currentPage: string = 'page-welcome';
      private pageOrder: string[] = [
        'page-welcome',
        'page-whoami',
        'page-growth',
        'page-map',
        'page-projects-space',
        'page-projects-experience',
        'page-competitions',
        'page-skills',
        'page-contact'
      ];

      constructor() {
        this.init();
      }

      init() {
        // Lock scroll on first page
        this.lockScroll();

        // Listen for navigation events
        document.addEventListener('navigate', ((e: CustomEvent) => {
          const target = e.detail?.target;
          if (target) {
            this.goTo(target);
          }
        }) as EventListener);

        // Handle all button clicks with data-action
        document.addEventListener('click', (e) => {
          console.log('[CLICK] Event captured at document level');
          const target = e.target as HTMLElement;
          console.log('[CLICK] target:', target.tagName, 'class:', target.className);
          const button = target.closest('[data-action]') as HTMLElement;
          console.log('[CLICK] button found:', button?.className, 'action:', button?.dataset.action);
          if (button) {
            const action = button.dataset.action;
            console.log('[CLICK] action:', action);
            if (action === 'next') {
              console.log('[CLICK] Calling this.next()');
              this.next();
            } else if (action === 'prev') {
              this.prev();
            } else if (action === 'goto') {
              const targetPage = button.dataset.goto;
              const company = button.dataset.company;
              if (targetPage) {
                if (company && targetPage === 'page-experience') {
                  window.location.href = `?experience=${company}`;
                } else {
                  this.goTo(targetPage);
                }
              }
            }
          }
        });

        // Initialize sound on first click
        document.addEventListener('click', () => sound.init(), { once: true });
      }

      lockScroll() {
        document.body.classList.add('scroll-locked');
      }

      unlockScroll() {
        document.body.classList.remove('scroll-locked');
      }

      goTo(pageId: string) {
        const current = document.getElementById(this.currentPage);
        const target = document.getElementById(pageId);

        if (!target || current?.id === pageId) return;

        // Play transition sound
        sound.playPageTransition();

        // Animate out current
        if (current) {
          current.classList.add('page-exit');
          current.classList.remove('active');
          setTimeout(() => {
            current.classList.remove('page-exit');
            current.style.display = 'none';
          }, 300);
        }

        // Animate in target
        setTimeout(() => {
          target.style.display = 'block';
          target.classList.add('active', 'page-enter');

          setTimeout(() => {
            target.classList.remove('page-enter');
          }, 400);

          // Only update currentPage AFTER animation completes
          this.currentPage = pageId;

          // Lock scroll if page has lock flag
          const shouldLock = target.dataset.lockScroll === 'true';
          if (shouldLock) {
            this.lockScroll();
          } else {
            this.unlockScroll();
          }
        }, 300);
      }

      next() {
        const currentIndex = this.pageOrder.indexOf(this.currentPage);
        if (currentIndex < this.pageOrder.length - 1) {
          this.goTo(this.pageOrder[currentIndex + 1]);
        }
      }

      prev() {
        const currentIndex = this.pageOrder.indexOf(this.currentPage);
        if (currentIndex > 0) {
          this.goTo(this.pageOrder[currentIndex - 1]);
        }
      }
    }

    // Initialize
        const pageNavigator = new PageNavigator();
    (window as any).pageNavigator = pageNavigator;
    (window as any).navigateTo = (pageId: string) => pageNavigator.goTo(pageId);

    // Handle hash navigation
    if (window.location.hash) {
      const pageId = 'page-' + window.location.hash.substring(1);
      setTimeout(() => pageNavigator.goTo(pageId), 100);
    }

    // Update path nav on page change - also update arrow buttons
    const originalGoTo = pageNavigator.goTo.bind(pageNavigator);
    pageNavigator.goTo = function(pageId: string) {
      originalGoTo(pageId);
      updatePathNav(pageId);
      // Update arrow buttons after page transition completes (400ms animation)
      setTimeout(updateNavButtonsFromPageId, 420);
    };

    function updateNavButtonsFromPageId() {
      const pages = ['page-welcome','page-whoami','page-growth','page-map','page-projects-space','page-projects-experience','page-competitions','page-skills','page-contact'];
      const branchPages = ['page-projects-space','page-projects-experience','page-competitions','page-skills','page-contact'];
      const prevBtn = document.getElementById('nav-prev-btn');
      const nextBtn = document.getElementById('nav-next-btn');
      const currentId = getCurrentPageId();
      const isBranchPage = branchPages.includes(currentId);
      const isMapPage = currentId === 'page-map';

      if (prevBtn) {
        if (isBranchPage) {
          prevBtn.style.display = 'none';
        } else {
          prevBtn.style.display = 'flex';
          prevBtn.disabled = false;
        }
      }
      if (nextBtn) {
        if (isBranchPage || isMapPage) {
          nextBtn.style.display = 'none';
        } else {
          nextBtn.style.display = 'flex';
          nextBtn.disabled = false;
        }
      }
      console.log('[NAV] currentId=', currentId, 'isBranchPage=', isBranchPage, 'isMapPage=', isMapPage);
    }

    function updatePathNav(pageId: string) {
      const steps = document.querySelectorAll('.path-step');
      const currentIndex = pageNavigator.pageOrder.indexOf(pageId);
      steps.forEach((step, i) => {
        step.classList.remove('current');
        if (i < currentIndex) {
          step.classList.add('visited');
        } else {
          step.classList.remove('visited');
        }
        if (i === currentIndex) {
          step.classList.add('current');
        }
      });
      // Move char to current position
      const char = document.querySelector('.char-on-path') as HTMLElement;
      if (char) {
        const stepWidth = 22; // gap + width
        char.style.transform = `translateX(${currentIndex * stepWidth - 2}px)`;
      }
    }

    // Swipe navigation - Full-screen swipe gesture (not on drag character)
    let swipeStartX = 0;
    let swipeStartY = 0;

    document.addEventListener('touchstart', (e) => {
      // Only track if not touching the path-char element
      if (!e.target.closest('#path-char')) {
        swipeStartX = e.touches[0].clientX;
        swipeStartY = e.touches[0].clientY;
        console.log('[SWIPE START] x:', swipeStartX, 'y:', swipeStartY);
      }
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      // Skip if was touching the path-char element
      if (e.target.closest('#path-char')) return;
      const swipeEndX = e.changedTouches[0].clientX;
      const swipeEndY = e.changedTouches[0].clientY;
      const deltaX = swipeEndX - swipeStartX;
      const deltaY = Math.abs(swipeEndY - swipeStartY);
      console.log('[SWIPE END] deltaX:', deltaX, 'deltaY:', deltaY, 'threshold check:', Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY);

      if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY) {
        if (deltaX < 0) {
          console.log('[SWIPE] Going to next page via swipe');
          pageNavigator.next();
        } else {
          console.log('[SWIPE] Going to previous page via swipe');
          pageNavigator.prev();
        }
      }
    }, { passive: true });

    // Initialize path nav
    updatePathNav('page-welcome');

    // Arrow button navigation - direct page switching
    const prevBtn = document.getElementById('nav-prev-btn');
    const nextBtn = document.getElementById('nav-next-btn');
    const pages = ['page-welcome','page-whoami','page-growth','page-map','page-projects-space','page-projects-experience','page-competitions','page-skills','page-contact'];

    function getCurrentPageId() {
      const active = document.querySelector('.page.active');
      return active?.id || 'page-welcome';
    }

    function updateNavButtons() {
      const currentId = getCurrentPageId();
      const currentIndex = pages.indexOf(currentId);
      if (prevBtn) prevBtn.disabled = currentIndex <= 0;
      if (nextBtn) nextBtn.disabled = currentIndex >= pages.length - 1;
      console.log('[NAV] updateNavButtons: currentId=', currentId, 'index=', currentIndex);
    }

    prevBtn?.addEventListener('click', () => {
      console.log('[ARROW] Prev button clicked!');
      const currentId = getCurrentPageId();
      const currentIndex = pages.indexOf(currentId);
      console.log('[NAV] Prev clicked: currentId=', currentId, 'index=', currentIndex);
      if (currentIndex > 0) {
        const prevPageId = pages[currentIndex - 1];
        console.log('[NAV] Going to:', prevPageId);
        pageNavigator.goTo(prevPageId);
        updateNavButtons();
      }
    });

    nextBtn?.addEventListener('click', () => {
      const currentId = getCurrentPageId();
      const currentIndex = pages.indexOf(currentId);
      console.log('[NAV] Next clicked: currentId=', currentId, 'index=', currentIndex);
      if (currentIndex < pages.length - 1) {
        const nextPageId = pages[currentIndex + 1];
        console.log('[NAV] Going to:', nextPageId);
        pageNavigator.goTo(nextPageId);
        updateNavButtons();
      }
    });

    // Initial button state
    updateNavButtons();

    // Background music toggle & auto-play on first click
    let bgMusicPlaying = false;
    let bgMusicInitialized = false;
    const bgMusicBtn = document.getElementById('bg-music-btn');

    // Auto-play music on first user interaction (browser policy)
    document.addEventListener('click', () => {
      if (!bgMusicInitialized) {
        bgMusicInitialized = true;
        (window as any).playBgMusic?.();
        bgMusicPlaying = true;
        bgMusicBtn?.classList.add('playing');
      }
    }, { once: true });

    bgMusicBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      const sound = (window as any).sound;
      if (!sound) return;

      if (!bgMusicPlaying) {
        sound.playBgMusic();
        bgMusicPlaying = true;
        bgMusicBtn.classList.add('playing');
      } else {
        sound.stopBgMusic();
        bgMusicPlaying = false;
        bgMusicBtn.classList.remove('playing');
      }
    });

  </script>

