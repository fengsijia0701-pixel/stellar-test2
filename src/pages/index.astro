---
import BaseLayout from '../layouts/BaseLayout.astro';
import WelcomeSection from '../components/WelcomeSection.astro';
import WhoAmISection from '../components/WhoAmISection.astro';
import GrowthTrackSection from '../components/GrowthTrackSection.astro';
import RPGMapSection from '../components/RPGMapSection.astro';
import ProjectsSpace from '../components/ProjectsSpace.astro';
import ProjectsExperience from '../components/ProjectsExperience.astro';
import CompetitionsSection from '../components/CompetitionsSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ContactSection from '../components/ContactSection.astro';
import ExperienceDetail from '../components/ExperienceDetail.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>冯思佳 | 产品/运营/市场营销</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Rajdhani:wght@500;700&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Page Container - Full Screen Pages -->
  <div id="app">
    <!-- Page 1: Welcome -->
    <section id="page-welcome" class="page active" data-lock-scroll="true">
      <WelcomeSection />
    </section>

    <!-- Page 2: Who Am I -->
    <section id="page-whoami" class="page" data-lock-scroll="true">
      <WhoAmISection />
    </section>

    <!-- Page 3: Growth Track -->
    <section id="page-growth" class="page" data-lock-scroll="true">
      <GrowthTrackSection />
    </section>

    <!-- Page 4: RPG Map -->
    <section id="page-map" class="page" data-lock-scroll="true">
      <RPGMapSection />
    </section>

    <!-- Branch Pages -->
    <section id="page-projects-space" class="page" data-lock-scroll="true">
      <ProjectsSpace />
    </section>

    <section id="page-projects-experience" class="page" data-lock-scroll="true">
      <ProjectsExperience />
    </section>

    <section id="page-competitions" class="page" data-lock-scroll="true">
      <CompetitionsSection />
    </section>

    <section id="page-skills" class="page" data-lock-scroll="true">
      <SkillsSection />
    </section>

    <section id="page-contact" class="page" data-lock-scroll="true">
      <ContactSection />
    </section>

    <!-- Experience Detail Page -->
    <section id="page-experience" class="page" data-lock-scroll="true">
      <ExperienceDetail />
    </section>
  </div>

  <style is:global>
    :root {
      /* 像素复古游戏风色彩 */
      --color-bg-dark: #0f1f0f;
      --color-bg-forest: #1a2f1a;
      --color-grass: #2d5a27;
      --color-dirt: #3d2817;

      /* 霓虹强调色 */
      --color-neon-green: #00ff88;
      --color-neon-yellow: #ffff00;
      --color-neon-cyan: #00ffff;
      --color-neon-magenta: #ff00ff;
      --color-neon-orange: #ff8e53;

      /* 星露谷经典色 */
      --color-wood: #8B5A2B;
      --color-wood-dark: #5D4037;
      --color-wood-light: #A67C52;
      --color-sky: #87CEEB;
      --color-grass-stardew: #7CB342;
      --color-gold: #FFD700;
      --color-parchment: #F5E6C8;
      --color-cream: #FFF8E7;
      --color-text: #E8DCC8;

      /* 字体 */
      --font-pixel: 'Press Start 2P', cursive;
      --font-game: 'Rajdhani', 'Noto Sans SC', sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      font-family: var(--font-game);
      overflow: hidden;
      height: 100%;
      width: 100%;
      background: var(--color-bg-dark);
      color: var(--color-text);
    }

    body {
      overflow: hidden;
    }

    /* Page Container */
    #app {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    /* Page Base */
    .page {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.4s ease, visibility 0.4s;
      overflow: hidden;
    }

    .page.active {
      opacity: 1;
      visibility: visible;
    }

    /* Fullscreen sections */
    .fullscreen-section {
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    /* Scroll locked state */
    body.scroll-locked {
      overflow: hidden;
      position: fixed;
      width: 100%;
      height: 100%;
    }

    /* Path Navigation - Fixed at bottom */
    #path-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 55px;
      z-index: 100;
      background: linear-gradient(180deg, #3d2817, #2a1a0f);
      border-top: 3px solid #8B4513;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      touch-action: none;
    }

    .path-container {
      position: relative;
      width: 260px;
      height: 40px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .arrow-hint {
      font-size: 1rem;
      color: #ffff00;
      text-shadow: 0 0 5px #ffff00;
    }

    .path-trail {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-progress-track {
      width: 100%;
      height: 10px;
      background: #1a2f1a;
      border: 2px solid #2d5a27;
      border-radius: 5px;
      position: relative;
      overflow: hidden;
    }

    .nav-progress-fill {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #ffff00, #ffcc00);
      border-radius: 3px;
      transition: width 0.3s ease-out;
      box-shadow: 0 0 10px rgba(255,255,0,0.5);
    }

    .char-on-path {
      position: absolute;
      left: 8px;
      font-size: 1.5rem;
      cursor: grab;
      user-select: none;
      transition: left 0.3s ease-out;
      z-index: 10;
      filter: drop-shadow(0 0 8px rgba(255,255,0,0.8));
    }

    .char-on-path:active {
      cursor: grabbing;
    }

    .char-on-path.dragging {
      transition: none;
      filter: drop-shadow(0 0 15px rgba(255,255,0,1));
    }

    .swipe-hint {
      font-family: var(--font-game);
      font-size: 0.7rem;
      color: #90EE90;
      letter-spacing: 1px;
    }
  </style>

  <script>
    // Sound Effects Class
    class SoundEffects {
      private audioContext: any = null;

      init() {
        if (!this.audioContext) {
          this.audioContext = new (window.AudioContext || (window as any).webkitAudioContext)();
        }
      }

      playClick() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(800, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(400, this.audioContext.currentTime + 0.1);
        osc.type = 'square';
        gain.gain.setValueAtTime(0.1, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.1);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.1);
      }

      playPageTransition() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(400, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(800, this.audioContext.currentTime + 0.2);
        osc.type = 'square';
        gain.gain.setValueAtTime(0.1, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.2);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.2);
      }

      playSuccess() {
        this.init();
        const notes = [523, 659, 784];
        notes.forEach((freq, i) => {
          const osc = this.audioContext.createOscillator();
          const gain = this.audioContext.createGain();
          osc.connect(gain);
          gain.connect(this.audioContext.destination);
          osc.frequency.value = freq;
          osc.type = 'square';
          gain.gain.setValueAtTime(0.08, this.audioContext.currentTime + i * 0.1);
          gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + i * 0.1 + 0.15);
          osc.start(this.audioContext.currentTime + i * 0.1);
          osc.stop(this.audioContext.currentTime + i * 0.1 + 0.15);
        });
      }
    }

    const sound = new SoundEffects();
    (window as any).sound = sound;

    // Page Navigation
    class PageNavigator {
      private currentPage: string = 'page-welcome';
      private pageOrder: string[] = [
        'page-welcome',
        'page-whoami',
        'page-growth',
        'page-experience',
        'page-map',
        'page-projects-space',
        'page-projects-experience',
        'page-competitions',
        'page-skills',
        'page-contact'
      ];

      constructor() {
        this.init();
      }

      init() {
        // Lock scroll on first page
        this.lockScroll();

        // Listen for navigation events
        document.addEventListener('navigate', ((e: CustomEvent) => {
          const target = e.detail?.target;
          if (target) {
            this.goTo(target);
          }
        }) as EventListener);

        // Handle all button clicks with data-action
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const button = target.closest('[data-action]') as HTMLElement;
          if (button) {
            const action = button.dataset.action;
            if (action === 'next') {
              this.next();
            } else if (action === 'prev') {
              this.prev();
            } else if (action === 'goto') {
              const targetPage = button.dataset.goto;
              const company = button.dataset.company;
              if (targetPage) {
                if (company && targetPage === 'page-experience') {
                  window.location.href = `?experience=${company}`;
                } else {
                  this.goTo(targetPage);
                }
              }
            }
          }
        });

        // Initialize sound on first click
        document.addEventListener('click', () => sound.init(), { once: true });
      }

      lockScroll() {
        document.body.classList.add('scroll-locked');
      }

      unlockScroll() {
        document.body.classList.remove('scroll-locked');
      }

      goTo(pageId: string) {
        const current = document.getElementById(this.currentPage);
        const target = document.getElementById(pageId);

        if (!target || current?.id === pageId) return;

        // Play transition sound
        sound.playPageTransition();

        // Animate out current
        if (current) {
          current.classList.add('page-exit');
          current.classList.remove('active');
          setTimeout(() => {
            current.classList.remove('page-exit');
            current.style.display = 'none';
          }, 300);
        }

        // Animate in target
        setTimeout(() => {
          target.style.display = 'block';
          target.classList.add('active', 'page-enter');

          setTimeout(() => {
            target.classList.remove('page-enter');
          }, 400);

          this.currentPage = pageId;

          // Lock scroll if page has lock flag
          const shouldLock = target.dataset.lockScroll === 'true';
          if (shouldLock) {
            this.lockScroll();
          } else {
            this.unlockScroll();
          }
        }, 300);
      }

      next() {
        const currentIndex = this.pageOrder.indexOf(this.currentPage);
        if (currentIndex < this.pageOrder.length - 1) {
          this.goTo(this.pageOrder[currentIndex + 1]);
        }
      }

      prev() {
        const currentIndex = this.pageOrder.indexOf(this.currentPage);
        if (currentIndex > 0) {
          this.goTo(this.pageOrder[currentIndex - 1]);
        }
      }
    }

    // Initialize
    const navigator = new PageNavigator();
    (window as any).navigator = navigator;
    (window as any).navigateTo = (pageId: string) => navigator.goTo(pageId);

    // Handle hash navigation
    if (window.location.hash) {
      const pageId = 'page-' + window.location.hash.substring(1);
      setTimeout(() => navigator.goTo(pageId), 100);
    }

    // Update path nav on page change
    const originalGoTo = navigator.goTo.bind(navigator);
    navigator.goTo = function(pageId: string) {
      originalGoTo(pageId);
      updatePathNav(pageId);
    };

    function updatePathNav(pageId: string) {
      const steps = document.querySelectorAll('.path-step');
      const currentIndex = navigator.pageOrder.indexOf(pageId);
      steps.forEach((step, i) => {
        step.classList.remove('current');
        if (i < currentIndex) {
          step.classList.add('visited');
        } else {
          step.classList.remove('visited');
        }
        if (i === currentIndex) {
          step.classList.add('current');
        }
      });
      // Move char to current position
      const char = document.querySelector('.char-on-path') as HTMLElement;
      if (char) {
        const stepWidth = 22; // gap + width
        char.style.transform = `translateX(${currentIndex * stepWidth - 2}px)`;
      }
    }

    // Swipe navigation - Full-screen swipe gesture (not on drag character)
    let swipeStartX = 0;
    let swipeStartY = 0;

    document.addEventListener('touchstart', (e) => {
      // Only track if not touching the path-char element
      if (!e.target.closest('#path-char')) {
        swipeStartX = e.touches[0].clientX;
        swipeStartY = e.touches[0].clientY;
        console.log('[SWIPE START] x:', swipeStartX, 'y:', swipeStartY);
      }
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      // Skip if was touching the path-char element
      if (e.target.closest('#path-char')) return;
      const swipeEndX = e.changedTouches[0].clientX;
      const swipeEndY = e.changedTouches[0].clientY;
      const deltaX = swipeEndX - swipeStartX;
      const deltaY = Math.abs(swipeEndY - swipeStartY);
      console.log('[SWIPE END] deltaX:', deltaX, 'deltaY:', deltaY, 'threshold check:', Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY);

      if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY) {
        if (deltaX < 0) {
          console.log('[SWIPE] Going to next page via swipe');
          navigator.next();
        } else {
          console.log('[SWIPE] Going to previous page via swipe');
          navigator.prev();
        }
      }
    }, { passive: true });

    // Initialize path nav
    updatePathNav('page-welcome');
  </script>

  <style is:global>
    .page-enter {
      animation: pixelEnter 0.4s ease-out forwards;
    }

    .page-exit {
      animation: pixelExit 0.3s ease-in forwards;
    }

    @keyframes pixelEnter {
      0% {
        opacity: 0;
        transform: translateX(40px);
        filter: blur(4px);
      }
      100% {
        opacity: 1;
        transform: translateX(0);
        filter: blur(0);
      }
    }

    @keyframes pixelExit {
      0% {
        opacity: 1;
        transform: translateX(0);
        filter: blur(0);
      }
      100% {
        opacity: 0;
        transform: translateX(-40px);
        filter: blur(4px);
      }
    }

    /* Scanlines overlay */
    body::after {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: repeating-linear-gradient(
        0deg,
        rgba(0, 0, 0, 0.08) 0px,
        rgba(0, 0, 0, 0.08) 1px,
        transparent 1px,
        transparent 2px
      );
      pointer-events: none;
      z-index: 9998;
    }

    /* Pixel glow effects */
    .pixel-glow-green {
      color: #00ff88;
      text-shadow: 0 0 5px #00ff88, 0 0 10px #00ff88, 2px 2px 0 #000;
    }

    .pixel-glow-yellow {
      color: #ffff00;
      text-shadow: 0 0 5px #ffff00, 0 0 10px #ffff00, 2px 2px 0 #5d4a00;
    }

    .pixel-glow-cyan {
      color: #00ffff;
      text-shadow: 0 0 5px #00ffff, 0 0 10px #00ffff, 2px 2px 0 #005555;
    }
  </style>

  <!-- Path Navigation - Fixed at bottom -->
  <div id="path-nav">
    <div class="path-container">
      <div class="arrow-hint left">◀</div>
      <div class="path-trail">
        <div class="nav-progress-track">
          <div class="nav-progress-fill" id="nav-progress-fill"></div>
        </div>
      </div>
      <div class="arrow-hint right">▶</div>
      <div class="char-on-path" id="path-char">👩‍🌾</div>
    </div>
    <div class="swipe-hint">拖动 ▶ 切换</div>
  </div>

  <script>
    // Drag Navigation
    // All 10 pages for drag navigation
    const ALL_NAV_PAGES = [
      'page-welcome',              // 0
      'page-whoami',               // 1
      'page-growth',               // 2
      'page-experience',           // 3
      'page-map',                  // 4
      'page-projects-space',       // 5
      'page-projects-experience',  // 6
      'page-competitions',         // 7
      'page-skills',               // 8
      'page-contact'              // 9
    ];

    const pathChar = document.getElementById('path-char');
    const progressFill = document.getElementById('nav-progress-fill');
    const navTrack = document.querySelector('.nav-progress-track') as HTMLElement;
    const totalNavPages = ALL_NAV_PAGES.length; // 10 pages
    let currentDragIndex = 0;
    let isDragging = false;
    let startX = 0;
    let startY = 0;
    let currentX = 0;
    let currentY = 0;
    // Get actual track width dynamically
    let maxOffset = 200;
    let trackWidth = 200;

    function updateDragPosition(pageIndex, animate = true) {
      currentDragIndex = pageIndex;
      const offset = (pageIndex / (totalNavPages - 1)) * maxOffset;
      pathChar.style.transition = animate ? 'left 0.3s ease-out' : 'none';
      pathChar.style.left = (8 + offset) + 'px';
      progressFill.style.width = (pageIndex / (totalNavPages - 1) * 100) + '%';
    }

    // Initialize - get actual track width
    function initTrackWidth() {
      if (navTrack) {
        trackWidth = navTrack.offsetWidth;
        maxOffset = trackWidth;
        console.log('[INIT] Track width:', trackWidth, 'maxOffset:', maxOffset);
      }
      updateDragPosition(0, false);
    }

    // Initialize drag position
    initTrackWidth();

    // Update track width on window resize
    window.addEventListener('resize', () => {
      if (navTrack) {
        trackWidth = navTrack.offsetWidth;
        maxOffset = trackWidth;
        console.log('[RESIZE] Track width updated:', trackWidth);
      }
    });

    pathChar.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      pathChar.classList.add('dragging');
      e.preventDefault();
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      currentX = e.clientX;
      const deltaX = currentX - startX;
      const currentOffset = (currentDragIndex / (totalNavPages - 1)) * maxOffset;
      const newOffset = Math.max(0, Math.min(maxOffset, currentOffset + deltaX));
      pathChar.style.left = (8 + newOffset) + 'px';
      progressFill.style.width = (newOffset / maxOffset * 100) + '%';
    });

    document.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      pathChar.classList.remove('dragging');

      const deltaX = currentX - startX;
      const threshold = 30;

      if (deltaX > threshold && currentDragIndex < totalNavPages - 1) {
        // Next page
        const nextIndex = currentDragIndex + 1;
        updateDragPosition(nextIndex);
        if (window.navigateTo) window.navigateTo(ALL_NAV_PAGES[nextIndex]);
      } else if (deltaX < -threshold && currentDragIndex > 0) {
        // Previous page
        const prevIndex = currentDragIndex - 1;
        updateDragPosition(prevIndex);
        if (window.navigateTo) window.navigateTo(ALL_NAV_PAGES[prevIndex]);
      } else {
        // Snap back
        updateDragPosition(currentDragIndex);
      }
    });

    // Touch events - attach to character directly
    let touchCharStartX = 0;
    let touchCharStartY = 0;
    let touchStartCharLeft = 0;

    pathChar.addEventListener('touchstart', (e) => {
      isDragging = true;
      touchCharStartX = e.touches[0].clientX;
      touchCharStartY = e.touches[0].clientY;
      startX = e.touches[0].clientX;
      // Get current left position of the character
      touchStartCharLeft = parseInt(pathChar.style.left) || 8;
      console.log('[TOUCH START] x:', e.touches[0].clientX, 'y:', e.touches[0].clientY, 'charLeft:', touchStartCharLeft);
      pathChar.classList.add('dragging');
      e.preventDefault();
    }, { passive: false });

    pathChar.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      currentX = e.touches[0].clientX;
      currentY = e.touches[0].clientY;
      const deltaX = currentX - startX;
      const deltaY = Math.abs(currentY - touchCharStartY);
      console.log('[TOUCH MOVE] deltaX:', deltaX, 'deltaY:', deltaY);
      // Only horizontal drag moves the char
      // Always prevent default for touchmove on char to avoid scrolling
      e.preventDefault();
      // Remove transition during drag for immediate response
      pathChar.style.transition = 'none';
      const currentOffset = (currentDragIndex / (totalNavPages - 1)) * maxOffset;
      const newOffset = Math.max(0, Math.min(maxOffset, currentOffset + deltaX));
      pathChar.style.left = (8 + newOffset) + 'px';
      progressFill.style.width = (newOffset / maxOffset * 100) + '%';
    }, { passive: false });

    pathChar.addEventListener('touchend', (e) => {
      console.log('[TOUCH END] isDragging:', isDragging);
      console.log('[TOUCH END] currentX:', currentX, 'startX:', startX);

      if (!isDragging) {
        console.log('[TOUCH END] Early return - isDragging is false');
        return;
      }
      isDragging = false;
      pathChar.classList.remove('dragging');

      const deltaX = currentX - startX;
      const charLeft = parseFloat(pathChar.style.left) || 8;
      console.log('[TOUCH END] deltaX:', deltaX, 'charLeft:', charLeft, 'currentDragIndex:', currentDragIndex);

      // Calculate position thresholds based on actual track width
      const rightEdge = 8 + maxOffset; // Right edge of track
      const leftEdge = 8; // Left edge of track
      const threshold = 30;

      console.log('[TOUCH END] rightEdge:', rightEdge, 'leftEdge:', leftEdge, 'maxOffset:', maxOffset);

      // Primary: Check if at edges first (regardless of deltaX)
      if (charLeft >= rightEdge - 10 && currentDragIndex < totalNavPages - 1) {
        // At rightmost position → go to next page
        console.log('[TOUCH END] At RIGHT edge, going to next page');
        const nextIndex = currentDragIndex + 1;
        updateDragPosition(nextIndex);
        if (window.navigateTo) window.navigateTo(ALL_NAV_PAGES[nextIndex]);
      } else if (charLeft <= leftEdge + 10 && currentDragIndex > 0) {
        // At leftmost position → go to previous page
        console.log('[TOUCH END] At LEFT edge, going to previous page');
        const prevIndex = currentDragIndex - 1;
        updateDragPosition(prevIndex);
        if (window.navigateTo) window.navigateTo(ALL_NAV_PAGES[prevIndex]);
      } else if (deltaX > threshold && currentDragIndex < totalNavPages - 1) {
        // Dragged right enough → next page
        console.log('[TOUCH END] DeltaX positive, going to next page');
        const nextIndex = currentDragIndex + 1;
        updateDragPosition(nextIndex);
        if (window.navigateTo) window.navigateTo(ALL_NAV_PAGES[nextIndex]);
      } else if (deltaX < -threshold && currentDragIndex > 0) {
        // Dragged left enough → previous page
        console.log('[TOUCH END] DeltaX negative, going to previous page');
        const prevIndex = currentDragIndex - 1;
        updateDragPosition(prevIndex);
        if (window.navigateTo) window.navigateTo(ALL_NAV_PAGES[prevIndex]);
      } else {
        // Snap back
        console.log('[TOUCH END] Snapping back');
        updateDragPosition(currentDragIndex);
      }

      e.preventDefault();
    }, { passive: false });

    pathChar.addEventListener('touchcancel', () => {
      isDragging = false;
      pathChar.classList.remove('dragging');
      updateDragPosition(currentDragIndex);
    });

    // Full-screen swipe gesture to change pages (not on drag character)
    let swipeStartX = 0;
    let swipeStartY = 0;

    document.addEventListener('touchstart', (e) => {
      if (!e.target.closest('#path-char')) {
        swipeStartX = e.touches[0].clientX;
        swipeStartY = e.touches[0].clientY;
      }
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      // Skip if path-char was being dragged - let path-char touchend handle it
      if (e.target.closest('#path-char')) return;
      // Also skip if isDragging is true (might be a delayed event)
      if (isDragging) return;
      const swipeEndX = e.changedTouches[0].clientX;
      const swipeEndY = e.changedTouches[0].clientY;
      const deltaX = swipeEndX - swipeStartX;
      const deltaY = Math.abs(swipeEndY - swipeStartY);
      console.log('[SWIPE END] deltaX:', deltaX, 'deltaY:', deltaY, 'threshold check:', Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY);

      if (Math.abs(deltaX) > 50 && Math.abs(deltaX) > deltaY) {
        if (deltaX < 0) {
          console.log('[SWIPE END] Going to next page via swipe');
          navigator.next();
        } else {
          console.log('[SWIPE END] Going to previous page via swipe');
          navigator.prev();
        }
      }
    }, { passive: true });

    // Sync drag position with page navigation
    // Override navigateTo to sync drag position when pages change
    const originalNavigateTo = (window as any).navigateTo;
    (window as any).navigateTo = function(pageId: string) {
      console.log('[DEBUG] navigateTo called with:', pageId);
      if (originalNavigateTo) {
        originalNavigateTo(pageId);
      } else {
        console.log('[DEBUG] originalNavigateTo is undefined, calling navigator.goTo directly');
        navigator.goTo(pageId);
      }
      const pageIndex = ALL_NAV_PAGES.indexOf(pageId);
      console.log('[DEBUG] pageIndex:', pageIndex);
      if (pageIndex !== -1) {
        setTimeout(() => {
          console.log('[DEBUG] Updating drag position to:', pageIndex);
          updateDragPosition(pageIndex, true);
        }, 400);
      }
    };
  </script>
</body>
</html>
