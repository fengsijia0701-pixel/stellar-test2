---
import BaseLayout from '../layouts/BaseLayout.astro';
import WelcomeSection from '../components/WelcomeSection.astro';
import WhoAmISection from '../components/WhoAmISection.astro';
import GrowthTrackSection from '../components/GrowthTrackSection.astro';
import RPGMapSection from '../components/RPGMapSection.astro';
import ProjectsSpace from '../components/ProjectsSpace.astro';
import ProjectsExperience from '../components/ProjectsExperience.astro';
import CompetitionsSection from '../components/CompetitionsSection.astro';
import SkillsSection from '../components/SkillsSection.astro';
import ContactSection from '../components/ContactSection.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>冯思佳 | 产品/运营/市场营销</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Page Container - Full Screen Pages -->
  <div id="app">
    <!-- Page 1: Welcome -->
    <section id="page-welcome" class="page active" data-lock-scroll="true">
      <WelcomeSection />
    </section>

    <!-- Page 2: Who Am I -->
    <section id="page-whoami" class="page" data-lock-scroll="true">
      <WhoAmISection />
    </section>

    <!-- Page 3: Growth Track -->
    <section id="page-growth" class="page" data-lock-scroll="true">
      <GrowthTrackSection />
    </section>

    <!-- Page 4: RPG Map -->
    <section id="page-map" class="page" data-lock-scroll="true">
      <RPGMapSection />
    </section>

    <!-- Branch Pages -->
    <section id="page-projects-space" class="page" data-lock-scroll="true">
      <ProjectsSpace />
    </section>

    <section id="page-projects-experience" class="page" data-lock-scroll="true">
      <ProjectsExperience />
    </section>

    <section id="page-competitions" class="page" data-lock-scroll="true">
      <CompetitionsSection />
    </section>

    <section id="page-skills" class="page" data-lock-scroll="true">
      <SkillsSection />
    </section>

    <section id="page-contact" class="page" data-lock-scroll="true">
      <ContactSection />
    </section>
  </div>

  <style is:global>
    :root {
      --color-wood: #8B5A2B;
      --color-wood-dark: #5D4037;
      --color-wood-light: #A67C52;
      --color-grass: #7CB342;
      --color-sky: #64B5F6;
      --color-gold: #FFD700;
      --color-parchment: #F5E6C8;
      --color-cream: #FFF8E7;
      --color-text: #5D4037;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      font-family: 'Gaegu', cursive, sans-serif;
      overflow: hidden;
      height: 100%;
      width: 100%;
    }

    body {
      overflow: hidden;
    }

    /* Page Container */
    #app {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    /* Page Base */
    .page {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.4s ease, visibility 0.4s;
      overflow: hidden;
    }

    .page.active {
      opacity: 1;
      visibility: visible;
    }

    /* Fullscreen sections */
    .fullscreen-section {
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    /* Scroll locked state */
    body.scroll-locked {
      overflow: hidden;
      position: fixed;
      width: 100%;
      height: 100%;
    }
  </style>

  <script>
    // Sound Effects Class
    class SoundEffects {
      private audioContext: any = null;

      init() {
        if (!this.audioContext) {
          this.audioContext = new (window.AudioContext || (window as any).webkitAudioContext)();
        }
      }

      playClick() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(800, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(400, this.audioContext.currentTime + 0.1);
        osc.type = 'square';
        gain.gain.setValueAtTime(0.1, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.1);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.1);
      }

      playPageTransition() {
        this.init();
        const osc = this.audioContext.createOscillator();
        const gain = this.audioContext.createGain();
        osc.connect(gain);
        gain.connect(this.audioContext.destination);
        osc.frequency.setValueAtTime(400, this.audioContext.currentTime);
        osc.frequency.exponentialRampToValueAtTime(800, this.audioContext.currentTime + 0.2);
        osc.type = 'square';
        gain.gain.setValueAtTime(0.1, this.audioContext.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + 0.2);
        osc.start();
        osc.stop(this.audioContext.currentTime + 0.2);
      }

      playSuccess() {
        this.init();
        const notes = [523, 659, 784];
        notes.forEach((freq, i) => {
          const osc = this.audioContext.createOscillator();
          const gain = this.audioContext.createGain();
          osc.connect(gain);
          gain.connect(this.audioContext.destination);
          osc.frequency.value = freq;
          osc.type = 'square';
          gain.gain.setValueAtTime(0.08, this.audioContext.currentTime + i * 0.1);
          gain.gain.exponentialRampToValueAtTime(0.01, this.audioContext.currentTime + i * 0.1 + 0.15);
          osc.start(this.audioContext.currentTime + i * 0.1);
          osc.stop(this.audioContext.currentTime + i * 0.1 + 0.15);
        });
      }
    }

    const sound = new SoundEffects();
    (window as any).sound = sound;

    // Page Navigation
    class PageNavigator {
      private currentPage: string = 'page-welcome';
      private pageOrder: string[] = [
        'page-welcome',
        'page-whoami',
        'page-growth',
        'page-map',
        'page-projects-space',
        'page-projects-experience',
        'page-competitions',
        'page-skills',
        'page-contact'
      ];

      constructor() {
        this.init();
      }

      init() {
        // Lock scroll on first page
        this.lockScroll();

        // Listen for navigation events
        document.addEventListener('navigate', ((e: CustomEvent) => {
          const target = e.detail?.target;
          if (target) {
            this.goTo(target);
          }
        }) as EventListener);

        // Handle all button clicks with data-action
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const button = target.closest('[data-action]') as HTMLElement;
          if (button) {
            const action = button.dataset.action;
            if (action === 'next') {
              this.next();
            } else if (action === 'prev') {
              this.prev();
            } else if (action === 'goto') {
              const targetPage = button.dataset.goto;
              if (targetPage) {
                this.goTo(targetPage);
              }
            }
          }
        });

        // Initialize sound on first click
        document.addEventListener('click', () => sound.init(), { once: true });
      }

      lockScroll() {
        document.body.classList.add('scroll-locked');
      }

      unlockScroll() {
        document.body.classList.remove('scroll-locked');
      }

      goTo(pageId: string) {
        const current = document.getElementById(this.currentPage);
        const target = document.getElementById(pageId);

        if (!target || current?.id === pageId) return;

        // Play transition sound
        sound.playPageTransition();

        // Animate out current
        if (current) {
          current.classList.add('page-exit');
          current.classList.remove('active');
          setTimeout(() => {
            current.classList.remove('page-exit');
            current.style.display = 'none';
          }, 300);
        }

        // Animate in target
        setTimeout(() => {
          target.style.display = 'block';
          target.classList.add('active', 'page-enter');

          setTimeout(() => {
            target.classList.remove('page-enter');
          }, 400);

          this.currentPage = pageId;

          // Lock scroll if page has lock flag
          const shouldLock = target.dataset.lockScroll === 'true';
          if (shouldLock) {
            this.lockScroll();
          } else {
            this.unlockScroll();
          }
        }, 300);
      }

      next() {
        const currentIndex = this.pageOrder.indexOf(this.currentPage);
        // Branch pages (after map) don't auto-next
        if (currentIndex >= 3 && currentIndex < this.pageOrder.length - 1) {
          const nextIndex = currentIndex + 1;
          this.goTo(this.pageOrder[nextIndex]);
        } else if (currentIndex < 3) {
          const nextIndex = currentIndex + 1;
          this.goTo(this.pageOrder[nextIndex]);
        }
      }

      prev() {
        const currentIndex = this.pageOrder.indexOf(this.currentPage);
        if (currentIndex > 0) {
          const prevIndex = currentIndex - 1;
          // If going back from a branch page, go to map
          if (currentIndex > 3) {
            this.goTo('page-map');
          } else {
            this.goTo(this.pageOrder[prevIndex]);
          }
        }
      }
    }

    // Initialize
    const navigator = new PageNavigator();
    (window as any).navigator = navigator;
    (window as any).navigateTo = (pageId: string) => navigator.goTo(pageId);

    // Handle hash navigation
    if (window.location.hash) {
      const pageId = 'page-' + window.location.hash.substring(1);
      setTimeout(() => navigator.goTo(pageId), 100);
    }
  </script>

  <style is:global>
    .page-enter {
      animation: pageEnter 0.4s ease-out forwards;
    }

    .page-exit {
      animation: pageExit 0.3s ease-in forwards;
    }

    @keyframes pageEnter {
      from { opacity: 0; transform: translateX(30px); }
      to { opacity: 1; transform: translateX(0); }
    }

    @keyframes pageExit {
      from { opacity: 1; transform: translateX(0); }
      to { opacity: 0; transform: translateX(-30px); }
    }
  </style>
</body>
</html>